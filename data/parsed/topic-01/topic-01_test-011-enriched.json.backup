  {
    "topic_number": 1,
    "question_number": 18,
    "category": "B",
    "question": {
      "es": "Circula por un carril delimitado por marcas longitudinales dobles discontinuas en vía urbana, ¿qué precauciones debe adoptar?",
      "en": null,
      "ru": null
    },
    "answers": [
      {
        "id": "a",
        "text": {
          "es": "Encender la luz de cruce o corto alcance, tanto de día como de noche, y no invadir el carril situado más a la izquierda.",
          "en": null,
          "ru": null
        },
        "is_correct": true
      },
      {
        "id": "b",
        "text": {
          "es": "Encender la señal de emergencia, además de la luz de cruce, tanto de día como de noche.",
          "en": null,
          "ru": null
        },
        "is_correct": false
      },
      {
        "id": "c",
        "text": {
          "es": "Circular como mínimo a 60 km/h y como máximo a 80 km/h.",
          "en": null,
          "ru": null
        },
        "is_correct": false
      }
    ],
    "explanation": {
      "es": null,
      "en": null,
      "ru": null
    },
