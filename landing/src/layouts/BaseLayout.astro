---
export interface Props {
  title: string;
  description: string;
  canonical: string;
  lang: string;
  ogImage?: string;
  jsonLd?: object | object[];
  hreflang?: { lang: string; href: string }[];
}

const {
  title,
  description,
  canonical,
  lang,
  ogImage = 'https://skilyapp.com/og-ru.jpg',
  jsonLd,
  hreflang = [],
} = Astro.props;

const jsonLdArray = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#09090b" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Hreflang -->
    {hreflang.map(h => (
      <link rel="alternate" hreflang={h.lang} href={h.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href="https://skilyapp.com" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Skily" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Robots -->
    <meta name="robots" content="index, follow" />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Fonts: Inter via Google (subset) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
    />

    <!-- JSON-LD Structured Data (GEO) -->
    {jsonLdArray.map(schema => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- Yandex.Metrika counter -->
    <script type="text/javascript">
      (function () {
        var hostname = window.location.hostname;
        var counterId = null;

        if (hostname === 'skilyapp.com' || hostname.endsWith('.skilyapp.com')) {
          counterId = 108379787;
        } else if (hostname === 'sdadim.eu' || hostname.endsWith('.sdadim.eu')) {
          counterId = 108379913;
        }

        if (!counterId) return;

        (function(m,e,t,r,i,k,a){
            m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
            m[i].l=1*new Date();
            for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
            k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
        })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=' + counterId, 'ym');

        ym(counterId, 'init', {
          webvisor: true,
          trackHash: true,
          clickmap: true,
          ecommerce: "dataLayer",
          accurateTrackBounce: true,
          trackLinks: true
        });
      })();
    </script>
    <noscript>
      <div>
        <img src="https://mc.yandex.ru/watch/108379787" style="position:absolute; left:-9999px;" alt="" />
      </div>
    </noscript>
    <!-- /Yandex.Metrika counter -->

    <!-- Microsoft Clarity -->
    <script type="text/javascript">
      (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "wr5d4m9nrf");
    </script>
    <!-- /Microsoft Clarity -->

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-18034090184"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'AW-18034090184');
    </script>
    <!-- /Google tag -->

    <!-- Axeptio Cookie Consent Management -->
    <script>
      window.axeptioSettings = {
        clientId: "69a1acef0a02cdc0f86b3b4e",
        cookiesVersion: "a9f70806-d61a-4b9c-897b-f1e641f17590"
      };
      // Hide the persistent badge after user makes a choice
      window._axcb = window._axcb || [];
      window._axcb.push(function(axeptio) {
        axeptio.on('cookies:complete', function() {
          var btn = document.getElementById('axeptio_btn');
          if (btn) btn.style.setProperty('display', 'none', 'important');
        });
      });
    </script>
    <script async src="https://static.axeptio.eu/sdk.js"></script>
    <style>
      /* Hide Axeptio persistent badge — consent is stored, banner won't reappear */
      #axeptio_btn { display: none !important; }
    </style>

    <!-- Start Engine Button Styles -->
    <style is:global>
      /* Scale wrapper: 68% mobile, 100% md+ */
      .engine-scale-wrapper {
        transform: scale(0.68);
        transform-origin: center;
        margin: -34px 0;
      }
      @media (min-width: 768px) {
        .engine-scale-wrapper { transform: scale(1.0); margin: -2px 0; }
      }
      /* Стрелку убрали — создавала visual noise */
      .engine-arrow-guide { display: none; }

      /* Outer button element — 220×220, relative container for all layers */
      .engine-btn-outer {
        position: relative;
        width: 220px;
        height: 220px;
        border-radius: 50%;
        cursor: pointer;
        background: transparent;
        border: none;
        padding: 0;
        -webkit-tap-highlight-color: transparent;
        user-select: none;
        transition: transform 0.2s ease;
        display: block;
      }
      .engine-btn-outer:hover { transform: scale(1.05); }
      .engine-btn-outer:active { transform: scale(0.95); }
      .engine-btn-outer.engine-shaking { animation: engine-shake 0.6s cubic-bezier(0.36,0.07,0.19,0.97) infinite; }

      /* Indigo glow — inside button, 50% bleed on all sides */
      .engine-glow {
        position: absolute;
        inset: -50%;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(99,102,241,0.4) 0%, rgba(99,102,241,0) 70%);
        opacity: 0;
        transition: opacity 0.5s;
        pointer-events: none;
      }
      .engine-btn-outer:hover .engine-glow { opacity: 0.6; }
      .engine-btn-outer.engine-igniting .engine-glow { opacity: 1; }

      /* Blue metallic ring */
      .engine-ring-layer {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        background: conic-gradient(#1e3a8a 0%, #2563eb 15%, #3b82f6 30%, #818cf8 50%, #3b82f6 70%, #2563eb 85%, #1e3a8a 100%);
        box-shadow: 0 20px 50px rgba(0,0,0,0.8), inset 0 2px 5px rgba(99,102,241,0.5),
                    0 0 22px rgba(59,130,246,0.35), 0 0 44px rgba(99,102,241,0.15);
        padding: 12px;
        z-index: 10;
        transition: box-shadow 0.45s ease;
      }
      .engine-btn-outer:hover .engine-ring-layer {
        box-shadow: 0 20px 50px rgba(0,0,0,0.8), inset 0 2px 5px rgba(99,102,241,0.7),
                    0 0 40px rgba(56,189,248,0.65), 0 0 80px rgba(56,189,248,0.3);
      }

      /* Dark circle layer — bg #111 with recessed shadow */
      .engine-dark-circle {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        background: #111;
        box-shadow: inset 0 5px 15px rgba(0,0,0,0.9);
        padding: 6px;
      }

      /* Gradient inner circle — the main button face */
      .engine-inner-circle {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        background: linear-gradient(to bottom, #0d1f3c, #040810);
        border-top: 1px solid rgba(99,102,241,0.35);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
      }
      .engine-btn-outer.engine-igniting .engine-inner-circle { border-color: rgba(99,102,241,0.5); }

      /* Radial white overlay — subtle center highlight */
      .engine-radial-overlay {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        background: radial-gradient(circle at center, rgba(255,255,255,0.2) 0%, transparent 100%);
        opacity: 0.2;
        pointer-events: none;
      }

      /* Loading bar — at top, 8px tall */
      .engine-bar-track {
        width: 64px;
        height: 8px;
        border-radius: 999px;
        background: rgba(0,0,0,0.8);
        margin-bottom: 16px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.05);
        box-shadow: inset 0 1px 3px rgba(0,0,0,1);
        position: relative;
        z-index: 1;
        flex-shrink: 0;
      }
      .engine-bar-fill {
        height: 100%;
        border-radius: 999px;
        width: 0%;
        background: linear-gradient(to right, #1d4ed8, #38bdf8);
        box-shadow: 0 0 10px rgba(56,189,248,0.8);
        transition: width 1.5s ease-out;
      }

      /* Icon + labels group */
      .engine-content-group {
        display: flex;
        flex-direction: column;
        align-items: center;
        position: relative;
        z-index: 10;
      }
      .engine-power-icon {
        width: 36px;
        height: 36px;
        margin-bottom: 8px;
        color: #60a5fa;
        filter: drop-shadow(0 0 8px rgba(59,130,246,0.6));
        transition: color 0.3s, filter 0.3s;
      }
      .engine-btn-outer:hover .engine-power-icon,
      .engine-btn-outer.engine-igniting .engine-power-icon { color: white; filter: drop-shadow(0 0 12px rgba(99,102,241,0.9)); }

      .engine-lbl-engine {
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: #93c5fd;
        line-height: 1;
        font-family: inherit;
        transition: color 0.3s;
      }
      .engine-btn-outer:hover .engine-lbl-engine,
      .engine-btn-outer.engine-igniting .engine-lbl-engine { color: #ffffff; }

      .engine-lbl-ss {
        font-size: 10px;
        color: #374151;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin-top: 4px;
        font-family: inherit;
      }

      /* Ambient bottom glow inside circle */
      .engine-ambient-light {
        position: absolute;
        bottom: 12px;
        left: 50%;
        transform: translateX(-50%);
        width: 90px;
        height: 36px;
        background: rgba(59,130,246,0.25);
        filter: blur(10px);
        border-radius: 50% 50% 0 0;
        opacity: 0.8;
        pointer-events: none;
      }

      /* PRESS START separator */
      .engine-press-row {
        display: flex;
        align-items: center;
        gap: 16px;
        opacity: 0.6;
        margin-top: 4px;
      }
      .engine-sep-line {
        height: 1px;
        width: 48px;
        background: linear-gradient(to right, transparent, #64748b);
      }
      .engine-sep-line-right { background: linear-gradient(to left, transparent, #64748b); }
      .engine-sep-text {
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.2em;
        color: #64748b;
        white-space: nowrap;
        font-family: inherit;
      }

      /* Fallback link */
      .engine-demo-link {
        font-size: 12px;
        color: #64748b;
        text-decoration: none;
        transition: color 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        font-family: inherit;
        margin-top: 4px;
      }
      .engine-demo-link:hover { color: #cbd5e1; }

      @keyframes engine-shake {
        0%, 100% { transform: translate3d(0, 0, 0); }
        25% { transform: translate3d(-1.5%, -1.5%, 0); }
        50% { transform: translate3d(1.5%, 1.5%, 0); }
        75% { transform: translate3d(-1%, 1%, 0); }
      }

      /* Pulse rings */
      .engine-pulse-ring {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        border: 1px solid rgba(99, 102, 241, 0.2);
        animation: engine-pulse-expand 5s cubic-bezier(0, 0, 0.2, 1) infinite;
        pointer-events: none;
        z-index: 0;
      }
      .engine-btn-outer > .engine-pulse-ring:nth-child(3) { animation-delay: 1.6s; }
      .engine-btn-outer > .engine-pulse-ring:nth-child(4) { animation-delay: 3.2s; }

      .engine-btn-outer.engine-shaking .engine-pulse-ring,
      .engine-btn-outer.engine-igniting .engine-pulse-ring {
        animation: none;
        opacity: 0;
      }

      @keyframes engine-pulse-expand {
        0%   { transform: scale(1);    opacity: 0.35; }
        60%  { opacity: 0.08; }
        100% { transform: scale(1.7);  opacity: 0; }
      }

      /* Directional arrow — neon */
      .engine-arrow-guide {
        display: block;
        flex-shrink: 0;
        overflow: visible;
        filter: drop-shadow(0 0 4px rgba(56,189,248,0.55)) drop-shadow(0 0 10px rgba(56,189,248,0.25));
        animation: engine-arrow-glow 2.6s ease-in-out 1.9s infinite;
      }
      .engine-arrow-guide .arrow-line {
        stroke-dasharray: 82;
        stroke-dashoffset: 82;
        animation: engine-arrow-draw 0.9s cubic-bezier(0.22,1,0.36,1) 0.7s forwards;
      }
      .engine-arrow-guide .arrow-head {
        opacity: 0;
        animation: engine-arrow-head 0.28s ease-out 1.5s forwards;
      }
      @keyframes engine-arrow-draw { to { stroke-dashoffset: 0; } }
      @keyframes engine-arrow-head {
        from { opacity: 0; transform: translateY(-4px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      @keyframes engine-arrow-glow {
        0%, 100% { filter: drop-shadow(0 0 3px rgba(56,189,248,0.45)) drop-shadow(0 0 7px rgba(56,189,248,0.2)); opacity: 0.72; }
        50%       { filter: drop-shadow(0 0 9px rgba(56,189,248,0.95)) drop-shadow(0 0 20px rgba(56,189,248,0.5)); opacity: 1; }
      }

      /* "Pulsa para empezar" shimmer label */
      .engine-pulsa-label {
        display: block;
        margin-top: 16px;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: none;
        text-align: center;
        background: linear-gradient(90deg, #475569 0%, #94a3b8 30%, #e2e8f0 50%, #94a3b8 70%, #475569 100%);
        background-size: 260% auto;
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        animation: pulsa-shimmer 6s linear 2s infinite;
      }
      @keyframes pulsa-shimmer {
        0%   { background-position: 200% center; }
        100% { background-position: -200% center; }
      }

      /* Social proof strip (bottom of hero) */
      .hero-social-proof {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        opacity: 0.85;
      }
      .hero-social-sep {
        display: inline-block;
        width: 1px;
        height: 13px;
        background: #334155;
        flex-shrink: 0;
      }

      /* ── Product slider ───────────────────────────────────────────── */
      .product-slider { position: relative; width: 100%; }

      /* Browser frame (replaces MacBook) */
      .browser-frame {
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid rgba(99,102,241,0.18);
        background: #080f1e;
        box-shadow:
          0 0 0 1px rgba(15,23,42,0.9),
          0 40px 100px rgba(0,0,0,0.65),
          0 0 0 1px rgba(99,102,241,0.08) inset,
          0 0 80px rgba(59,130,246,0.1);
      }

      /* MacBook frame */
      /* MacBook outer lid — space gray aluminium */
      .macbook-frame {
        background: linear-gradient(180deg, #636368 0%, #535358 50%, #4a4a50 100%);
        border-radius: 18px 18px 0 0;
        padding: 22px 22px 0;
        box-shadow:
          0 0 0 1px rgba(0,0,0,0.5),
          0 0 0 2px rgba(255,255,255,0.08),
          0 70px 140px -20px rgba(0,0,0,0.95),
          0 0 160px rgba(59,130,246,0.2);
        position: relative;
      }
      /* Camera dot */
      .macbook-cam {
        position: absolute;
        top: 8px; left: 50%; transform: translateX(-50%);
        width: 8px; height: 8px;
        background: radial-gradient(circle at 35% 35%, #555, #222);
        border-radius: 50%;
        border: 1px solid rgba(0,0,0,0.7);
        z-index: 2;
        box-shadow: 0 0 0 2px rgba(0,0,0,0.3);
      }
      .macbook-cam::after {
        content: '';
        position: absolute;
        top: 2px; left: 2px;
        width: 3px; height: 3px;
        background: rgba(255,255,255,0.12);
        border-radius: 50%;
      }
      /* Screen area — no extra border, frame itself creates the bezel */
      .macbook-inner {
        border-radius: 3px 3px 0 0;
        overflow: hidden;
        position: relative;
        background: #0f172a;
      }
      /* Keyboard chassis — silver aluminium */
      .macbook-deck {
        background: linear-gradient(180deg,
          #d2d2da 0%,
          #c4c4cc 25%,
          #b8b8c0 60%,
          #c0c0c8 100%
        );
        height: 34px;
        border-radius: 0 0 4px 4px;
        position: relative;
        box-shadow:
          inset 0 1px 0 rgba(255,255,255,0.5),
          inset 0 -1px 0 rgba(0,0,0,0.15),
          0 8px 40px rgba(0,0,0,0.8);
      }
      /* Hinge shadow line at top of deck */
      .macbook-deck::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent 3%, rgba(0,0,0,0.35) 15%, rgba(0,0,0,0.35) 85%, transparent 97%);
      }
      /* Trackpad indent hint */
      .macbook-deck::after {
        content: '';
        position: absolute;
        top: 50%; left: 50%; transform: translate(-50%, -50%);
        width: 26%; height: 55%;
        background: linear-gradient(180deg, rgba(0,0,0,0.06), rgba(0,0,0,0.03));
        border-radius: 3px;
        border: 1px solid rgba(0,0,0,0.07);
      }

      .product-slider-frame {
        position: relative;
        aspect-ratio: 1280/650;
        background: #0f172a;
        overflow: hidden;
      }
      /* MacBook stand below deck */
      .macbook-stand-wrap {
        display: flex;
        justify-content: center;
      }
      .macbook-stand {
        width: 38%;
        height: 10px;
        background: linear-gradient(180deg, #b8b8c0 0%, #a8a8b0 100%);
        border-radius: 0 0 14px 14px;
        box-shadow: 0 6px 30px rgba(0,0,0,0.6), inset 0 -1px 0 rgba(0,0,0,0.2);
        position: relative;
      }
      .macbook-stand::after {
        content: '';
        position: absolute;
        bottom: 0; left: -18%; right: -18%;
        height: 4px;
        background: linear-gradient(90deg, transparent, rgba(0,0,0,0.25) 20%, rgba(0,0,0,0.25) 80%, transparent);
        border-radius: 0 0 20px 20px;
      }
      .slide-img {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0;
        transition: opacity 0.6s ease;
        pointer-events: none;
      }
      .slide-img.active { opacity: 1; pointer-events: auto; }

      /* Caption strip */
      .slider-caption {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        margin-top: 28px;
        text-align: center;
      }
      .slider-caption-icon {
        width: 40px; height: 40px;
        border-radius: 12px;
        background: rgba(99,102,241,0.15);
        border: 1px solid rgba(99,102,241,0.3);
        display: flex; align-items: center; justify-content: center;
        color: #818cf8;
        margin-bottom: 4px;
      }
      .slider-caption-text { display: flex; flex-direction: column; gap: 6px; align-items: center; }
      .slider-caption-title {
        font-size: 20px; font-weight: 800; color: #f8fafc; line-height: 1.2;
        letter-spacing: -0.02em;
        transition: opacity 0.35s;
      }
      .slider-caption-desc {
        font-size: 14px; color: #94a3b8; line-height: 1.5;
        max-width: 520px;
        transition: opacity 0.35s;
      }

      /* Dot indicators */
      .slider-dots {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        margin-top: 16px;
      }
      .slider-dot {
        width: 6px; height: 6px;
        border-radius: 50%;
        background: #334155;
        border: none; cursor: pointer; padding: 0;
        transition: width 0.3s ease, background 0.3s ease;
      }
      .slider-dot.active {
        width: 20px;
        border-radius: 3px;
        background: #6366f1;
      }
      /* ────────────────────────────────────────────────────────────── */

      /* Secondary CTA button below engine */
      .engine-cta-secondary {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 11px 18px;
        border-radius: 14px;
        background: rgba(59, 130, 246, 0.07);
        border: 1px solid rgba(59, 130, 246, 0.28);
        color: #93c5fd;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        transition: background 0.2s ease, border-color 0.2s ease;
        font-family: inherit;
      }
      .engine-cta-secondary:hover {
        background: rgba(59, 130, 246, 0.14);
        border-color: rgba(59, 130, 246, 0.45);
      }
      .engine-cta-secondary svg { flex-shrink: 0; transition: transform 0.2s ease; }
      .engine-cta-secondary:hover svg { transform: translateX(3px); }
      .engine-cta-badge {
        font-size: 10px;
        font-weight: 700;
        padding: 2px 8px;
        border-radius: 6px;
        background: rgba(34, 197, 94, 0.12);
        border: 1px solid rgba(34, 197, 94, 0.28);
        color: #4ade80;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        white-space: nowrap;
      }
    </style>
  </head>

  <body class="bg-surface text-white font-sans antialiased">
    <slot />
    <script is:inline>
      function handleStartEngine(btn) {
        if (btn.dataset.igniting) return;
        btn.dataset.igniting = 'true';
        var id = btn.id.replace('engine-btn-', '');
        var loginUrl = btn.dataset.url;
        var bar = document.getElementById('engine-bar-' + id);
        btn.classList.add('engine-shaking', 'engine-igniting');
        if (bar) requestAnimationFrame(function() { bar.style.width = '100%'; });
        setTimeout(function() { window.location.href = loginUrl; }, 1500);
      }
    </script>
    <script is:inline>
      (function() {
        var loaded = false;
        function loadCrisp() {
          if (loaded) return;
          loaded = true;
          window.$crisp = window.$crisp || [];
          window.CRISP_WEBSITE_ID = "f75e4c12-7db0-4f2f-90fb-711aacc45df3";
          window.$crisp.push(["do", "chat:hide"]);
          window.$crisp.push(["on", "chat:closed", function() {
            window.$crisp.push(["do", "chat:hide"]);
          }]);
          var s = document.createElement('script');
          s.src = 'https://client.crisp.chat/l.js';
          s.async = true;
          document.head.appendChild(s);
        }
        window.openCrispChat = function() {
          loadCrisp();
          window.$crisp = window.$crisp || [];
          window.$crisp.push(["do", "chat:show"]);
          window.$crisp.push(["do", "chat:open"]);
        };
      })();
    </script>
  </body>
</html>
