---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Dgt2026ArticleContent } from "../../components/Dgt2026ArticleContent";
import { articles, getArticle } from "../../data/articles";

export function getStaticPaths() {
  return articles.map((a) => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const article = getArticle(slug!);
if (!article) return Astro.redirect("/blog");

// Default language for static page is Spanish (primary audience)
const lang = "es";
const loc = article[lang];
const BASE = "https://skilyapp.com";
const canonical = `${BASE}/article/${article.slug}`;

const jsonLd: object[] = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Skilyapp", item: `${BASE}/` },
      { "@type": "ListItem", position: 2, name: "Blog", item: `${BASE}/blog` },
      { "@type": "ListItem", position: 3, name: loc.title, item: canonical },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: loc.title,
    description: loc.description,
    url: canonical,
    datePublished: article.publishedAt,
    dateModified: article.publishedAt,
    author: { "@type": "Person", name: loc.author },
    publisher: {
      "@type": "Organization",
      name: "Skilyapp",
      url: BASE,
      logo: { "@type": "ImageObject", url: `${BASE}/og-ru.jpg` },
    },
    inLanguage: "es-ES",
    keywords: article.keywords?.join(", "),
    mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
  },
];

if (article.faqItems?.length) {
  jsonLd.push({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: article.faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: { "@type": "Answer", text: item.answer },
    })),
  });
}

if (article.howTo) {
  jsonLd.push({
    "@context": "https://schema.org",
    "@type": "HowTo",
    name: article.howTo.name,
    description: article.howTo.description,
    totalTime: article.howTo.totalTime,
    step: article.howTo.steps.map((s) => ({
      "@type": "HowToStep",
      name: s.name,
      text: s.text,
    })),
  });
}

const hreflang = [
  { lang: "es", href: canonical },
  { lang: "en", href: canonical },
  { lang: "ru", href: canonical },
];

const isFullContent = article.slug === "ekzamen-dgt-2026";
---

<BaseLayout
  title={`${loc.title} | Skilyapp Blog`}
  description={loc.description}
  canonical={canonical}
  lang="es"
  jsonLd={jsonLd}
  hreflang={hreflang}
>
  <main class="min-h-screen bg-zinc-950 px-4 py-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <!-- Breadcrumb -->
      <nav class="mb-6 text-sm text-zinc-500">
        <a href="/" class="hover:text-zinc-300">Skilyapp</a>
        <span class="mx-2">/</span>
        <a href="/blog" class="hover:text-zinc-300">Blog</a>
        <span class="mx-2">/</span>
        <span class="text-zinc-300 line-clamp-1">{loc.title}</span>
      </nav>

      <!-- Article header -->
      <header class="mb-8">
        <span class="mb-3 inline-block rounded-full bg-zinc-800 px-2.5 py-0.5 text-xs text-zinc-400">
          {loc.category}
        </span>
        <h1 class="mb-4 text-2xl font-bold text-white sm:text-3xl lg:text-4xl leading-tight">
          {loc.title}
        </h1>
        <p class="mb-4 text-lg text-zinc-400">{loc.description}</p>
        <div class="flex items-center gap-4 text-sm text-zinc-500">
          <span>
            {new Date(article.publishedAt).toLocaleDateString("es-ES", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </span>
          <span>·</span>
          <span>{article.readTime} min de lectura</span>
          <span>·</span>
          <span>{loc.author}</span>
        </div>
      </header>

      <!-- Article content -->
      <article class="prose prose-invert prose-zinc max-w-none">
        {isFullContent ? (
          <Dgt2026ArticleContent lang="es" client:only="react" />
        ) : (
          <div>
            <p class="lead text-lg text-zinc-300 mb-6">{loc.excerpt}</p>
            <div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-6 text-center">
              <p class="mb-4 text-zinc-400">
                Lee el artículo completo en Skilyapp — preparación DGT con IA, duelos y más.
              </p>
              <a
                href="https://skilyapp.com/app/dashboard"
                class="inline-block rounded-xl bg-white px-6 py-3 text-sm font-semibold text-black hover:bg-zinc-100 transition-colors"
              >
                Abrir Skilyapp
              </a>
            </div>
          </div>
        )}
      </article>

      <!-- FAQ section (if available) -->
      {article.faqItems?.length && (
        <section class="mt-12">
          <h2 class="mb-6 text-xl font-bold text-white">Preguntas frecuentes</h2>
          <div class="space-y-4">
            {article.faqItems.map((item) => (
              <details class="rounded-xl border border-zinc-800 bg-zinc-900 p-4">
                <summary class="cursor-pointer font-medium text-white">{item.question}</summary>
                <p class="mt-3 text-sm text-zinc-400">{item.answer}</p>
              </details>
            ))}
          </div>
        </section>
      )}

      <!-- CTA -->
      <div class="mt-12 rounded-2xl border border-zinc-700 bg-zinc-900 p-6 text-center">
        <p class="mb-2 text-lg font-semibold text-white">¿Listo para prepararte?</p>
        <p class="mb-4 text-sm text-zinc-400">
          Más de 15 000 candidatos ya estudian con Skilyapp. Empieza gratis.
        </p>
        <a
          href="https://t.me/skilyapp_bot"
          class="inline-block rounded-xl bg-white px-6 py-3 text-sm font-semibold text-black hover:bg-zinc-100 transition-colors"
        >
          Empezar gratis en Telegram
        </a>
      </div>

      <!-- Back to blog -->
      <div class="mt-8 text-center">
        <a href="/blog" class="text-sm text-zinc-500 hover:text-zinc-300">← Volver al Blog</a>
      </div>
    </div>
  </main>
</BaseLayout>
