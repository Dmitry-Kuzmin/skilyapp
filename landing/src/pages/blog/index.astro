---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogSearch from "../../components/BlogSearch";
import { articles, sortedArticles } from "../../data/articles";

const lang = "es";
const BASE = "https://skilyapp.com";

const title = "Blog DGT — Guías, consejos y novedades para el examen | Skilyapp";
const description =
  "Artículos sobre el examen teórico DGT 2026, estrategias de preparación, señales y motivación. Actualizado con las últimas novedades de la DGT.";

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Skilyapp", item: `${BASE}/` },
      { "@type": "ListItem", position: 2, name: "Blog", item: `${BASE}/blog` },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: title,
    url: `${BASE}/blog`,
    description,
    inLanguage: "es-ES",
    isPartOf: { "@type": "WebSite", name: "Skilyapp", url: BASE },
    mainEntity: {
      "@type": "ItemList",
      itemListOrder: "https://schema.org/ItemListOrderDescending",
      numberOfItems: sortedArticles.length,
      itemListElement: sortedArticles.map((a, i) => ({
        "@type": "ListItem",
        position: i + 1,
        url: `${BASE}/article/${a.slug}`,
        name: a.es.title,
      })),
    },
  },
];

const hreflang = [
  { lang: "es", href: `${BASE}/blog` },
  { lang: "en", href: `${BASE}/en/blog` },
  { lang: "ru", href: `${BASE}/ru/blog` },
];

const labels = {
  searchPlaceholder: "Buscar artículos...",
  readMin: "min",
  readMore: "Leer más",
  categories: {
    all: "Todo",
    "dgt-2026": "DGT 2026",
    news: "Actualidad",
    preparation: "Preparación",
    tips: "Consejos",
  },
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={`${BASE}/blog`}
  lang="es"
  jsonLd={jsonLd}
  hreflang={hreflang}
>
  <main class="min-h-screen bg-zinc-950 px-4 py-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <!-- Header -->
      <div class="mb-10">
        <nav class="mb-4 text-sm text-zinc-500">
          <a href="/" class="hover:text-zinc-300">Skilyapp</a>
          <span class="mx-2">/</span>
          <span class="text-zinc-300">Blog</span>
        </nav>
        <h1 class="text-3xl font-bold text-white sm:text-4xl">Blog DGT</h1>
        <p class="mt-2 text-zinc-400">
          Guías, consejos y novedades sobre el examen teórico en España
        </p>
      </div>

      <!-- Search + filter (React island) -->
      <BlogSearch articles={articles} lang={lang} labels={labels} client:load />

      <!-- RSS link -->
      <div class="mt-12 text-center">
        <a href="/blog/feed.xml" class="text-xs text-zinc-600 hover:text-zinc-400">RSS Feed</a>
      </div>
    </div>
  </main>
</BaseLayout>
