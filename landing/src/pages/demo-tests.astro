---
import BaseLayout from "../layouts/BaseLayout.astro";
import DemoTest from "../components/DemoTest";

const BASE = "https://skilyapp.com";
const canonical = `${BASE}/demo-tests`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Skilyapp", item: `${BASE}/` },
      { "@type": "ListItem", position: 2, name: "Test Demo DGT", item: canonical },
    ],
  },
];

const hreflang = [
  { lang: "es", href: canonical },
  { lang: "x-default", href: canonical },
];
---

<BaseLayout
  title="Test Demo DGT 2025 — 30 preguntas reales gratis | Skilyapp"
  description="Pon a prueba tu nivel con 30 preguntas reales del examen DGT. Sin registro, sin tarjeta. Descubre en qué temas necesitas refuerzo antes del examen."
  canonical={canonical}
  lang="es"
  jsonLd={jsonLd}
  hreflang={hreflang}
>
  <main class="min-h-screen bg-zinc-950">
    <div class="px-4 py-10 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-xl">

        <!-- Header -->
        <div class="mb-8 text-center">
          <a href="/" class="inline-block mb-6 opacity-80 hover:opacity-100 transition-opacity">
            <img src="/logo.svg" alt="Skilyapp" class="h-7 mx-auto" onerror="this.style.display='none'" />
          </a>
          <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-zinc-700 bg-zinc-900 px-3 py-1 text-xs text-zinc-400">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
            30 preguntas reales · Sin registro
          </div>
          <h1 class="text-2xl font-bold text-white sm:text-3xl">
            Test Demo DGT
          </h1>
          <p class="mt-2 text-sm text-zinc-400">
            Preguntas reales del examen teórico de conducir en España
          </p>
        </div>

        <!-- Test card -->
        <div class="rounded-2xl border border-zinc-800 bg-zinc-900 p-5 sm:p-6">
          <DemoTest client:load />
        </div>

        <!-- Footer note -->
        <p class="mt-6 text-center text-xs text-zinc-600">
          ¿Quieres practicar con +2000 preguntas y IA?
          <a href="https://t.me/skilyapp_bot" class="text-zinc-400 underline hover:text-white transition-colors ml-1">
            Empieza gratis →
          </a>
        </p>

      </div>
    </div>
  </main>
</BaseLayout>
