    function aiAsk(key) {
      // Hide chips
      var chips = document.getElementById('ai-chips');
      if (chips) chips.style.display = 'none';

      var labels = { pista:'Dame una pista', explicar:'Explícame la regla completa', rapido:'¿Por qué ir rápido es peligroso?' };
      aiAddMessage('user', labels[key] || key);

      setTimeout(function() {
        aiShowTypingIndicator();
        setTimeout(function() {
          aiRemoveTyping();
          aiAddMessage('assistant', AI_REPLIES[key] || AI_REPLIES.default);
        }, 900);
      }, 200);
    }

    function aiSend() {
      var inp = document.getElementById('ai-input');
      if (!inp || !inp.value.trim()) return;
      var chips = document.getElementById('ai-chips');
      if (chips) chips.style.display = 'none';
      var msg = inp.value.trim();
      inp.value = '';
      aiAddMessage('user', msg);
      setTimeout(function() {
        aiShowTypingIndicator();
        setTimeout(function() {
          aiRemoveTyping();
          aiAddMessage('assistant', AI_REPLIES.default);
        }, 1100);
      }, 200);
    }
