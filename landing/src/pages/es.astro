      "La mitad de la velocidad en metros (ej: a 80 km/h = 40 m)",
      "Depende del tipo de carretera, no de tu velocidad"
    ],
    correct: 1,
    explanation: "✅ La distancia de seguridad es la necesaria para frenar y detenerse ante cualquier obstáculo. Depende de la velocidad, estado del vehículo y condiciones de la vía — no hay un valor fijo."
  }
];

let current = 0;
let score = 0;
let answered = false;

const $ = (id: string) => document.getElementById(id)!;

function getImageHTML(type: string | null): string {
  if (!type) return '';
  if (type === 'stop') {
    return `<svg viewBox="0 0 100 100" width="80" height="80" xmlns="http://www.w3.org/2000/svg">
      <polygon points="29,0 71,0 100,29 100,71 71,100 29,100 0,71 0,29" fill="#c0392b" stroke="white" stroke-width="4"/>
      <text x="50" y="62" font-size="26" font-weight="900" text-anchor="middle" fill="white" font-family="Arial">STOP</text>
    </svg>`;
  }
  if (type === 'triangle') {
    return `<svg viewBox="0 0 100 90" width="90" height="80" xmlns="http://www.w3.org/2000/svg">
      <polygon points="50,5 95,85 5,85" fill="white" stroke="#c0392b" stroke-width="5"/>
      <text x="50" y="72" font-size="44" text-anchor="middle">⚠️</text>
    </svg>`;
  }
  return '';
}

function render() {
  const q = QUESTIONS[current];

  // Counter & progress
  $('q-counter').textContent = `Pregunta ${current + 1} / ${QUESTIONS.length}`;
  $('q-score-live').textContent = `✓ ${score} correctas`;
  ($('progress-bar') as HTMLElement).style.width = `${((current + 1) / QUESTIONS.length) * 100}%`;

  // Image
  const imgSlot = $('q-image-slot');
  const imgHTML = getImageHTML(q.img);
  if (imgHTML) {
    imgSlot.innerHTML = imgHTML;
    imgSlot.style.display = 'flex';
  } else {
    imgSlot.style.display = 'none';
  }

  // Question text
  $('q-text').textContent = q.q;

  // Answers
  const grid = $('q-answers');
  grid.innerHTML = '';
  const letters = ['A', 'B', 'C', 'D'];
  q.answers.forEach((ans, i) => {
    const btn = document.createElement('button');
    btn.className = 'flex items-start gap-3 w-full text-left px-4 py-3 rounded-xl border border-slate-700/60 bg-slate-800/40 hover:border-indigo-500/50 hover:bg-slate-800 transition-all text-sm text-slate-200 font-medium group answer-btn';
    btn.innerHTML = `<span class="flex-shrink-0 w-6 h-6 rounded-lg bg-slate-700 text-slate-400 text-xs font-black flex items-center justify-center group-hover:bg-indigo-500/20 group-hover:text-indigo-300 transition-colors">${letters[i]}</span><span>${ans}</span>`;
    btn.addEventListener('click', () => handleAnswer(i));
    grid.appendChild(btn);
  });

  // Reset state
  $('q-explanation').classList.add('hidden');
  $('q-explanation').textContent = '';
  ($('q-next') as HTMLButtonElement).classList.add('hidden');
  answered = false;
}

function handleAnswer(idx: number) {
  if (answered) return;
  answered = true;

  const q = QUESTIONS[current];
  const isCorrect = idx === q.correct;
  if (isCorrect) score++;

  const btns = document.querySelectorAll<HTMLButtonElement>('.answer-btn');
  btns.forEach((btn, i) => {
    btn.disabled = true;
    if (i === q.correct) {
      btn.className = btn.className.replace('border-slate-700/60 bg-slate-800/40 hover:border-indigo-500/50 hover:bg-slate-800', 'border-emerald-500/60 bg-emerald-500/10 text-emerald-200');
    } else if (i === idx) {
      btn.className = btn.className.replace('border-slate-700/60 bg-slate-800/40 hover:border-indigo-500/50 hover:bg-slate-800', 'border-red-500/60 bg-red-500/10 text-red-300');
    } else {
      btn.className = btn.className.replace('hover:border-indigo-500/50 hover:bg-slate-800', '');
      btn.style.opacity = '0.4';
    }
  });

  const exp = $('q-explanation');
  exp.textContent = q.explanation;
  exp.classList.remove('hidden');

  $('q-score-live').textContent = `✓ ${score} correctas`;

  const nextBtn = $('q-next') as HTMLButtonElement;
  if (current < QUESTIONS.length - 1) {
    nextBtn.textContent = 'Siguiente pregunta →';
    nextBtn.classList.remove('hidden');
    nextBtn.onclick = () => { current++; render(); };
  } else {
    nextBtn.textContent = 'Ver mi resultado →';
    nextBtn.classList.remove('hidden');
    nextBtn.onclick = showResult;
  }
}

function showResult() {
  $('q-area').classList.add('hidden');
  const result = $('q-result');
  result.classList.remove('hidden');

  const pct = Math.round((score / QUESTIONS.length) * 100);
  $('q-result-score').textContent = `${score} / ${QUESTIONS.length}`;

  let emoji = '😰', msg = '';
  if (score >= 6) { emoji = '🏆'; msg = '¡Excelente! Casi listo para el DGT. Empieza a practicar los 3.247 restantes.'; }
  else if (score >= 4) { emoji = '🎯'; msg = 'Buen nivel de base. Skily AI te ayudará a pulir los puntos débiles.'; }
  else if (score >= 2) { emoji = '📚'; msg = 'Hay margen de mejora. La IA de Skily identifica exactamente dónde fallas.'; }
  else { emoji = '🚀'; msg = 'Empezar desde cero es lo más honesto. Skily lo hace rápido y sin estrés.'; }

  $('q-result-emoji').textContent = emoji;
  $('q-result-msg').textContent = msg;
  $('progress-bar' as any).style.width = '100%';
  $('q-counter').textContent = `Resultado final`;
}

// Init
render();
</script>

</BaseLayout>
