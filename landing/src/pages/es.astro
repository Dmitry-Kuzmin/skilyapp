        <div class="flex flex-col md:flex-row items-center justify-between gap-8 mb-8">
          <div class="flex items-center gap-2">
            <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-indigo-500 to-blue-600 flex items-center justify-center font-black text-white text-xs shadow-lg">S</div>
