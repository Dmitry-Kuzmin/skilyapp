    function aiTypeText(id, text) {
      var el = document.getElementById(id);
      if (!el) return;
      // Convert **bold** markers to visual emphasis inline
      var plain = text.replace(/\*\*([^*]+)\*\*/g, '$1');
      var i = 0;
      var speed = plain.length > 200 ? 12 : 18;
      function tick() {
        if (!document.getElementById(id)) return;
        el.textContent = plain.slice(0, i);
        el.closest('[style*="overflow-y"]') && (el.closest('[style*="overflow-y"]').scrollTop = 9999);
        var box = document.getElementById('ai-messages');
        if (box) box.scrollTop = box.scrollHeight;
        i++;
        if (i <= plain.length) aiTypingTimer = setTimeout(tick, speed);
      }
      tick();
    }

