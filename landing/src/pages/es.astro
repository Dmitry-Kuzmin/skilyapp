    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        // Observer for reveal on scroll
        const observerOptions = { threshold: 0.1, rootMargin: '0px 0px -50px 0px' };
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              // If it's a showcase, init parallax
              if (entry.target.id === 'product-showcase-container' || entry.target.id === 'product-showcase-v1') {
                initShowcaseParallax();
              }
            }
          });
        }, observerOptions);

        document.querySelectorAll('.reveal-on-scroll').forEach(el => observer.observe(el));

        // Logic for variant display
        const variant = new URLSearchParams(window.location.search).get('v') || '2';
        const h1 = document.getElementById('hero-v1');
        const h2 = document.getElementById('hero-v2');
        if(h1) h1.style.display = variant === '1' ? 'block' : 'none';
        if(h2) h2.style.display = variant === '2' ? 'block' : 'none';

        // Parallax effect for product showcase
        function initShowcaseParallax() {
          const showcase = document.getElementById('product-showcase-container') || document.getElementById('product-showcase-v1');
          if (!showcase || showcase.dataset.parallaxInit) return;
          showcase.dataset.parallaxInit = "true";

          let ticking = false;
          const updateParallax = () => {
            const rect = showcase.getBoundingClientRect();
            const winH = window.innerHeight;
            const progress = (rect.top + rect.height / 2 - winH / 2) / (winH / 2 + rect.height / 2);
            
            const tiltX = progress * 15; 
            const tiltY = progress * -15;
            
            showcase.style.setProperty('--tilt-x', `${tiltX}deg`);
            showcase.style.setProperty('--tilt-y', `${tiltY}deg`);
            showcase.style.setProperty('--parallax-offset', `${progress * 50}px`);
            ticking = false;
          };

          window.addEventListener('scroll', () => {
            if (!ticking) {
              window.requestAnimationFrame(updateParallax);
              ticking = true;
            }
          }, { passive: true });
          
          updateParallax();
        }

        // Emergency reveal
        setTimeout(() => {
          document.querySelectorAll('.reveal-on-scroll').forEach(el => {
            const rect = el.getBoundingClientRect();
            if (rect.top < window.innerHeight) {
              el.classList.add('revealed');
              if (el.id === 'product-showcase-container' || el.id === 'product-showcase-v1') initShowcaseParallax();
            }
          });
        }, 500);
      });

      // ─── AI CHAT DEMO ────────────────────────────────────────────────────────
      const ICON_CHECK = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
      const ICON_X     = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';

      var AI_REPLIES = {
        pista:   "Fíjate bien en la señal de la imagen — es la **S-28** (zona de estancia y juego).\n\nPiénsalo: ¿quién es más vulnerable en esa zona? En estas zonas los vehículos son los «invitados», no los dueños de la vía. 🚸",
        explicar:"La señal **S-28** indica una zona de estancia и juego.\n\nSegún el Reglamento General de Circulación:\n\n1️⃣ Los **peatones** tienen prioridad и pueden usar toda la calzada\n2️⃣ Los vehículos circulan a **paso de hombre** (máx. 20 km/h)\n3️⃣ El conductor debe detenerse si un peatón lo necesita\n\nOjo: aquí los peatones mandan en toda la calzada, no solo en los pasos señalizados. ¿Tienes más dudas? 🚗",
        default: "Buena pregunta 🤔 En esta zona con señal S-28, la clave es que los **peatones tienen prioridad absoluta** en toda la calzada. Si quieres profundizar, pulsa «Explícame el tema» o escрібеme directamente."
      };

      var aiDemoAnswered = false;
      var aiTypingTimer = null;

      window.aiDemoAnswer = function(n) {
        if (aiDemoAnswered) return;
        aiDemoAnswered = true;
        var correct = 1;
        [1, 2, 3].forEach(function(i) {
          var btn = document.getElementById('ai-opt-' + i);
          if (!btn) return;
          btn.style.cursor = 'default';
          btn.onclick = null;
          var key = btn.querySelector('.ai-opt-key');
          var txt = btn.querySelector('.ai-opt-txt');
          if (i === correct) {
            btn.style.background = 'rgba(34,197,94,0.1)';
            btn.style.border = '1px solid rgba(34,197,94,0.5)';
            if (key) { key.style.background = '#22c55e'; key.style.border = '1px solid #16a34a'; key.style.color = 'white'; key.innerHTML = ICON_CHECK; }
            if (txt) txt.style.color = '#86efac';
          } else if (i === n) {
            btn.style.background = 'rgba(239,68,68,0.08)';
            btn.style.border = '1px solid rgba(239,68,68,0.45)';
            if (key) { key.style.background = '#ef4444'; key.style.border = '1px solid #dc2626'; key.style.color = 'white'; key.innerHTML = ICON_X; }
            if (txt) txt.style.color = '#fca5a5';
          } else {
            btn.style.opacity = '0.35';
          }
        });

        var hb = document.getElementById('ai-hint-btn');
        if (hb) hb.style.animation = 'none';
        
        aiWidgetSetAnalyzing();
        var isRight = n === correct;
        setTimeout(function() {
          aiWidgetSetIdle();
          var prefix = isRight ? '¡Magnífico! Respuesta correcta. ' : 'No del todo. ';
          aiWidgetShowMsg(prefix + AI_REPLIES.explicar, isRight);
        }, 1050);
      };

      window.aiAsk = function(type) {
        if (aiDemoAnswered && type === 'pista') return;
        aiWidgetSetAnalyzing();
        setTimeout(function() {
          aiWidgetSetIdle();
          aiWidgetShowMsg(AI_REPLIES[type] || AI_REPLIES.default);
        }, 800);
      };

      function aiWidgetSetAnalyzing() {
        var idle = document.getElementById('ai-idle-state');
        var msg  = document.getElementById('ai-widget-msg');
        if(idle) idle.style.display = 'none';
        if(msg) {
          msg.style.display = 'block';
          msg.innerHTML = '<div style="display:flex;gap:8px;align-items:center;padding:10px;"><span class="ai-dot-loading"></span><span style="font-size:12px;color:#64748b;">Skily AI pensando...</span></div>';
        }
        document.getElementById('ai-ping-ring').style.borderColor = '#3b82f6';
      }

      function aiWidgetSetIdle() {
        var msg = document.getElementById('ai-widget-msg');
        if(msg) msg.innerHTML = '';
      }

      function aiWidgetShowMsg(text, isSuccess) {
        var msg = document.getElementById('ai-widget-msg');
        if(!msg) return;
        msg.style.display = 'block';
        var color = isSuccess ? '#86efac' : '#e2e8f0';
        msg.innerHTML = '<div style="background:rgba(30,41,59,0.7);border:1px solid rgba(255,255,255,0.08);border-radius:14px;padding:12px;margin-bottom:10px;">'
          + '<p id="ai-typing-text" style="color:'+color+';font-size:12px;line-height:1.6;margin:0;white-space:pre-line;"></p></div>'
          + '<button onclick="location.reload()" style="font-size:10px;color:#475569;background:none;border:none;cursor:pointer;text-decoration:underline;">Reiniciar demo</button>';
        
        var el = document.getElementById('ai-typing-text');
        var i = 0;
        var plain = text.replace(/\*\*([^*]+)\*\*/g, '$1');
        function tick() {
          if(!el) return;
          el.textContent = plain.slice(0, i);
          i++;
          if(i <= plain.length) setTimeout(tick, 15);
        }
        tick();
      }
    </script>

    <style is:global>
      .reveal-on-scroll {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.8s ease-out, transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .reveal-on-scroll.revealed {
        opacity: 1;
        transform: translateY(0);
      }

      /* Showcase Parallax Layer */
      .parallax-element {
        --tilt-x: 10deg;
        --tilt-y: -15deg;
        --parallax-offset: 0px;
        transform: rotateX(var(--tilt-x)) rotateY(var(--tilt-y)) translateY(var(--parallax-offset));
        will-change: transform;
        transition: transform 0.1s ease-out;
      }

      @keyframes float {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-15px); }
        100% { transform: translateY(0px); }
      }
      .floating-animation {
        animation: float 6s ease-in-out infinite;
      }

      @media (max-width: 768px) {
        .parallax-element {
          --tilt-x: 5deg;
          --tilt-y: -8deg;
          transform: none !important; /* Disable on mobile for performance */
        }
      }
      
      .no-scrollbar::-webkit-scrollbar { display: none; }
      .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

      /* AI Demo Styles */
      .demo-btn {
        display:flex;align-items:center;gap:12px;padding:12px;border-radius:14px;background:rgba(30,41,59,0.8);border:1px solid rgba(255,255,255,0.07);width:100%;text-align:left;cursor:pointer;transition:all 0.2s;
      }
      .demo-btn:hover { background: rgba(51, 65, 85, 0.9); border-color: rgba(255,255,255,0.15); transform: translateX(4px); }
      .ai-opt-key {
        width:28px;height:28px;border-radius:8px;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;color:#64748b;flex-shrink:0;
      }
      .ai-opt-txt { color:#cbd5e1;font-size:12px;line-height:1.4; }
      
      .ai-ring-outer { position:absolute;inset:0;border-radius:50%;border:1px solid rgba(59,130,246,0.15);animation:spin 12s linear infinite; }
      .ai-ring-mid { position:absolute;inset:4px;border-radius:50%;border:1px dashed rgba(59,130,246,0.3);animation:spin 8s linear infinite reverse; }
      .ai-ring-inner { position:absolute;inset:8px;border-radius:50%;border:2px solid rgba(59,130,246,0.5);border-right-color:transparent;animation:spin 3s cubic-bezier(0.4,0,0.2,1) infinite; }
      .ai-core { position:absolute;inset:14px;border-radius:50%;background:radial-gradient(circle at 30% 30%, #60a5fa, #2563eb);box-shadow:0 0 15px rgba(37,99,235,0.6); }
      
      @keyframes spin { from {transform:rotate(0deg)} to {transform:rotate(360deg)} }
      .ai-ping-ring { position:absolute;width:100%;height:100%;border-radius:50%;border:2px solid #22c55e;animation:ping 1.5s cubic-bezier(0,0,0.2,1) infinite; }
      .ai-ping-dot { width:4px;height:4px;border-radius:50%;background:#22c55e; }
      @keyframes ping { 75%,100% {transform:scale(2.5);opacity:0} }

      .hint-pulse { animation: hint-pulse 2s infinite; }
      @keyframes hint-pulse { 0% {box-shadow:0 0 0 0 rgba(59,130,246,0.4)} 70% {box-shadow:0 0 0 10px rgba(59,130,246,0)} 100% {box-shadow:0 0 0 0 rgba(59,130,246,0)} }
      
      .ai-dot-loading { width:6px;height:6px;border-radius:50%;background:#3b82f6;animation:aidot 1s infinite alternate; }
      @keyframes aidot { from {opacity:0.3;transform:scale(0.8)} to {opacity:1;transform:scale(1.2)} }

      @media (max-width: 900px) {
        .demo-grid { grid-template-columns: 1fr !important; }
        .demo-grid > div:first-child { border-right: none !important; border-bottom: 1px solid rgba(255,255,255,0.06); }
      }
    </style>
  </div>
</BaseLayout>
