---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Skily — Aprueba el examen DGT a la primera | IA + Gamificación';
const description =
  'Prepara el examen teórico DGT con IA que personaliza tu estudio. Preguntas oficiales actualizadas, simulacros reales, dueloss PvP y explicaciones instantáneas. 97% de aprobados en primera convocatoria.';
const canonical = 'https://skilyapp.com/es';
const appBaseUrl = import.meta.env.DEV ? 'http://localhost:8080' : 'https://skilyapp.com';

const hreflang = [
  { lang: 'es', href: 'https://skilyapp.com/es' },
  { lang: 'en', href: 'https://skilyapp.com/en' },
  { lang: 'ru', href: 'https://skilyapp.com/ru' },
];

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Skily',
  alternateName: ['Skily App', 'Skilyapp', 'Skily DGT'],
  description:
    'Aplicación móvil y Telegram Mini App para preparar el examen teórico DGT (carnet de conducir en España). Usa IA tutora, duelos PvP y aprendizaje adaptativo. Disponible en español, inglés y ruso.',
  applicationCategory: 'EducationApplication',
  operatingSystem: 'Web, iOS, Android, Telegram',
  url: 'https://skilyapp.com',
  downloadUrl: 'https://t.me/skilyapp_bot',
  inLanguage: ['es', 'en', 'ru'],
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'EUR',
    description: 'Acceso básico gratuito. Premium desde 4,99€/mes.',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '10000',
    bestRating: '5',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Skily',
    url: 'https://skilyapp.com',
    email: 'hello@skily.ai',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Barcelona',
      addressCountry: 'ES',
    },
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Es obligatorio ir a la autoescuela para el examen teórico DGT?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No, es un mito. Tienes el derecho legal de presentarte por libre ("Por Libre"). Las autoescuelas cobran entre 250€ y 400€ solo por la teoría. Con Skily obtienes la misma preparación —o mejor— sin sobrecostes.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cuánto tiempo se necesita para preparar el examen DGT con Skily?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'La mayoría de nuestros alumnos aprueban con 4-6 semanas de práctica diaria de 20 minutos. La IA detecta tus puntos débiles y optimiza el tiempo de estudio.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Las preguntas de Skily son las mismas que en el examen real?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí. Usamos el banco oficial de preguntas DGT, actualizado semanalmente. Si la DGT modifica una pregunta, Skily lo refleja ese mismo día.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Puedo preparar el DGT en otro idioma si mi español es bajo?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí. Skily está disponible en español, inglés y ruso. La IA explica la lógica de cada pregunta en tu idioma nativo para que entiendas el concepto, no solo memorices la respuesta.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cómo me inscribo al examen DGT por libre?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Debes pagar la tasa (Tasa 2.1, aprox. 94€) y solicitar cita en la web de la DGT. Skily Premium incluye una guía paso a paso con los enlaces y formularios necesarios.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué diferencia hay entre Skily y una autoescuela?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'La autoescuela cobra 250-400€ solo por teoría, tiene horario fijo y explicaciones genéricas. Skily cuesta desde 4,99€/mes, está disponible 24/7 y la IA personaliza el aprendizaje según tus errores específicos.',
      },
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  lang="es"
  ogImage="https://skilyapp.com/og-es.jpg"
  jsonLd={[appSchema, faqSchema]}
  hreflang={hreflang}
>
  <div class="relative min-h-[100dvh] bg-[#0f172a] text-white font-sans overflow-x-hidden selection:bg-indigo-500/30 w-full">

    <!-- Noise texture -->
    <div class="fixed inset-0 pointer-events-none opacity-[0.03] z-0" style="background-image:url('/noise.svg')"></div>
    <!-- Grid pattern -->
    <div class="fixed inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px] pointer-events-none z-0"></div>

    <!-- ═══════════════════════════════════════ NAV ══════════════════════════════════════ -->
    <nav class="relative z-[100] px-4 md:px-10 pt-5 pb-4 md:pb-6 flex items-center justify-between max-w-[1400px] mx-auto gap-4">
      <a href="/es" class="flex items-center gap-2.5 select-none" aria-label="Skily inicio">
        <!-- Настоящий логотип Skily: синий квадрат + машинка Lucide car-front -->
        <div class="w-10 h-10 rounded-2xl flex items-center justify-center shadow-lg shadow-blue-500/30 shrink-0" style="background:linear-gradient(135deg,#3b82f6,#2563eb,#1d4ed8);">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m21 8-2 2-1.5-3.7A2 2 0 0 0 15.646 5H8.4a2 2 0 0 0-1.903 1.257L5 10 3 8"/>
            <path d="M7 14h.01"/><path d="M17 14h.01"/>
            <rect width="18" height="8" x="3" y="10" rx="2"/>
            <path d="M5 18v2"/><path d="M19 18v2"/>
          </svg>
        </div>
        <span class="font-black text-lg tracking-tight text-white" style="letter-spacing:-0.02em;">Skily</span>
      </a>

      <div class="flex items-center gap-2 md:gap-3 ml-auto">
        <div class="hidden sm:flex items-center gap-1 text-xs font-bold text-slate-400">
          <a href="/es" class="px-2 py-1 rounded-lg bg-white/10 text-white">ES</a>
          <a href="/en" class="px-2 py-1 rounded-lg hover:bg-white/5 transition-colors">EN</a>
          <a href="/ru" class="px-2 py-1 rounded-lg hover:bg-white/5 transition-colors">RU</a>
        </div>
        <a
          href="https://t.me/skilyapp_bot"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-white text-slate-900 px-5 py-2.5 rounded-xl font-bold text-sm hover:bg-indigo-50 transition-colors shadow-lg shadow-white/10 whitespace-nowrap"
        >
          Entrar
        </a>
      </div>
    </nav>

    <!-- ═══════════════════════════════════════ HERO ══════════════════════════════════════ -->
    <section class="relative z-10 px-6 pt-12 pb-8 md:pt-20 md:pb-12 max-w-[1400px] mx-auto flex flex-col items-center text-center">

      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-300 text-[10px] font-bold tracking-[0.25em] uppercase mb-6">
        🇪🇸 DGT Approved · 2025
      </div>

      <!-- H1 -->
      <div class="relative mb-4 md:mb-6 w-full flex flex-col items-center">
        <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[110%] h-[140%] blur-[120px] opacity-25 bg-gradient-to-r from-blue-600 via-sky-400 to-cyan-300 pointer-events-none"></div>
        <h1 class="relative text-[clamp(2.25rem,8vw,5.5rem)] font-black tracking-tighter leading-[1.05] max-w-4xl">
          <span class="bg-clip-text text-transparent bg-gradient-to-b from-white via-slate-100 to-slate-300 block pb-2">
            Tu teórico a la primera
          </span>
          <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-500 via-sky-400 to-cyan-300 block">
            Sin dramas
          </span>
        </h1>
      </div>

      <!-- Subtitle -->
      <p class="max-w-3xl text-base sm:text-lg md:text-xl text-slate-300 leading-relaxed mb-10 md:mb-12 font-medium px-1">
        <span class="text-white font-bold">Olvida los manuales aburridos</span>. Nuestra IA detecta tus fallos y personaliza el estudio. Gamificación, preguntas oficiales actualizadas y explicaciones instantáneas. Tu 'L' te está esperando.
      </p>

      <!-- CTA -->
      <div class="flex flex-col items-center gap-4">
        <!-- Primary: Demo test -->
        <a
          href={`${appBaseUrl}/demo`}
          class="group relative inline-flex items-center justify-center gap-3 px-10 py-5 rounded-2xl bg-white text-slate-900 font-black text-lg shadow-2xl shadow-white/20 hover:bg-indigo-50 hover:shadow-indigo-200/30 transition-all duration-300 hover:scale-[1.02] active:scale-[0.98]"
        >
          <!-- Coin badge -->
          <span class="absolute -top-3 -right-3 flex items-center gap-1 bg-amber-400 text-amber-950 text-[11px] font-black px-2.5 py-1 rounded-full shadow-lg shadow-amber-400/30 whitespace-nowrap">
            🪙 +100 monedas gratis
          </span>
          <span class="text-2xl">🎯</span>
          <span>Probar test gratis · 10 preguntas</span>
          <svg class="w-5 h-5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>

        <!-- Secondary: Register / Telegram -->
        <div class="flex items-center gap-3 flex-wrap justify-center">
          <a
            href="https://t.me/skilyapp_bot"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-white/15 text-slate-300 font-bold text-sm hover:border-white/30 hover:text-white transition-all"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12L7.19 13.267l-2.96-.924c-.643-.204-.657-.643.136-.953l11.57-4.461c.537-.194 1.006.131.958.292z"/></svg>
            Entrar con Telegram
          </a>
          <span class="text-slate-700 text-xs">o</span>
          <a
            href={`${appBaseUrl}/login`}
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-white/15 text-slate-300 font-bold text-sm hover:border-white/30 hover:text-white transition-all"
          >
            Registrarme con email
          </a>
        </div>

        <p class="text-slate-600 text-xs font-medium">Sin tarjeta · 2 min · 100 monedas al registrarte</p>
      </div>
    </section>

    <!-- ═══════════════════════════════════════ FEATURES ═══════════════════════════════════ -->
    <section class="relative z-10 px-6 pt-20 pb-6 max-w-[1400px] mx-auto" id="features">
      <!-- Header -->
      <div class="text-center mb-14">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-indigo-300 text-[10px] font-bold tracking-[0.25em] uppercase mb-5">
          ✦ Plataforma completa
        </div>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-black text-white mb-4 leading-tight">
          Todo lo que necesitas<br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-400 via-violet-400 to-blue-400">para aprobar el DGT</span>
        </h2>
        <p class="text-slate-400 text-base max-w-xl mx-auto">Más de 40 000 alumnos ya preparan su carnet con Skily. Esto es lo que te da ventaja.</p>
      </div>

      <!-- Feature tabs container -->
      <div class="flex flex-col lg:flex-row gap-4 lg:gap-6 items-start">

        <!-- Left: Tab list -->
        <div class="w-full lg:w-[280px] shrink-0">
          <!-- Mobile: horizontal scroll -->
          <div class="flex lg:flex-col gap-2 overflow-x-auto pb-2 lg:pb-0 no-scrollbar" id="feat-tabs">
            <button data-tab="training" class="feat-tab active-tab group flex-shrink-0 w-full text-left px-4 py-3.5 rounded-2xl border transition-all duration-200 flex items-center gap-3" onclick="switchTab('training')">
              <span class="text-xl">🎯</span>
              <span class="font-bold text-sm whitespace-nowrap">Entrenamiento IA</span>
            </button>
            <button data-tab="duel" class="feat-tab group flex-shrink-0 w-full text-left px-4 py-3.5 rounded-2xl border transition-all duration-200 flex items-center gap-3" onclick="switchTab('duel')">
              <span class="text-xl">⚔️</span>
              <span class="font-bold text-sm whitespace-nowrap">Duelos PvP</span>
            </button>
            <button data-tab="ai" class="feat-tab group flex-shrink-0 w-full text-left px-4 py-3.5 rounded-2xl border transition-all duration-200 flex items-center gap-3" onclick="switchTab('ai')">
              <span class="text-xl">🧠</span>
              <span class="font-bold text-sm whitespace-nowrap">Tutor IA</span>
            </button>
            <button data-tab="progress" class="feat-tab group flex-shrink-0 w-full text-left px-4 py-3.5 rounded-2xl border transition-all duration-200 flex items-center gap-3" onclick="switchTab('progress')">
              <span class="text-xl">📊</span>
              <span class="font-bold text-sm whitespace-nowrap">Tu Progreso</span>
            </button>
            <button data-tab="game" class="feat-tab group flex-shrink-0 w-full text-left px-4 py-3.5 rounded-2xl border transition-all duration-200 flex items-center gap-3" onclick="switchTab('game')">
              <span class="text-xl">🎮</span>
              <span class="font-bold text-sm whitespace-nowrap">Gamificación</span>
            </button>
            <button data-tab="app" class="feat-tab group flex-shrink-0 w-full text-left px-4 py-3.5 rounded-2xl border transition-all duration-200 flex items-center gap-3" onclick="switchTab('app')">
              <span class="text-xl">📱</span>
              <span class="font-bold text-sm whitespace-nowrap">Siempre contigo</span>
            </button>
          </div>
        </div>

        <!-- Right: Content panels -->
        <div class="flex-1 relative min-h-[420px] lg:min-h-[460px]">

          <!-- TRAINING -->
          <div id="panel-training" class="feat-panel">
            <div class="bg-slate-900/80 border border-slate-700/60 rounded-[2rem] overflow-hidden h-full">
              <div class="grid lg:grid-cols-2 gap-0 h-full">
                <div class="p-8 flex flex-col justify-center">
                  <p class="text-xs font-black uppercase tracking-[0.2em] text-indigo-400 mb-3">6 modos de práctica</p>
                  <h3 class="text-2xl sm:text-3xl font-black text-white mb-4 leading-tight">Entrena como<br/>un profesional</h3>
                  <p class="text-slate-400 text-sm leading-relaxed mb-6">Desde práctica libre hasta examen oficial simulado. La IA ajusta la dificultad según tus errores.</p>
                  <ul class="space-y-2.5">
                    <li class="flex items-center gap-2.5 text-sm text-slate-300"><span class="w-5 h-5 rounded-full bg-indigo-500/20 flex items-center justify-center text-xs">✓</span> Examen DGT con tiempo real</li>
                    <li class="flex items-center gap-2.5 text-sm text-slate-300"><span class="w-5 h-5 rounded-full bg-indigo-500/20 flex items-center justify-center text-xs">✓</span> Modo Blitz — 20 preguntas, 5 min</li>
                    <li class="flex items-center gap-2.5 text-sm text-slate-300"><span class="w-5 h-5 rounded-full bg-indigo-500/20 flex items-center justify-center text-xs">✓</span> Marathon — sin errores hasta el final</li>
                    <li class="flex items-center gap-2.5 text-sm text-slate-300"><span class="w-5 h-5 rounded-full bg-indigo-500/20 flex items-center justify-center text-xs">✓</span> 3 000+ preguntas oficiales DGT</li>
                  </ul>
                </div>
                <div class="hidden lg:flex items-center justify-center bg-gradient-to-br from-indigo-500/5 to-violet-500/5 border-l border-slate-700/40 p-8 overflow-hidden">
                  <!-- Browser frame -->
                  <div class="w-full max-w-[380px] rounded-2xl overflow-hidden shadow-2xl border border-slate-600/50" style="background:#1e2433;">
                    <!-- Browser chrome bar -->
                    <div class="flex items-center gap-2 px-4 py-3 border-b border-slate-700/60" style="background:#161c2c;">
                      <!-- Traffic lights -->
                      <div class="flex items-center gap-1.5 shrink-0">
                        <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
                        <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
                        <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
                      </div>
                      <!-- URL bar -->
                      <div class="flex-1 mx-3 h-6 rounded-md bg-slate-800/80 border border-slate-700/50 flex items-center px-3 gap-2">
                        <div class="w-2 h-2 rounded-full bg-emerald-400/60 shrink-0"></div>
                        <span class="text-[10px] text-slate-400 font-medium truncate">skilyapp.com · Práctica DGT</span>
                      </div>
                    </div>
                    <!-- Video content -->
                    <video
                      src="/videos/feat-training-cut.webm"
                      autoplay loop muted playsinline
                      class="w-full block"
                      style="max-height: 300px; object-fit: cover; object-position: top;"
                    ></video>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- DUEL -->
          <div id="panel-duel" class="feat-panel hidden">
            <div class="bg-slate-900/80 border border-slate-700/60 rounded-[2rem] overflow-hidden h-full">
              <div class="grid lg:grid-cols-2 gap-0 h-full">
                <div class="p-8 flex flex-col justify-center">
                  <p class="text-xs font-black uppercase tracking-[0.2em] text-rose-400 mb-3">PvP en tiempo real</p>
                  <h3 class="text-2xl sm:text-3xl font-black text-white mb-4 leading-tight">Reta a otro<br/>alumno ahora</h3>
                  <p class="text-slate-400 text-sm leading-relaxed mb-6">Responde más rápido que tu rival. Cada acierto suma combo. El más rápido y exacto gana monedas y XP.</p>
                  <ul class="space-y-2.5">
                    <li class="flex items-center gap-2.5 text-sm text-slate-300"><span class="w-5 h-5 rounded-full bg-rose-500/20 flex items-center justify-center text-xs">✓</span> Matchmaking instantáneo</li>
                    <li class="flex items-center gap-2.5 text-sm text-slate-300"><span class="w-5 h-5 rounded-full bg-rose-500/20 flex items-center justify-center text-xs">✓</span> Sistema de combos y rachas</li>
                    <li class="flex items-center gap-2.5 text-sm text-slate-300"><span class="w-5 h-5 rounded-full bg-rose-500/20 flex items-center justify-center text-xs">✓</span> Temporadas con Duel Pass</li>
                    <li class="flex items-center gap-2.5 text-sm text-slate-300"><span class="w-5 h-5 rounded-full bg-rose-500/20 flex items-center justify-center text-xs">✓</span> Recompensas exclusivas por ranking</li>
                  </ul>
                </div>
                <div class="hidden lg:flex items-center justify-center bg-gradient-to-br from-rose-500/5 to-orange-500/5 border-l border-slate-700/40 p-8">
                  <!-- Duel mock -->
                  <div class="w-full max-w-[240px] space-y-3">
                    <div class="bg-slate-800/80 border border-slate-700/60 rounded-xl p-4 space-y-3">
                      <div class="flex items-center justify-between">
                        <div class="flex items-center gap-2">
                          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-indigo-400 to-violet-500 flex items-center justify-center text-xs font-black text-white">TÚ</div>
                          <div>
                            <div class="text-xs font-black text-white">Tú</div>
                            <div class="text-[10px] text-emerald-400 font-bold">🔥 x3 combo</div>
                          </div>
                        </div>
                        <div class="text-xl font-black text-white">VS</div>
                        <div class="flex items-center gap-2">
                          <div>
                            <div class="text-xs font-black text-white text-right">Rival</div>
                            <div class="text-[10px] text-slate-400 font-bold text-right">sin combo</div>
                          </div>
                          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-slate-500 to-slate-600 flex items-center justify-center text-xs font-black text-white">R</div>
                        </div>
                      </div>
                      <div class="flex gap-1.5">
                        <div class="flex-1 h-3 rounded-full bg-gradient-to-r from-indigo-500 to-violet-500" style="width:70%"></div>
                        <div class="h-3 rounded-full bg-slate-700" style="width:30%"></div>
                      </div>
                      <div class="flex justify-between text-xs font-black">
                        <span class="text-indigo-300">420 pts</span>
                        <span class="text-slate-500">180 pts</span>
                      </div>
                    </div>
                    <div class="bg-rose-500/10 border border-rose-400/20 rounded-xl p-3 text-center">
                      <p class="text-xs font-black text-rose-300">¡Ganaste el duelo!</p>
                      <p class="text-[10px] text-slate-400 mt-0.5">+50 🪙 · +120 XP</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- AI TUTOR -->
          <div id="panel-ai" class="feat-panel hidden">
            <div class="bg-slate-900/80 border border-slate-700/60 rounded-[2rem] overflow-hidden h-full">
              <div class="grid lg:grid-cols-2 gap-0 h-full">
                <div class="p-8 flex flex-col justify-center">
                  <p class="text-xs font-black uppercase tracking-[0.2em] text-violet-400 mb-3">GPT-4o integrado</p>
                  <h3 class="text-2xl sm:text-3xl font-black text-white mb-4 leading-tight">Tutor IA en<br/>cada pregunta</h3>
                  <p class="text-slate-400 text-sm leading-relaxed mb-6">¿No entiendes por qué fallaste? Pregúntale a la IA. Explica la norma, la señal y el contexto en segundos.</p>
                  <ul class="space-y-2.5">
                    <li class="flex items-center gap-2.5 text-sm text-slate-300"><span class="w-5 h-5 rounded-full bg-violet-500/20 flex items-center justify-center text-xs">✓</span> Explicación de cada respuesta</li>
                    <li class="flex items-center gap-2.5 text-sm text-slate-300"><span class="w-5 h-5 rounded-full bg-violet-500/20 flex items-center justify-center text-xs">✓</span> Chat libre — pregunta lo que quieras</li>
