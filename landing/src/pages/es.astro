---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Skily — Aprueba el examen DGT a la primera | IA + Gamificación';
const description =
  'Prepara el examen teórico DGT con IA que personaliza tu estudio. Preguntas oficiales actualizadas, simulacros reales, dueloss PvP y explicaciones instantáneas. 97% de aprobados en primera convocatoria.';
const canonical = 'https://skilyapp.com/es';
const appBaseUrl = import.meta.env.DEV ? 'http://localhost:8080' : 'https://skilyapp.com';

const hreflang = [
  { lang: 'es', href: 'https://skilyapp.com/es' },
  { lang: 'en', href: 'https://skilyapp.com/en' },
  { lang: 'ru', href: 'https://skilyapp.com/ru' },
];

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Skily',
  alternateName: ['Skily App', 'Skilyapp', 'Skily DGT'],
  description:
    'Aplicación móvil y Telegram Mini App para preparar el examen teórico DGT (carnet de conducir en España). Usa IA tutora, duelos PvP y aprendizaje adaptativo. Disponible en español, inglés y ruso.',
  applicationCategory: 'EducationApplication',
  operatingSystem: 'Web, iOS, Android, Telegram',
  url: 'https://skilyapp.com',
  downloadUrl: 'https://t.me/skilyapp_bot',
  inLanguage: ['es', 'en', 'ru'],
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'EUR',
    description: 'Acceso básico gratuito. Premium desde 4,99€/mes.',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '10000',
    bestRating: '5',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Skily',
    url: 'https://skilyapp.com',
    email: 'hello@skily.ai',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Barcelona',
      addressCountry: 'ES',
    },
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Es obligatorio ir a la autoescuela para el examen teórico DGT?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No, es un mito. Tienes el derecho legal de presentarte por libre ("Por Libre"). Las autoescuelas cobran entre 250€ y 400€ solo por la teoría. Con Skily obtienes la misma preparación —o mejor— sin sobrecostes.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cuánto tiempo se necesita para preparar el examen DGT con Skily?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'La mayoría de nuestros alumnos aprueban con 4-6 semanas de práctica diaria de 20 minutos. La IA detecta tus puntos débiles y optimiza el tiempo de estudio.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Las preguntas de Skily son las mismas que en el examen real?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí. Usamos el banco oficial de preguntas DGT, actualizado semanalmente. Si la DGT modifica una pregunta, Skily lo refleja ese mismo día.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Puedo preparar el DGT en otro idioma si mi español es bajo?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí. Skily está disponible en español, inglés y ruso. La IA explica la lógica de cada pregunta en tu idioma nativo para que entiendas el concepto, no solo memorices la respuesta.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cómo me inscribo al examen DGT por libre?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Debes pagar la tasa (Tasa 2.1, aprox. 94€) y solicitar cita en la web de la DGT. Skily Premium incluye una guía paso a paso con los enlaces y formularios necesarios.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué diferencia hay entre Skily y una autoescuela?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'La autoescuela cobra 250-400€ solo por teoría, tiene horario fijo y explicaciones genéricas. Skily cuesta desde 4,99€/mes, está disponible 24/7 y la IA personaliza el aprendizaje según tus errores específicos.',
      },
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  lang="es"
  ogImage="https://skilyapp.com/og-es.jpg"
  jsonLd={[appSchema, faqSchema]}
  hreflang={hreflang}
>
  <div class="relative min-h-[100dvh] bg-[#0f172a] text-white font-sans overflow-x-hidden selection:bg-indigo-500/30 w-full">

    <!-- Noise texture -->
    <div class="fixed inset-0 pointer-events-none opacity-[0.03] z-0" style="background-image:url('/noise.svg')"></div>
    <!-- Grid pattern -->
    <div class="fixed inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px] pointer-events-none z-0"></div>

    <!-- ═══════════════════════════════════════ NAV ══════════════════════════════════════ -->
    <nav class="relative z-[100] px-4 md:px-10 pt-5 pb-4 md:pb-6 flex items-center justify-between max-w-[1400px] mx-auto gap-4">
      <a href="/es" class="flex items-center gap-2.5 select-none" aria-label="Skily inicio">
        <!-- Настоящий логотип Skily: синий квадрат + машинка Lucide car-front -->
        <div class="w-10 h-10 rounded-2xl flex items-center justify-center shadow-lg shadow-blue-500/30 shrink-0" style="background:linear-gradient(135deg,#3b82f6,#2563eb,#1d4ed8);">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m21 8-2 2-1.5-3.7A2 2 0 0 0 15.646 5H8.4a2 2 0 0 0-1.903 1.257L5 10 3 8"/>
            <path d="M7 14h.01"/><path d="M17 14h.01"/>
            <rect width="18" height="8" x="3" y="10" rx="2"/>
            <path d="M5 18v2"/><path d="M19 18v2"/>
          </svg>
        </div>
        <span class="font-black text-lg tracking-tight text-white" style="letter-spacing:-0.02em;">Skily</span>
      </a>

      <div class="flex items-center gap-2 md:gap-3 ml-auto">
        <div class="hidden sm:flex items-center gap-1 text-xs font-bold text-slate-400">
          <a href="/es" class="px-2 py-1 rounded-lg bg-white/10 text-white">ES</a>
          <a href="/en" class="px-2 py-1 rounded-lg hover:bg-white/5 transition-colors">EN</a>
          <a href="/ru" class="px-2 py-1 rounded-lg hover:bg-white/5 transition-colors">RU</a>
        </div>
        <a
          href="https://t.me/skilyapp_bot"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-white text-slate-900 px-5 py-2.5 rounded-xl font-bold text-sm hover:bg-indigo-50 transition-colors shadow-lg shadow-white/10 whitespace-nowrap"
        >
          Entrar
        </a>
      </div>
    </nav>

    <!-- ═══════════════════════════════════════ HERO ══════════════════════════════════════ -->
    <section class="relative z-10 px-6 pt-12 pb-8 md:pt-20 md:pb-12 max-w-[1400px] mx-auto flex flex-col items-center text-center">

      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-300 text-[10px] font-bold tracking-[0.25em] uppercase mb-6">
        🇪🇸 DGT Approved · 2025
      </div>

      <!-- H1 -->
      <div class="relative mb-4 md:mb-6 w-full flex flex-col items-center">
        <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[110%] h-[140%] blur-[120px] opacity-25 bg-gradient-to-r from-blue-600 via-sky-400 to-cyan-300 pointer-events-none"></div>
        <h1 class="relative text-[clamp(2.25rem,8vw,5.5rem)] font-black tracking-tighter leading-[1.05] max-w-4xl">
          <span class="bg-clip-text text-transparent bg-gradient-to-b from-white via-slate-100 to-slate-300 block pb-2">
            Tu teórico a la primera
          </span>
          <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-500 via-sky-400 to-cyan-300 block">
            Sin dramas
          </span>
        </h1>
      </div>

      <!-- Subtitle -->
      <p class="max-w-3xl text-base sm:text-lg md:text-xl text-slate-300 leading-relaxed mb-10 md:mb-12 font-medium px-1">
        <span class="text-white font-bold">Olvida los manuales aburridos</span>. Nuestra IA detecta tus fallos y personaliza el estudio. Gamificación, preguntas oficiales actualizadas y explicaciones instantáneas. Tu 'L' te está esperando.
      </p>

      <!-- CTA -->
      <div class="flex flex-col items-center gap-4">
        <!-- Primary: Demo test -->
        <a
          href={`${appBaseUrl}/demo`}
          class="group relative inline-flex items-center justify-center gap-3 px-10 py-5 rounded-2xl bg-white text-slate-900 font-black text-lg shadow-2xl shadow-white/20 hover:bg-indigo-50 hover:shadow-indigo-200/30 transition-all duration-300 hover:scale-[1.02] active:scale-[0.98]"
        >
          <!-- Coin badge -->
          <span class="absolute -top-3 -right-3 flex items-center gap-1 bg-amber-400 text-amber-950 text-[11px] font-black px-2.5 py-1 rounded-full shadow-lg shadow-amber-400/30 whitespace-nowrap">
            🪙 +100 monedas gratis
          </span>
          <span class="text-2xl">🎯</span>
          <span>Probar test gratis · 10 preguntas</span>
          <svg class="w-5 h-5 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
        </a>

        <!-- Secondary: Register / Telegram -->
        <div class="flex items-center gap-3 flex-wrap justify-center">
          <a
            href="https://t.me/skilyapp_bot"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-white/15 text-slate-300 font-bold text-sm hover:border-white/30 hover:text-white transition-all"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm5.894 8.221-1.97 9.28c-.145.658-.537.818-1.084.508l-3-2.21-1.447 1.394c-.16.16-.295.295-.605.295l.213-3.053 5.56-5.023c.242-.213-.054-.333-.373-.12L7.19 13.267l-2.96-.924c-.643-.204-.657-.643.136-.953l11.57-4.461c.537-.194 1.006.131.958.292z"/></svg>
            Entrar con Telegram
          </a>
          <span class="text-slate-700 text-xs">o</span>
          <a
            href={`${appBaseUrl}/login`}
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-white/15 text-slate-300 font-bold text-sm hover:border-white/30 hover:text-white transition-all"
          >
            Registrarme con email
          </a>
        </div>

        <p class="text-slate-600 text-xs font-medium">Sin tarjeta · 2 min · 100 monedas al registrarte</p>
      </div>
    </section>

    <!-- ═══════════════════════════════════════ FEATURES ═══════════════════════════════════ -->
    <section class="relative z-10 px-6 pt-24 pb-6 max-w-[1200px] mx-auto" id="features">

      <!-- Header -->
      <div class="text-center mb-10">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-300 text-[10px] font-bold tracking-[0.25em] uppercase mb-5">
          ✦ Plataforma completa
        </div>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-black text-white mb-4 leading-tight">
          Todo lo que necesitas<br/><span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-300 via-blue-400 to-blue-500">para aprobar el DGT</span>
        </h2>
        <p class="text-slate-400 text-base max-w-xl mx-auto">Más de 40 000 alumnos ya preparan su carnet con Skily.</p>
      </div>

      <!-- Horizontal tab pills -->
      <div class="flex items-center justify-center gap-2 flex-wrap mb-8 no-scrollbar">
        <button data-tab="ai" class="feat-tab active-tab px-4 py-2 rounded-full border text-sm font-bold flex items-center gap-2 transition-all duration-200 whitespace-nowrap" onclick="switchTab('ai')">
          <span>🧠</span> Test + Tutor IA
        </button>
        <button data-tab="duel" class="feat-tab px-4 py-2 rounded-full border text-sm font-bold flex items-center gap-2 transition-all duration-200 whitespace-nowrap" onclick="switchTab('duel')">
          <span>⚔️</span> Duelos PvP
        </button>
        <button data-tab="progress" class="feat-tab px-4 py-2 rounded-full border text-sm font-bold flex items-center gap-2 transition-all duration-200 whitespace-nowrap" onclick="switchTab('progress')">
          <span>📊</span> Progreso
        </button>
        <button data-tab="game" class="feat-tab px-4 py-2 rounded-full border text-sm font-bold flex items-center gap-2 transition-all duration-200 whitespace-nowrap" onclick="switchTab('game')">
          <span>🎮</span> Gamificación
        </button>
        <button data-tab="app" class="feat-tab px-4 py-2 rounded-full border text-sm font-bold flex items-center gap-2 transition-all duration-200 whitespace-nowrap" onclick="switchTab('app')">
          <span>🌍</span> Multiidioma
        </button>
      </div>

      <!-- Panels -->
      <div class="relative">

        <!-- TRAINING — Interactive Demo (hidden, kept for switchTab) -->
        <div id="panel-training" class="feat-panel hidden">
          <!-- Browser chrome -->
          <div class="rounded-[1.5rem] overflow-hidden border border-slate-700/60 shadow-2xl shadow-blue-500/10 mb-6" style="background:#0f172a;">
            <div class="flex items-center gap-2 px-5 py-3.5 border-b border-slate-700/50" style="background:#161c2c;">
              <div class="flex gap-1.5"><div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div><div class="w-3 h-3 rounded-full bg-[#febc2e]"></div><div class="w-3 h-3 rounded-full bg-[#28c840]"></div></div>
              <div class="flex-1 mx-4 h-7 rounded-lg bg-slate-800/80 border border-slate-700/40 flex items-center px-3 gap-2">
                <div class="w-2 h-2 rounded-full bg-emerald-400/70 shrink-0"></div>
                <span class="text-[11px] text-slate-400 font-medium">skilyapp.com · Práctica DGT</span>
              </div>
            </div>
            <!-- Demo app shell -->
            <div id="demo-shell" style="min-height:520px;padding:0;">
              <!-- Session header -->
              <div id="demo-header" style="display:flex;align-items:center;gap:12px;padding:14px 20px;border-bottom:1px solid rgba(255,255,255,0.06);background:#0f172a;">
                <button style="width:36px;height:36px;border-radius:12px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);display:flex;align-items:center;justify-content:center;color:#94a3b8;cursor:pointer;flex-shrink:0;" onclick="demoReset()">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
                </button>
                <div style="display:flex;align-items:center;gap:8px;flex:1;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
                  <span id="demo-counter" style="color:#94a3b8;font-size:13px;font-weight:700;">1 / 5</span>
                  <div style="flex:1;height:6px;background:#1e293b;border-radius:9999px;overflow:hidden;margin:0 4px;">
                    <div id="demo-bar" style="height:100%;background:linear-gradient(90deg,#22c55e,#16a34a);border-radius:9999px;transition:width 0.4s ease;width:0%;"></div>
                  </div>
                </div>
                <div style="display:flex;gap:6px;">
                  <div style="display:flex;align-items:center;gap:4px;padding:4px 10px;border-radius:9999px;background:rgba(34,197,94,0.12);border:1px solid rgba(34,197,94,0.25);">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    <span id="demo-correct" style="color:#22c55e;font-size:12px;font-weight:800;">0</span>
                  </div>
                  <div style="display:flex;align-items:center;gap:4px;padding:4px 10px;border-radius:9999px;background:rgba(239,68,68,0.12);border:1px solid rgba(239,68,68,0.25);">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5"><path d="M18 6 6 18M6 6l12 12"/></svg>
                    <span id="demo-wrong" style="color:#ef4444;font-size:12px;font-weight:800;">0</span>
                  </div>
                </div>
              </div>
              <!-- Question body -->
              <div id="demo-body" style="padding:20px 24px 24px;"></div>
            </div>
          </div>
          <!-- Info cards -->
          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="p-4 rounded-2xl bg-slate-900/60 border border-slate-800">
              <p class="text-blue-400 font-black text-sm mb-1">6 modos</p>
              <p class="text-white/70 text-xs leading-relaxed">Práctica, Examen, Blitz, Marathon, Mastery y más</p>
            </div>
            <div class="p-4 rounded-2xl bg-slate-900/60 border border-slate-800">
              <p class="text-blue-400 font-black text-sm mb-1">3 000+ preguntas</p>
              <p class="text-white/70 text-xs leading-relaxed">Base oficial DGT actualizada en tiempo real</p>
            </div>
            <div class="p-4 rounded-2xl bg-slate-900/60 border border-slate-800">
              <p class="text-blue-400 font-black text-sm mb-1">Imágenes reales</p>
              <p class="text-white/70 text-xs leading-relaxed">Señales, situaciones de tráfico y más</p>
            </div>
            <div class="p-4 rounded-2xl bg-slate-900/60 border border-slate-800">
              <p class="text-blue-400 font-black text-sm mb-1">IA adaptativa</p>
              <p class="text-white/70 text-xs leading-relaxed">Ajusta la dificultad según tus errores</p>
            </div>
          </div>
        </div>

        <!-- DUEL — Interactive Demo -->
        <div id="panel-duel" class="feat-panel hidden">
          <div class="rounded-[1.5rem] overflow-hidden border border-slate-700/60 shadow-2xl shadow-rose-500/10 mb-6" style="background:#080f1e;">
            <!-- Browser chrome -->
            <div style="display:flex;align-items:center;gap:8px;padding:10px 20px;border-bottom:1px solid rgba(255,255,255,0.05);background:#0f172a;">
              <div style="display:flex;gap:5px;"><div style="width:11px;height:11px;border-radius:50%;background:#ff5f57;"></div><div style="width:11px;height:11px;border-radius:50%;background:#febc2e;"></div><div style="width:11px;height:11px;border-radius:50%;background:#28c840;"></div></div>
              <div style="flex:1;margin:0 12px;height:24px;border-radius:7px;background:rgba(30,41,59,0.8);border:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;padding:0 10px;gap:6px;">
                <div style="width:6px;height:6px;border-radius:50%;background:rgba(34,197,94,0.7);"></div>
                <span style="font-size:11px;color:#64748b;font-weight:500;">skilyapp.com · Duelos PvP</span>
              </div>
            </div>
            <!-- Game screen — full width desktop -->
            <div id="duel-screen" style="height:480px;overflow:hidden;"></div>
          </div>

          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="p-4 rounded-2xl bg-slate-900/60 border border-slate-800"><p class="text-rose-400 font-black text-sm mb-1">PvP real</p><p class="text-white/70 text-xs">Matchmaking instantáneo contra otro alumno</p></div>
            <div class="p-4 rounded-2xl bg-slate-900/60 border border-slate-800"><p class="text-rose-400 font-black text-sm mb-1">Apuestas de monedas</p><p class="text-white/70 text-xs">Pon algo en juego — el ganador se lo lleva</p></div>
            <div class="p-4 rounded-2xl bg-slate-900/60 border border-slate-800"><p class="text-rose-400 font-black text-sm mb-1">Duel Pass</p><p class="text-white/70 text-xs">Temporadas con recompensas exclusivas</p></div>
            <div class="p-4 rounded-2xl bg-slate-900/60 border border-slate-800"><p class="text-rose-400 font-black text-sm mb-1">Boost & poderes</p><p class="text-white/70 text-xs">Úsalos estratégicamente para ganar</p></div>
          </div>
        </div>

        <!-- AI TUTOR — Interactive Demo -->
        <div id="panel-ai" class="feat-panel">
          <div class="rounded-[1.5rem] overflow-hidden border border-slate-700/60 shadow-2xl shadow-blue-500/10 mb-6" style="background:#0f172a;">
            <!-- Browser chrome -->
            <div style="display:flex;align-items:center;gap:8px;padding:10px 20px;border-bottom:1px solid rgba(255,255,255,0.06);background:#161c2c;">
              <div style="display:flex;gap:5px;"><div style="width:12px;height:12px;border-radius:50%;background:#ff5f57;"></div><div style="width:12px;height:12px;border-radius:50%;background:#febc2e;"></div><div style="width:12px;height:12px;border-radius:50%;background:#28c840;"></div></div>
              <div style="flex:1;margin:0 12px;height:26px;border-radius:8px;background:rgba(30,41,59,0.8);border:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;padding:0 10px;gap:6px;">
                <div style="width:7px;height:7px;border-radius:50%;background:rgba(34,197,94,0.7);"></div>
                <span style="font-size:11px;color:#64748b;font-weight:500;">skilyapp.com · Práctica DGT</span>
              </div>
            </div>

            <!-- App shell -->
            <div id="ai-demo-shell" style="display:grid;grid-template-columns:1fr 340px;min-height:500px;">

              <!-- LEFT: Question card (exact app style) -->
              <div style="padding:24px;display:grid;grid-template-columns:1.2fr 1fr;gap:20px;align-items:start;">
                <!-- Image -->
                <div>
                  <img src="https://yffjnqegeiorunyvcxkn.supabase.co/storage/v1/object/public/dgt-images/generated/topic-03_test-004/008eac5e-9c20-482d-8b46-1df4adc3e2c2_1769470209354_pro.webp"
                    alt="" loading="lazy"
                    style="width:100%;border-radius:24px;border:1px solid rgba(255,255,255,0.07);object-fit:cover;display:block;"/>
                </div>
                <!-- Question + options -->
