---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Skily — Aprueba el examen DGT a la primera | IA + Gamificación';
const description =
  'Prepara el examen teórico DGT con IA, duelos PvP y gamificación. 3247 preguntas oficiales actualizadas. Prueba gratis ahora mismo — sin registro.';
const canonical = 'https://skilyapp.com/es';

const hreflang = [
  { lang: 'es', href: 'https://skilyapp.com/es' },
  { lang: 'en', href: 'https://skilyapp.com/en' },
  { lang: 'ru', href: 'https://skilyapp.com/ru' },
];

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Skily',
  alternateName: ['Skily App', 'Skilyapp', 'Skily DGT'],
  description: 'Aplicación móvil y Telegram Mini App para preparar el examen teórico DGT. IA tutora, duelos PvP y aprendizaje adaptativo en español, inglés y ruso.',
  applicationCategory: 'EducationApplication',
  operatingSystem: 'Web, iOS, Android, Telegram',
  url: 'https://skilyapp.com',
  downloadUrl: 'https://t.me/skilyapp_bot',
  inLanguage: ['es', 'en', 'ru'],
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' },
  aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '10000', bestRating: '5' },
  publisher: { '@type': 'Organization', name: 'Skily', url: 'https://skilyapp.com', email: 'hello@skily.ai', address: { '@type': 'PostalAddress', addressLocality: 'Barcelona', addressCountry: 'ES' } },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '¿Es obligatorio ir a la autoescuela para el examen teórico DGT?', acceptedAnswer: { '@type': 'Answer', text: 'No. Tienes el derecho legal de presentarte por libre. Las autoescuelas cobran 250–400€ solo por la teoría. Con Skily obtienes la misma preparación sin sobrecostes.' } },
    { '@type': 'Question', name: '¿Cuánto tiempo se necesita para preparar el DGT con Skily?', acceptedAnswer: { '@type': 'Answer', text: 'La mayoría aprueban con 4–6 semanas de práctica diaria de 20 minutos. La IA detecta tus puntos débiles y optimiza el tiempo de estudio.' } },
    { '@type': 'Question', name: '¿Las preguntas de Skily son las del examen real?', acceptedAnswer: { '@type': 'Answer', text: 'Sí. Usamos el banco oficial DGT, actualizado semanalmente. 3247 preguntas con explicaciones en tu idioma.' } },
    { '@type': 'Question', name: '¿Puedo preparar el DGT en otro idioma?', acceptedAnswer: { '@type': 'Answer', text: 'Sí. Skily funciona en español, inglés y ruso. La IA explica cada pregunta en tu idioma nativo.' } },
    { '@type': 'Question', name: '¿Cómo me inscribo al examen por libre?', acceptedAnswer: { '@type': 'Answer', text: 'Pagas la tasa (≈94€) y solicitas cita en la web DGT. Skily Premium incluye guía paso a paso.' } },
  ],
};
---

<BaseLayout title={title} description={description} canonical={canonical} lang="es" ogImage="https://skilyapp.com/og-es.jpg" jsonLd={[appSchema, faqSchema]} hreflang={hreflang}>
<div class="relative min-h-[100dvh] bg-[#0f172a] text-white font-sans overflow-x-hidden selection:bg-indigo-500/30">

  <!-- Noise + Grid -->
  <div class="fixed inset-0 pointer-events-none opacity-[0.03] z-0" style="background-image:url('/noise.svg')"></div>
  <div class="fixed inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px] pointer-events-none z-0"></div>

  <!-- ══════════════ NAV ══════════════ -->
  <nav class="relative z-[100] px-5 md:px-10 pt-5 pb-4 flex items-center justify-between max-w-[1400px] mx-auto">
    <a href="/es" class="flex items-center gap-2.5 select-none">
      <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-indigo-500 to-blue-600 flex items-center justify-center font-black text-white text-sm shadow-lg shadow-indigo-500/30">S</div>
      <span class="font-black text-lg tracking-tight">Skily</span>
    </a>
    <div class="flex items-center gap-2 md:gap-3">
      <div class="hidden sm:flex items-center gap-0.5 text-[11px] font-bold">
        <a href="/es" class="px-2.5 py-1 rounded-lg bg-indigo-500/20 text-indigo-300 border border-indigo-500/30">ES</a>
        <a href="/en" class="px-2.5 py-1 rounded-lg text-slate-500 hover:text-slate-300 transition-colors">EN</a>
        <a href="/ru" class="px-2.5 py-1 rounded-lg text-slate-500 hover:text-slate-300 transition-colors">RU</a>
      </div>
      <a href="https://t.me/skilyapp_bot" target="_blank" rel="noopener noreferrer"
         class="bg-white text-slate-900 px-4 py-2 rounded-xl font-bold text-sm hover:bg-indigo-50 transition-colors shadow-lg shadow-white/10">
        Entrar
      </a>
    </div>
  </nav>

  <!-- ══════════════ HERO (headline + quiz) ══════════════ -->
  <section class="relative z-10 px-5 md:px-10 pt-10 pb-6 md:pt-16 max-w-[1400px] mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- LEFT: Headline -->
      <div>
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-300 text-[10px] font-bold tracking-[0.25em] uppercase mb-6">
          🇪🇸 DGT Approved · 2025
        </div>

        <div class="relative mb-5">
          <div class="absolute -left-4 top-0 bottom-0 w-[110%] blur-[100px] opacity-20 bg-gradient-to-r from-blue-600 via-sky-400 to-cyan-300 pointer-events-none -z-10"></div>
          <h1 class="text-[clamp(2.4rem,6vw,4.5rem)] font-black tracking-tighter leading-[1.02]">
            <span class="bg-clip-text text-transparent bg-gradient-to-b from-white via-slate-100 to-slate-300 block">Tu teórico a la primera.</span>
            <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-500 via-sky-400 to-cyan-300 block">Sin dramas.</span>
          </h1>
        </div>

        <p class="text-slate-400 text-base md:text-lg leading-relaxed mb-8 max-w-lg">
          <span class="text-white font-semibold">Prueba ahora mismo</span> — responde 7 preguntas reales del examen DGT y descubre en qué nivel estás. Sin registro.
        </p>

        <!-- Trust signals (compact) -->
        <div class="flex flex-wrap gap-x-6 gap-y-2 text-xs text-slate-500 font-medium">
          <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>3.247 preguntas oficiales</span>
          <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-blue-400"></span>IA explica cada error</span>
          <span class="flex items-center gap-1.5"><span class="w-1.5 h-1.5 rounded-full bg-indigo-400"></span>10.000+ alumnos activos</span>
        </div>
      </div>

      <!-- RIGHT: Quiz Widget -->
      <div id="quiz-widget" class="relative bg-slate-900/80 backdrop-blur-xl border border-slate-700/60 rounded-[2rem] p-6 md:p-8 shadow-2xl shadow-black/40 overflow-hidden">
        <!-- Glow -->
        <div class="absolute inset-0 bg-gradient-to-br from-indigo-500/5 via-transparent to-blue-500/5 pointer-events-none"></div>

        <!-- Progress bar -->
        <div class="relative z-10 mb-6">
          <div class="flex items-center justify-between mb-2">
            <span id="q-counter" class="text-xs font-bold text-slate-400 uppercase tracking-widest">Pregunta 1 / 7</span>
            <span id="q-score-live" class="text-xs font-bold text-indigo-400">✓ 0 correctas</span>
          </div>
          <div class="h-1.5 bg-slate-800 rounded-full overflow-hidden">
            <div id="progress-bar" class="h-full bg-gradient-to-r from-indigo-500 to-blue-400 rounded-full transition-all duration-500" style="width: 14.3%"></div>
          </div>
        </div>

        <!-- Question area -->
        <div id="q-area" class="relative z-10">
          <!-- Image slot (shown only for questions with images) -->
          <div id="q-image-slot" class="mb-4 flex justify-center" style="display:none!important"></div>

          <p id="q-text" class="text-white font-bold text-base md:text-lg leading-snug mb-5"></p>

          <div id="q-answers" class="grid grid-cols-1 gap-2.5"></div>

          <!-- Explanation (shown after answer) -->
          <div id="q-explanation" class="hidden mt-4 p-4 rounded-xl bg-slate-800/60 border border-slate-700/50 text-slate-300 text-sm leading-relaxed"></div>

          <button id="q-next" class="hidden mt-5 w-full py-3 rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white font-black text-sm transition-colors flex items-center justify-center gap-2">
            Siguiente pregunta <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
          </button>
        </div>

        <!-- Result state (hidden initially) -->
        <div id="q-result" class="hidden relative z-10 text-center py-4">
          <div id="q-result-emoji" class="text-5xl mb-4"></div>
          <div id="q-result-score" class="text-5xl font-black text-white mb-1"></div>
          <div id="q-result-label" class="text-slate-400 text-sm mb-2">de 7 correctas</div>
          <div id="q-result-msg" class="text-base font-semibold text-white mb-6"></div>
          <a href="https://t.me/skilyapp_bot" target="_blank" rel="noopener noreferrer"
             class="flex items-center justify-center gap-2 w-full py-4 rounded-xl bg-white text-slate-900 font-black text-base hover:bg-indigo-50 transition-colors shadow-lg shadow-white/10 mb-3">
            🚀 Empezar gratis en Skily
          </a>
          <p class="text-slate-600 text-xs">Explicación detallada de cada error · IA incluida</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════ HOW IT WORKS ══════════════ -->
  <section class="relative z-10 px-5 md:px-10 py-20 max-w-[1400px] mx-auto">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-black text-white mb-3">Cómo funciona</h2>
      <p class="text-slate-400 max-w-lg mx-auto">Tres pasos para pasar del cero al aprobado.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
      <div class="relative p-7 rounded-[2rem] bg-slate-900/50 border border-slate-800 hover:border-indigo-500/20 transition-all">
        <div class="w-10 h-10 rounded-xl bg-indigo-500/15 border border-indigo-500/20 flex items-center justify-center text-indigo-400 font-black text-lg mb-5">1</div>
        <h3 class="font-black text-lg text-white mb-2">Diagnóstico inicial</h3>
        <p class="text-slate-400 text-sm leading-relaxed">Haz el test de nivel. Skily identifica en qué temas fallas y crea tu plan de estudio personalizado.</p>
      </div>
      <div class="relative p-7 rounded-[2rem] bg-slate-900/50 border border-slate-800 hover:border-indigo-500/20 transition-all">
        <div class="w-10 h-10 rounded-xl bg-blue-500/15 border border-blue-500/20 flex items-center justify-center text-blue-400 font-black text-lg mb-5">2</div>
        <h3 class="font-black text-lg text-white mb-2">Practica con IA</h3>
        <p class="text-slate-400 text-sm leading-relaxed">Tests, duelos y juegos. Cada error tiene explicación inmediata de la IA en tu idioma. El Challenge Bank™ te recuerda repasar lo que fallas.</p>
      </div>
      <div class="relative p-7 rounded-[2rem] bg-slate-900/50 border border-slate-800 hover:border-indigo-500/20 transition-all">
        <div class="w-10 h-10 rounded-xl bg-cyan-500/15 border border-cyan-500/20 flex items-center justify-center text-cyan-400 font-black text-lg mb-5">3</div>
        <h3 class="font-black text-lg text-white mb-2">Simulacro y aprueba</h3>
        <p class="text-slate-400 text-sm leading-relaxed">Cuando alcances 90% en simulacros reales, estás listo. Mismo formato, tiempos y estrés que el examen DGT real.</p>
      </div>
    </div>
  </section>

  <!-- ══════════════ FEATURES GRID ══════════════ -->
  <section class="relative z-10 px-5 md:px-10 py-10 max-w-[1400px] mx-auto">
    <div class="mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-500/10 border border-indigo-500/20 text-indigo-300 text-[10px] font-bold tracking-widest uppercase mb-4">
        Todo lo que incluye Skily
      </div>
      <h2 class="text-3xl md:text-5xl font-black text-white mb-3 max-w-2xl">Una plataforma. Todo lo que necesitas.</h2>
      <p class="text-slate-400 max-w-xl">No es un banco de preguntas. Es un ecosistema completo de aprendizaje.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

      <!-- Feature: Tests DGT -->
      <div class="bg-slate-900/50 border border-slate-800 p-7 rounded-[2rem] hover:border-indigo-500/25 transition-all group">
        <div class="w-11 h-11 rounded-xl bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
          <svg class="w-5 h-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
        </div>
        <h3 class="font-black text-base text-white mb-2">3.247 preguntas oficiales DGT</h3>
        <p class="text-slate-400 text-sm leading-relaxed">Banco completo actualizado semanalmente. Si la DGT cambia una norma, Skily lo refleja ese mismo día.</p>
      </div>

      <!-- Feature: Simulacro -->
      <div class="bg-slate-900/50 border border-slate-800 p-7 rounded-[2rem] hover:border-indigo-500/25 transition-all group">
        <div class="w-11 h-11 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
          <svg class="w-5 h-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h3 class="font-black text-base text-white mb-2">Simulacro real DGT</h3>
        <p class="text-slate-400 text-sm leading-relaxed">30 preguntas, 30 minutos. Mismo interfaz y presión que el examen oficial. Entrena en condiciones reales.</p>
      </div>

      <!-- Feature: Skily AI -->
      <div class="bg-slate-900/80 border border-fuchsia-500/20 p-7 rounded-[2rem] hover:border-fuchsia-500/40 transition-all group relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 blur-3xl bg-fuchsia-500/10 pointer-events-none"></div>
        <div class="w-11 h-11 rounded-xl bg-fuchsia-500/10 border border-fuchsia-500/20 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
          <svg class="w-5 h-5 text-fuchsia-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"/></svg>
        </div>
        <h3 class="font-black text-base text-white mb-2">Skily AI™ — explica cada fallo</h3>
        <p class="text-slate-400 text-sm leading-relaxed">La IA analiza por qué te equivocas y lo explica en tu idioma (ES/EN/RU). No solo la respuesta correcta — la lógica detrás.</p>
        <div class="mt-3 inline-flex items-center gap-1.5 text-[10px] font-bold text-fuchsia-400 uppercase tracking-widest">⚡ Gemini + Groq</div>
      </div>

      <!-- Feature: Challenge Bank -->
      <div class="bg-slate-900/50 border border-slate-800 p-7 rounded-[2rem] hover:border-amber-500/25 transition-all group">
        <div class="w-11 h-11 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
          <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4Zm-8 2a2 2 0 1 0 0 4 2 2 0 0 0 0-4Z"/></svg>
        </div>
        <h3 class="font-black text-base text-white mb-2">Challenge Bank™</h3>
        <p class="text-slate-400 text-sm leading-relaxed">Guarda automáticamente cada pregunta fallada y programa repasos inteligentes. Cero preguntas olvidadas.</p>
      </div>

      <!-- Feature: Duel PvP -->
      <div class="bg-slate-900/50 border border-slate-800 p-7 rounded-[2rem] hover:border-red-500/25 transition-all group">
        <div class="w-11 h-11 rounded-xl bg-red-500/10 border border-red-500/20 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
          <svg class="w-5 h-5 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/></svg>
        </div>
        <h3 class="font-black text-base text-white mb-2">Duel PvP — 1vs1 en tiempo real</h3>
        <p class="text-slate-400 text-sm leading-relaxed">Reta a un amigo o a un desconocido. Quien responda primero y más correctamente, gana monedas. Aprenderás sin darte cuenta.</p>
      </div>

      <!-- Feature: Coins & XP -->
      <div class="bg-slate-900/50 border border-slate-800 p-7 rounded-[2rem] hover:border-yellow-500/25 transition-all group">
        <div class="w-11 h-11 rounded-xl bg-yellow-500/10 border border-yellow-500/20 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
          <svg class="w-5 h-5 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
        </div>
        <h3 class="font-black text-base text-white mb-2">Monedas, XP y niveles</h3>
        <p class="text-slate-400 text-sm leading-relaxed">Cada respuesta correcta da XP y monedas. Sube de nivel, gana logros, desbloquea contenido. El estudio se convierte en juego.</p>
      </div>

      <!-- Feature: Game Modes -->
      <div class="bg-slate-900/50 border border-slate-800 p-7 rounded-[2rem] hover:border-orange-500/25 transition-all group">
        <div class="w-11 h-11 rounded-xl bg-orange-500/10 border border-orange-500/20 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
          <svg class="w-5 h-5 text-orange-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 0 1-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 0 0 6.16-12.12A14.98 14.98 0 0 0 9.631 8.41m5.96 5.96a14.926 14.926 0 0 1-5.841 2.58m-.119-8.54a6 6 0 0 0-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 0 0-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 0 1-2.448-2.448 14.9 14.9 0 0 1 .06-.312m-2.24 2.39a4.493 4.493 0 0 0-1.757 4.306 4.493 4.493 0 0 0 4.306-1.758M16.5 9a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z"/></svg>
        </div>
        <h3 class="font-black text-base text-white mb-2">RaceGame · GuessSign · Matching</h3>
        <p class="text-slate-400 text-sm leading-relaxed">Tres juegos adicionales para fijar señales y conceptos. Contrarreloj, reconocimiento visual y memoria. Aprendes 3x más rápido que leyendo.</p>
      </div>

      <!-- Feature: Topics + Flashcards -->
      <div class="bg-slate-900/50 border border-slate-800 p-7 rounded-[2rem] hover:border-emerald-500/25 transition-all group">
        <div class="w-11 h-11 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center mb-5 group-hover:scale-110 transition-transform">
          <svg class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"/></svg>
        </div>
        <h3 class="font-black text-base text-white mb-2">Temas + Flashcards</h3>
        <p class="text-slate-400 text-sm leading-relaxed">Estudia por categorías (señales, normas, conducción defensiva). Las flashcards fijan conceptos clave en memoria a largo plazo.</p>
      </div>

      <!-- Feature: Leaderboard + Duel Pass -->
      <div class="bg-slate-900/50 border border-slate-800 p-7 rounded-[2rem] hover:border-purple-500/25 transition-all group">
