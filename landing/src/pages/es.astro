---
import BaseLayout from '../layouts/BaseLayout.astro';
const currentYear = new Date().getFullYear();
const appBaseUrl = import.meta.env.DEV ? 'http://localhost:8080' : 'https://skilyapp.com';

const url = new URL(Astro.request.url);
const variant = url.searchParams.get('v') || '1'; // 1 = Side, 2 = Stacked
const isDev = import.meta.env.DEV;

const title = 'Skily — Aprueba el examen DGT a la primera | IA + Gamificación';
const description =
  'Prepara el examen teórico DGT con IA que personaliza tu estudio. Preguntas oficiales actualizadas, simulacros reales, dueloss PvP y explicaciones instantáneas. 97% de aprobados en primera convocatoria.';
const canonical = 'https://skilyapp.com/es';

const hreflang = [
  { lang: 'es', href: 'https://skilyapp.com/es' },
  { lang: 'en', href: 'https://skilyapp.com/en' },
  { lang: 'ru', href: 'https://skilyapp.com/ru' },
];

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Skily',
  alternateName: ['Skily App', 'Skilyapp', 'Skily DGT'],
  description:
    'Aplicación móvil y Telegram Mini App para preparar el examen teórico DGT (carnet de conducir en España). Usa IA tutora, duelos PvP y aprendizaje adaptativo. Disponible en español, inglés y ruso.',
  applicationCategory: 'EducationApplication',
  operatingSystem: 'Web, iOS, Android, Telegram',
  url: 'https://skilyapp.com',
  downloadUrl: 'https://t.me/skilyapp_bot',
  inLanguage: ['es', 'en', 'ru'],
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'EUR',
    description: 'Acceso básico gratuito. Premium desde 4,99€/mes.',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '10000',
    bestRating: '5',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Skily',
    url: 'https://skilyapp.com',
    email: 'hello@skily.ai',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Barcelona',
      addressCountry: 'ES',
    },
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Es obligatorio ir a la autoescuela para el examen teórico DGT?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No, es un mito. Tienes el derecho legal de presentarte por libre ("Por Libre"). Las autoescuelas cobran entre 250€ y 400€ solo por la teoría. Con Skily obtienes la misma preparación —o mejor— sin sobrecostes.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cuánto tiempo se necesita para preparar el examen DGT con Skily?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'La mayoría de nuestros alumnos aprueban con 4-6 semanas de práctica diaria de 20 minutos. La IA detecta tus puntos débiles y optimiza el tiempo de estudio.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Las preguntas de Skily son las mismas que en el examen real?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí. Usamos el banco oficial de preguntas DGT, actualizado semanalmente. Si la DGT modifica una pregunta, Skily lo refleja ese mismo día.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Puedo preparar el DGT en otro idioma si mi español es bajo?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí. Skily está disponible en español, inglés y ruso. La IA explica la lógica de cada pregunta en tu idioma nativo para que entiendas el concepto, no solo memorices la respuesta.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cómo me inscribo al examen DGT por libre?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Debes pagar la tasa (Tasa 2.1, aprox. 94€) y solicitar cita en la web de la DGT. Skily Premium incluye una guía paso a paso con los enlaces y formularios necesarios.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué diferencia hay entre Skily y una autoescuela?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'La autoescuela cobra 250-400€ solo por teoría, tiene horario fijo y explicaciones genéricas. Skily cuesta desde 4,99€/mes, está disponible 24/7 y la IA personaliza el aprendizaje según tus errores específicos.',
      },
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  lang="es"
  ogImage="https://skilyapp.com/og-es.jpg"
  jsonLd={[appSchema, faqSchema]}
  hreflang={hreflang}
>
  <!-- Auth redirect: logged-in users go straight to /dashboard -->
  <script is:inline>
    (function() {
      try {
        var raw = localStorage.getItem('sb-yffjnqegeiorunyvcxkn-auth-token');
        if (raw) {
          var parsed = JSON.parse(raw);
          if (parsed && parsed.access_token) {
            window.location.replace('/dashboard');
          }
        }
      } catch(e) {}
    })();
  </script>

  <div class="relative min-h-[100dvh] bg-[#0f172a] text-white font-sans overflow-x-hidden selection:bg-indigo-500/30 w-full">

    <!-- Dev Variant Switcher (Only in DEV) -->
    {isDev && (
      <div class="fixed bottom-10 right-10 z-[9999] flex flex-col gap-3">
        <div class="bg-slate-900/90 backdrop-blur-xl border border-white/10 p-2 rounded-2xl shadow-2xl">
          <div class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2 px-2 text-center">Design Variant</div>
          <div class="flex flex-col gap-2">
            <a href="?v=1" class={`px-4 py-2.5 rounded-xl text-xs font-bold transition-all flex items-center gap-2 ${variant === '1' ? 'bg-blue-600 text-white shadow-lg shadow-blue-500/30' : 'text-slate-400 hover:bg-white/5 hover:text-white'}`}>
              <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
              Side (Modern)
            </a>
            <a href="?v=2" class={`px-4 py-2.5 rounded-xl text-xs font-bold transition-all flex items-center gap-2 ${variant === '2' ? 'bg-blue-600 text-white shadow-lg shadow-blue-500/30' : 'text-slate-400 hover:bg-white/5 hover:text-white'}`}>
              <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
              Stacked (Classic)
            </a>
          </div>
        </div>
      </div>
    )}

    <!-- Noise texture -->
    <div class="fixed inset-0 pointer-events-none opacity-[0.03] z-0" style="background-image:url('/noise.svg')"></div>
    <!-- Grid pattern -->
    <div class="fixed inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px] pointer-events-none z-0"></div>

    <!-- ═══════════════════════════════════════ NAV ══════════════════════════════════════ -->
    <nav class="relative z-[100] px-4 md:px-10 pt-5 pb-4 md:pb-6 flex items-center justify-between max-w-[1400px] mx-auto gap-4">
      <a href="/es" class="flex items-center gap-2.5 select-none" aria-label="Skily inicio">
        <!-- Настоящий логотип Skily: синий квадрат + машинка Lucide car-front -->
        <div class="w-10 h-10 rounded-2xl flex items-center justify-center shadow-lg shadow-blue-500/30 shrink-0" style="background:linear-gradient(135deg,#3b82f6,#2563eb,#1d4ed8);">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m21 8-2 2-1.5-3.7A2 2 0 0 0 15.646 5H8.4a2 2 0 0 0-1.903 1.257L5 10 3 8"/>
            <path d="M7 14h.01"/><path d="M17 14h.01"/>
            <rect width="18" height="8" x="3" y="10" rx="2"/>
            <path d="M5 18v2"/><path d="M19 18v2"/>
          </svg>
        </div>
        <span class="font-black text-lg tracking-tight text-white" style="letter-spacing:-0.02em;">Skily</span>
      </a>

      <div class="flex items-center gap-2 md:gap-3 ml-auto">
        <div class="relative group hidden sm:flex items-center h-[40px] w-[40px]">
          <div class="absolute right-0 flex items-center bg-white/5 border border-white/10 backdrop-blur-xl rounded-full overflow-hidden transition-all duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] w-[40px] group-hover:w-[120px] h-[40px] shadow-[0_0_15px_rgba(0,0,0,0.1)]">
            <div class="flex items-center min-w-[120px] px-1 gap-1 h-full">
              <div class="w-[32px] h-[32px] flex items-center justify-center rounded-full bg-white text-slate-900 font-black text-[10px] shadow-sm shrink-0 cursor-default">ES</div>
              <a href="/en" class="w-[32px] h-[32px] flex items-center justify-center rounded-full hover:bg-white/10 text-slate-400 hover:text-white font-bold text-[10px] transition-colors shrink-0">EN</a>
              <a href="/ru" class="w-[32px] h-[32px] flex items-center justify-center rounded-full hover:bg-white/10 text-slate-400 hover:text-white font-bold text-[10px] transition-colors shrink-0">RU</a>
            </div>
          </div>
        </div>
        <a
          href={`${appBaseUrl}/login`}
          class="bg-white text-slate-900 px-6 py-2.5 rounded-xl font-bold text-sm hover:scale-[1.02] active:scale-[0.98] transition-all shadow-lg shadow-white/10 whitespace-nowrap"
        >
          Entrar
        </a>
      </div>
    </nav>

    <!-- ═══════════════════════════════════════ HERO SECTION ═══════════════════════════════════ -->
    <section class="relative pt-20 pb-10 md:pt-32 md:pb-32 overflow-hidden px-6">
      <div class="max-w-[1400px] mx-auto relative z-10">
        <!-- Variant 1 Container -->
        <div id="hero-v1" class="hidden">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-8 items-center pt-4 md:pt-10">
            <div class="flex flex-col items-center lg:items-start text-center lg:text-left reveal-on-scroll">
              <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-300 text-[10px] font-bold tracking-[0.2em] uppercase mb-8">
                🇪🇸 DGT Approved · {currentYear}
              </div>
              <h1 class="text-[clamp(2.5rem,8vw,5rem)] lg:text-[clamp(3rem,5vw,5.5rem)] font-black tracking-tighter leading-[1.05] mb-6">
                <span class="bg-clip-text text-transparent bg-gradient-to-b from-white via-slate-100 to-slate-300 block pb-2">Tu teórico a la primera</span>
                <span class="block" style="overflow:hidden;padding-bottom:0.08em;margin-bottom:-0.08em">
                  <span id="hero-word-v1" class="hero-rotating-word block" style="background:linear-gradient(to right,#3b82f6,#38bdf8,#67e8f9);-webkit-background-clip:text;background-clip:text;color:transparent;white-space:nowrap">Sin dramas</span>
                </span>
              </h1>
              <p class="max-w-xl text-lg md:text-xl text-slate-300 leading-relaxed mb-10 font-medium">
                <span class="text-white font-bold">Olvida los manuales aburridos</span>. Nuestra IA detecta tus fallos и personaliza el estudio. Gamificación, preguntas oficiales actualizadas и Tu 'L' esperando.
              </p>
              <div class="flex flex-col sm:flex-row items-center gap-6 w-full lg:justify-start">
                <a href={`${appBaseUrl}/demo`} class="relative flex items-center justify-center gap-3 px-10 py-5 rounded-2xl bg-white text-slate-900 font-black text-lg shadow-2xl hover:scale-[1.02] active:scale-[0.98] transition-all duration-300">
                  <span>Probar test gratis</span>
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
                </a>
              </div>
            </div>
            <div class="relative w-[115%] -ml-[7.5%] h-[280px] sm:h-[450px] lg:h-[700px] sm:w-full sm:ml-0 reveal-on-scroll" style="transition-delay: 200ms" id="product-showcase-v1">
              <div class="lg:absolute lg:top-1/2 lg:-translate-y-1/2 lg:left-0 lg:w-[140%] lg:max-w-none perspective-2000">
                <div class="relative w-full parallax-element">
                   <div class="floating-animation">
                      <div class="absolute -inset-20 bg-blue-500/20 blur-[120px] rounded-full opacity-60"></div>
                      <div class="relative rounded-[2.5rem] overflow-hidden shadow-[0_30px_60px_-15px_rgba(0,0,0,0.9),0_0_80px_0_rgba(59,130,246,0.4)] border border-white/20 group">
                        <img src="/images/dashboard-preview.png" alt="Skily Dashboard" class="w-full h-auto object-cover scale-[1.3] md:scale-[1.02] group-hover:scale-105 transition-transform duration-1000" />
                      </div>
                   </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Variant 2 Container -->
        <div id="hero-v2" class="hidden">
          <div class="flex flex-col items-center text-center max-w-4xl mx-auto pt-10">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-300 text-[10px] font-bold tracking-[0.2em] uppercase mb-8 reveal-on-scroll">
              🇪🇸 DGT Approved · {currentYear}
            </div>
            <h1 class="text-[clamp(2.5rem,8vw,6rem)] font-black tracking-tighter leading-[1.05] mb-8 reveal-on-scroll">
              <span class="bg-clip-text text-transparent bg-gradient-to-b from-white via-slate-100 to-slate-300 block pb-2">Tu teórico a la primera</span>
              <span class="block" style="overflow:hidden;padding-bottom:0.08em;margin-bottom:-0.08em">
                <span id="hero-word-v2" class="hero-rotating-word block" style="background:linear-gradient(to right,#3b82f6,#38bdf8,#67e8f9);-webkit-background-clip:text;background-clip:text;color:transparent;white-space:nowrap">Sin dramas</span>
              </span>
            </h1>
            <p class="max-w-2xl text-lg md:text-xl text-slate-300 leading-relaxed mb-12 font-medium reveal-on-scroll">
              <span class="text-white font-bold">Olvida los manuales aburridos</span>. Nuestra IA detectта tus fallos и personaliza el estudio. Gamificación, preguntas oficiales actualizadas и Tu 'L' esperando.
            </p>
            <div class="flex flex-col sm:flex-row items-center justify-center gap-6 w-full mb-20 reveal-on-scroll">
              <a href={`${appBaseUrl}/demo`} class="relative flex items-center justify-center gap-3 px-12 py-6 rounded-2xl bg-white text-slate-900 font-black text-xl shadow-2xl hover:scale-[1.02] active:scale-[0.98] transition-all duration-300">
                <span>Probar test gratis</span>
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
              </a>
            </div>
            <div class="relative w-[115%] -ml-[7.5%] sm:w-full sm:ml-0 max-w-[1000px] mx-auto reveal-on-scroll" id="product-showcase-v2">
              <div class="relative w-full perspective-2000 parallax-element">
                 <div class="floating-animation">
                    <div class="absolute -inset-20 bg-blue-500/10 blur-[100px] rounded-full opacity-40"></div>
                    <div class="relative rounded-[2.5rem] overflow-hidden shadow-[0_50px_100px_-20px_rgba(0,0,0,0.6)] border border-white/10">
                      <img src="/images/dashboard-preview.png" alt="Skily Dashboard" class="w-full h-auto object-cover scale-[1.1] md:scale-100" />
                    </div>
                 </div>
              </div>
            </div>
          </div>
        </div>

        <script is:inline>
          // Immediate client-side visibility toggle
          (function() {
            const urlParams = new URLSearchParams(window.location.search);
            const v = urlParams.get('v') || '1';
            const el = document.getElementById('hero-v' + v);
            if (el) el.classList.remove('hidden');
          })();
        </script>
      </div>

      <!-- Background Grid Decoration -->
      <div class="absolute inset-0 z-0 opacity-20 [mask-image:radial-gradient(ellipse_at_center,black,transparent)] pointer-events-none">
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#1e293b_1px,transparent_1px),linear-gradient(to_bottom,#1e293b_1px,transparent_1px)] bg-[size:40px_40px]"></div>
      </div>
    </section>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const observerOptions = { threshold: 0.05, rootMargin: '0px 0px -50px 0px' };
        
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              // If this element or its parent is the showcase, init parallax
              if (entry.target.id === 'product-showcase' || entry.target.querySelector('#product-showcase-container')) {
                initShowcaseParallax();
              }
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);

        // Observe all revealable elements
        const revealElements = document.querySelectorAll('.reveal-on-scroll, section');
        revealElements.forEach(el => observer.observe(el));

        function initShowcaseParallax() {
          const showcase = document.getElementById('product-showcase-container');
          if (!showcase || showcase.dataset.parallaxInit) return;
          showcase.dataset.parallaxInit = "true";

          let ticking = false;
          const updateParallax = () => {
            const rect = showcase.getBoundingClientRect();
            const winH = window.innerHeight;
            const progress = (rect.top + rect.height / 2 - winH / 2) / (winH / 2 + rect.height / 2);
            
            // Stronger angles: X: 20deg, Y: -25deg, Offset: 80px
            const tiltX = progress * 20; 
            const tiltY = progress * -25;
            
            showcase.style.setProperty('--tilt-x', `${tiltX}deg`);
            showcase.style.setProperty('--tilt-y', `${tiltY}deg`);
            showcase.style.setProperty('--parallax-offset', `${progress * 80}px`);
            ticking = false;
          };

          window.addEventListener('scroll', () => {
            if (!ticking) {
              window.requestAnimationFrame(updateParallax);
              ticking = true;
            }
          }, { passive: true });
          
          updateParallax();
        }

        // Emergency reveal for top elements if observer fails or is slow
        setTimeout(() => {
          document.querySelectorAll('.reveal-on-scroll').forEach(el => {
            const rect = el.getBoundingClientRect();
            if (rect.top < window.innerHeight) {
              el.classList.add('revealed');
              if (el.id === 'product-showcase') initShowcaseParallax();
            }
          });
        }, 500);

        // ── Hero rotating words ────────────────────────────────────────────────
        (function() {
          var WORDS = [
            { text:'Sin dramas',            grad:'linear-gradient(to right,#3b82f6,#38bdf8,#67e8f9)' },
            { text:'Con IA inteligente',    grad:'linear-gradient(to right,#8b5cf6,#c084fc,#e879f9)' },
            { text:'Jugando en PvP',        grad:'linear-gradient(to right,#f97316,#fb923c,#fcd34d)' },
            { text:'En tiempo récord',      grad:'linear-gradient(to right,#10b981,#2dd4bf,#67e8f9)' },
            { text:'Sin libros aburridos',  grad:'linear-gradient(to right,#ec4899,#f472b6,#fb923c)' },
          ];
          var idx = 0;

          function getEls() {
            return ['hero-word-v1','hero-word-v2']
              .map(function(id){ return document.getElementById(id); })
              .filter(Boolean);
          }

          function rotate() {
            idx = (idx + 1) % WORDS.length;
            var word = WORDS[idx];
            getEls().forEach(function(el) {
              el.classList.add('hero-word-out');
              setTimeout(function() {
                el.textContent = word.text;
                el.style.backgroundImage = word.grad;
                el.classList.remove('hero-word-out');
                el.classList.add('hero-word-in');
                setTimeout(function(){ el.classList.remove('hero-word-in'); }, 700);
              }, 420);
            });
          }

          setInterval(rotate, 2800);
        })();
      });
    </script>

    <style is:global>
      .reveal-on-scroll {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.8s ease-out, transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .reveal-on-scroll.revealed {
        opacity: 1;
        transform: translateY(0);
      }

      /* Showcase Parallax Layer */
      .parallax-element {
        --tilt-x: 10deg;
        --tilt-y: -15deg;
        --parallax-offset: 0px;
        transform: rotateX(var(--tilt-x)) rotateY(var(--tilt-y)) translateY(var(--parallax-offset));
        will-change: transform;
      }

      @media (max-width: 768px) {
        .parallax-element {
          --tilt-x: 5deg;
          --tilt-y: -8deg;
        }
      }

      .perspective-2000 {
        perspective: 2000px;
      }
      
      /* Floating Layer (Inner) */
      .floating-animation {
        animation: float 6s ease-in-out infinite;
        will-change: transform;
      }

      @keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-20px); }
      }

      .group:hover .floating-animation {
        animation-play-state: paused;
      }

      /* ── Hero rotating words ───────────────────────────── */
      .hero-rotating-word { will-change: transform, opacity, filter; }
      @keyframes heroWordIn {
        from { opacity:0; transform:translateY(110%); filter:blur(10px); }
        to   { opacity:1; transform:translateY(0);    filter:blur(0); }
      }
      @keyframes heroWordOut {
        from { opacity:1; transform:translateY(0);     filter:blur(0); }
        to   { opacity:0; transform:translateY(-110%); filter:blur(10px); }
      }
      .hero-word-in  { animation: heroWordIn  0.6s cubic-bezier(0.16,1,0.3,1) forwards; }
      .hero-word-out { animation: heroWordOut 0.4s cubic-bezier(0.4,0,1,1)    forwards; }
    </style>

    <!-- ═══════════════════════════════════════ FEATURES (Zig-Zag) ══════════════════════════════════════ -->
    <section id="features" class="relative z-10 py-24 md:py-40 bg-[#0f172a]">
      <div class="max-w-[1400px] mx-auto px-6">
        <!-- Features Header -->
        <div class="text-center mb-24 md:mb-40 reveal-on-scroll">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-300 text-[10px] font-bold tracking-[0.2em] uppercase mb-8">
            ✦ Plataforma Completa
          </div>
          <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 leading-tight max-w-3xl mx-auto">
            TODO lo que necesitas para<br/><span class="text-slate-300">aprobar en un único lugar</span>
          </h2>
          <p class="text-slate-400 text-base md:text-lg max-w-2xl mx-auto">Más de 40.000 estudiantes ya preparan su carnet con Skily — IA personalizada, duelos reales y gamificación.</p>
