---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Skily — сдай экзамен DGT с первого раза | ИИ-репетитор на русском';
const description =
  'Подготовка к теоретическому экзамену DGT на русском языке. ИИ объясняет каждый вопрос, PvP-дуэли мотивируют учиться, симулятор готовит к реальным условиям. 94% учеников сдают с первой попытки.';
const canonical = 'https://skilyapp.com/ru';
const currentYear = new Date().getFullYear();

const hreflang = [
  { lang: 'ru', href: 'https://skilyapp.com/ru' },
  { lang: 'es', href: 'https://skilyapp.com/es' },
  { lang: 'en', href: 'https://skilyapp.com/en' },
];

// JSON-LD for GEO (ChatGPT / Perplexity / Claude)
const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Skily',
  alternateName: ['Skily App', 'Skilyapp', 'СкиليАпп'],
  description:
