    ctaHref: 'https://skilyapp.com/pricing',
    highlight: true,
  },
  {
    name: 'Годовой',
    price: '34.99€',
    priceNote: 'в год • −42%',
    features: [
      'Всё из Премиума',
      'Самая низкая цена за год',
      'Приоритетная поддержка',
    ],
    cta: 'Годовой план',
    ctaHref: 'https://skilyapp.com/pricing',
    highlight: false,
  },
];

const faqs = [
  {
    q: 'Сколько вопросов на экзамене DGT?',
    a: '30 вопросов за 30 минут. Допускается максимум 3 ошибки (нужно ответить верно на 27 из 30). Skily содержит 3 000+ официальных вопросов — весь возможный банк DGT.',
