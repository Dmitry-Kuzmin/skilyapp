---
import BaseLayout from '../layouts/BaseLayout.astro';
const currentYear = new Date().getFullYear();
const appBaseUrl = import.meta.env.DEV ? 'http://localhost:8080' : 'https://skilyapp.com';

const url = new URL(Astro.request.url);
const variant = url.searchParams.get('v') || '2'; // 1 = Side, 2 = Stacked
const isDev = import.meta.env.DEV;

const title = 'Skily — сдай экзамен DGT с первого раза | ИИ + Геймификация';
const description =
  'Подготовка к теоретическому экзамену DGT с ИИ, который персонализирует твое обучение. Официальные вопросы, реальные симуляции, PvP-дуэли и мгновенные объяснения. 97% сдают с первой попытки.';
const canonical = 'https://skilyapp.com/ru';

const hreflang = [
  { lang: 'es', href: 'https://skilyapp.com/es' },
  { lang: 'en', href: 'https://skilyapp.com/en' },
  { lang: 'ru', href: 'https://skilyapp.com/ru' },
];

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Skily',
  alternateName: ['Skily App', 'Skilyapp', 'Skily DGT'],
  description:
    'Мобильное приложение и Telegram Mini App для подготовки к экзамену DGT. Использует ИИ-тьютора, PvP-дуэли и адаптивное обучение. Доступно на испанском, английском и русском.',
  applicationCategory: 'EducationApplication',
  operatingSystem: 'Web, iOS, Android, Telegram',
  url: 'https://skilyapp.com',
  downloadUrl: 'https://t.me/skilyapp_bot',
  inLanguage: ['es', 'en', 'ru'],
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'EUR',
    description: 'Базовый доступ бесплатно. Премиум от 4,99€/мес.',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.8',
    reviewCount: '312',
    bestRating: '5',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Skily',
    url: 'https://skilyapp.com',
    email: 'hello@skily.ai',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Barcelona',
      addressCountry: 'ES',
    },
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Обязательно ли идти в автошколу для теории DGT?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Нет, это миф. У вас есть законное право сдавать теорию самостоятельно ("Por Libre"). Автошколы берут от 250€ до 400€ только за теорию. Со Skily вы получаете ту же подготовку без переплат.',
      },
    },
    {
      '@type': 'Question',
      name: 'Сколько времени нужно для подготовки с Skily?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Большинство наших учеников сдают через 4-6 недель ежедневных занятий по 20 минут. ИИ находит ваши слабые места и оптимизирует время обучения.',
      },
    },
    {
      '@type': 'Question',
      name: 'Вопросы в Skily такие же, как на реальном экзамене?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Да. Мы используем официальную базу вопросов DGT, обновляемую еженедельно. Если DGT меняет вопрос, Skily обновляет его в тот же день.',
      },
    },
  ],
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  lang="ru"
  ogImage="https://skilyapp.com/og-ru.jpg"
  jsonLd={[appSchema, faqSchema]}
  hreflang={hreflang}
>
  <link rel="preload" as="image" href="/images/dashboard-preview.webp" fetchpriority="high" slot="head" />
  <!-- Auth redirect: logged-in users go straight to /dashboard -->
  <script is:inline>
    (function() {
      try {
        var raw = localStorage.getItem('sb-yffjnqegeiorunyvcxkn-auth-token');
        if (raw) {
          var parsed = JSON.parse(raw);
          if (parsed && parsed.access_token) {
            window.location.replace('/dashboard');
          }
        }
      } catch(e) {}
    })();
  </script>

  <div class="relative min-h-[100dvh] bg-[#0f172a] text-white font-sans overflow-x-hidden selection:bg-blue-500/30 w-full">

    <!-- Dev Variant Switcher (Only in DEV) -->
    {isDev && (
      <div class="fixed bottom-10 right-10 z-[9999] flex flex-col gap-3">
        <div class="bg-slate-900/90 backdrop-blur-xl border border-white/10 p-2 rounded-2xl shadow-2xl">
          <div class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-2 px-2 text-center">Вариант дизайна</div>
          <div class="flex flex-col gap-2">
            <a href="?v=1" class={`px-4 py-2.5 rounded-xl text-xs font-bold transition-all flex items-center gap-2 ${variant === '1' ? 'bg-blue-600 text-white shadow-lg shadow-blue-500/30' : 'text-slate-400 hover:bg-white/5 hover:text-white'}`}>
              <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
              Side (Modern)
            </a>
            <a href="?v=2" class={`px-4 py-2.5 rounded-xl text-xs font-bold transition-all flex items-center gap-2 ${variant === '2' ? 'bg-blue-600 text-white shadow-lg shadow-blue-500/30' : 'text-slate-400 hover:bg-white/5 hover:text-white'}`}>
              <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
              Stacked (Classic)
            </a>
          </div>
        </div>
      </div>
    )}

    <!-- Noise texture -->
    <div class="fixed inset-0 pointer-events-none opacity-[0.03] z-0" style="background-image:url('/noise.svg')"></div>
    <!-- Grid pattern -->
    <div class="fixed inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px] pointer-events-none z-0"></div>

    <!-- ═══════════════════════════════════════ NAV ══════════════════════════════════════ -->
    <nav class="relative z-[100] px-4 md:px-10 pt-5 pb-4 md:pb-6 flex items-center max-w-[1400px] mx-auto gap-4">
      <a href="/ru" class="flex items-center gap-2.5 select-none shrink-0" aria-label="Skily начало">
        <div class="w-10 h-10 rounded-2xl flex items-center justify-center shadow-lg shadow-blue-500/30 shrink-0" style="background:linear-gradient(135deg,#3b82f6,#2563eb,#1d4ed8);">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m21 8-2 2-1.5-3.7A2 2 0 0 0 15.646 5H8.4a2 2 0 0 0-1.903 1.257L5 10 3 8"/>
            <path d="M7 14h.01"/><path d="M17 14h.01"/>
            <rect width="18" height="8" x="3" y="10" rx="2"/>
            <path d="M5 18v2"/><path d="M19 18v2"/>
          </svg>
        </div>
        <span class="font-black text-lg tracking-tight text-white" style="letter-spacing:-0.02em;">Skily</span>
      </a>

      <!-- Desktop nav items -->
      <div class="hidden md:flex flex-1 justify-center items-center gap-0.5 px-4">
        <a href={`${appBaseUrl}/tests`} class="flex items-center gap-2 px-3 py-2 rounded-lg text-slate-400 hover:text-white hover:bg-white/[0.07] transition-all duration-200 text-sm font-medium whitespace-nowrap">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
          Тесты
        </a>
        <a href={`${appBaseUrl}/learning`} class="flex items-center gap-2 px-3 py-2 rounded-lg text-slate-400 hover:text-white hover:bg-white/[0.07] transition-all duration-200 text-sm font-medium whitespace-nowrap">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 7v14"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/></svg>
          Обучение
        </a>
        <a href={`${appBaseUrl}/games`} class="flex items-center gap-2 px-3 py-2 rounded-lg text-slate-400 hover:text-white hover:bg-white/[0.07] transition-all duration-200 text-sm font-medium whitespace-nowrap">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="6" x2="10" y1="11" y2="11"/><line x1="8" x2="8" y1="9" y2="13"/><line x1="15" x2="15.01" y1="12" y2="12"/><line x1="18" x2="18.01" y1="10" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z"/></svg>
          Игры
        </a>
      </div>

      <div class="flex items-center gap-2 md:gap-3 ml-auto shrink-0">
        <div class="relative group hidden sm:flex items-center h-[40px] w-[40px]">
          <div class="absolute right-0 flex items-center bg-white/5 border border-white/10 backdrop-blur-xl rounded-full overflow-hidden transition-all duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] w-[40px] group-hover:w-[120px] h-[40px] shadow-[0_0_15px_rgba(0,0,0,0.1)]">
            <div class="flex items-center min-w-[120px] px-1 gap-1 h-full">
              <div class="w-[32px] h-[32px] flex items-center justify-center rounded-full bg-white text-slate-900 font-black text-[10px] shadow-sm shrink-0 cursor-default">RU</div>
              <a href="/es" class="w-[32px] h-[32px] flex items-center justify-center rounded-full hover:bg-white/10 text-slate-400 hover:text-white font-bold text-[10px] transition-colors shrink-0">ES</a>
              <a href="/en" class="w-[32px] h-[32px] flex items-center justify-center rounded-full hover:bg-white/10 text-slate-400 hover:text-white font-bold text-[10px] transition-colors shrink-0">EN</a>
            </div>
          </div>
        </div>
        <a
          href={`${appBaseUrl}/login`}
          class="bg-white text-slate-900 px-6 py-2.5 rounded-xl font-bold text-sm hover:scale-[1.02] active:scale-[0.98] transition-all shadow-lg shadow-white/10 whitespace-nowrap"
        >
          Войти
        </a>
      </div>
    </nav>
    <!-- Mobile nav pills -->
    <div class="md:hidden flex items-center gap-2 px-4 pb-4 overflow-x-auto relative z-[100] max-w-[1400px] mx-auto" style="-webkit-overflow-scrolling:touch;scrollbar-width:none;">
      <a href={`${appBaseUrl}/tests`} class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-white/[0.06] border border-white/[0.08] text-slate-300 text-xs font-semibold whitespace-nowrap hover:bg-white/10 transition-colors shrink-0">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
        Тесты
      </a>
      <a href={`${appBaseUrl}/learning`} class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-white/[0.06] border border-white/[0.08] text-slate-300 text-xs font-semibold whitespace-nowrap hover:bg-white/10 transition-colors shrink-0">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 7v14"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/></svg>
        Обучение
      </a>
      <a href={`${appBaseUrl}/games`} class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-white/[0.06] border border-white/[0.08] text-slate-300 text-xs font-semibold whitespace-nowrap hover:bg-white/10 transition-colors shrink-0">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" x2="10" y1="11" y2="11"/><line x1="8" x2="8" y1="9" y2="13"/><line x1="15" x2="15.01" y1="12" y2="12"/><line x1="18" x2="18.01" y1="10" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z"/></svg>
        Игры
      </a>
    </div>

    <!-- ═══════════════════════════════════════ HERO SECTION ═══════════════════════════════════ -->
    <section class="relative pt-12 pb-10 md:pt-16 md:pb-32 overflow-hidden px-6">
      <div class="max-w-[1400px] mx-auto relative z-10">
        <div>
          <div class="flex flex-col items-center text-center max-w-4xl mx-auto pt-2">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-300 text-[10px] font-bold tracking-[0.2em] uppercase mb-6 reveal-on-scroll">
              🇪🇸 DGT Approved · {currentYear}
            </div>
            <h1 class="text-[clamp(2rem,5vw,4rem)] md:whitespace-nowrap font-black tracking-tighter leading-[1.05] mb-6 reveal-on-scroll">
              <span class="bg-clip-text text-transparent bg-gradient-to-b from-white via-slate-100 to-slate-300 block pb-2">Теория DGT с первого раза</span>
              <span class="block min-h-[1.2em]">
                <span id="text-cycler" class="text-cycle-container">
                  {["Без стресса", "С умным ИИ", "Играя в PvP-дуэли", "В рекордные сроки", "Без скучных учебников"].map((word, i) => (
                    <span class={`text-cycle-word ${i === 0 ? 'active' : ''}`} style={i === 0 ? "position:relative;" : ""}>{word}</span>
                  ))}
                </span>
              </span>
            </h1>
            
            <style>
              .text-cycle-container {
                display: inline-flex;
                position: relative;
                transition: width 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
                white-space: nowrap;
                height: 1.2em;
              }
              .text-cycle-word {
                position: absolute;
                left: 0;
                top: 0;
                opacity: 0;
                transform: translateY(-20px);
                filter: blur(8px);
                pointer-events: none;
                background-image: linear-gradient(to right, #3b82f6, #38bdf8, #67e8f9);
                -webkit-background-clip: text;
                color: transparent;
                padding-right: 0.1em;
              }
              .text-cycle-word.active {
                opacity: 1;
                transform: translateY(0);
                filter: blur(0px);
                transition: opacity 0.4s ease-out, transform 0.4s ease-out, filter 0.4s ease-out;
              }
              .text-cycle-word.exit {
                opacity: 0;
                transform: translateY(20px);
                filter: blur(8px);
                transition: opacity 0.3s ease-in, transform 0.3s ease-in, filter 0.3s ease-in;
              }
            </style>

            <script is:inline>
              (function() {
                requestAnimationFrame(() => {
                  const container = document.getElementById('text-cycler');
                  if(!container) return;
                  const wordEls = Array.from(container.querySelectorAll('.text-cycle-word'));
                  if(wordEls.length === 0) return;
                  let currentIndex = 0;
                  container.style.width = wordEls[0].offsetWidth + 'px';
                  wordEls[0].style.position = 'absolute';

                  function cycle() {
                    const prevIndex = currentIndex;
                    currentIndex = (currentIndex + 1) % wordEls.length;
                    const currentEl = wordEls[currentIndex];
                    const prevEl = wordEls[prevIndex];
                    currentEl.style.opacity = '0';
                    currentEl.style.position = 'relative';
                    const newWidth = currentEl.offsetWidth;
                    currentEl.style.position = 'absolute';
                    currentEl.style.opacity = '';
                    container.style.width = newWidth + 'px';
                    prevEl.classList.remove('active');
                    prevEl.classList.add('exit');
                    setTimeout(() => {
                      prevEl.classList.remove('exit');
                    }, 400);
                    currentEl.classList.add('active');
                  }
                  setInterval(cycle, 3000);
                });
              })();
            </script>

            <p class="max-w-2xl text-lg md:text-xl text-slate-300 leading-relaxed mb-10 font-medium reveal-on-scroll" style="transition-delay: 100ms">
              <span class="text-white font-bold">Обеспечь себе успех</span>. Наш ИИ объясняет логику каждого правила, а PvP-дуэли превращают подготовку в азартную игру.
            </p>
            <div class="flex flex-col items-center gap-4 w-full sm:w-auto reveal-on-scroll" style="transition-delay: 200ms">
              <div class="engine-scale-wrapper">
                <button class="engine-btn-outer" id="engine-btn-v2" data-url={`${appBaseUrl}/login`} onclick="handleStartEngine(this)">
                  <div class="engine-glow" id="engine-glow-v2"></div>
                  <div class="engine-ring-layer" id="engine-ring-v2">
                    <div class="engine-dark-circle">
                      <div class="engine-inner-circle">
                        <div class="engine-radial-overlay"></div>
                        <div class="engine-bar-track"><div class="engine-bar-fill" id="engine-bar-v2"></div></div>
                        <div class="engine-content-group">
                          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="engine-power-icon">
                            <path d="M12 2v10"/><path d="M18.4 6.6a9 9 0 1 1-12.77.04"/>
                          </svg>
                          <span class="engine-lbl-engine">Engine</span>
                          <span class="engine-lbl-ss">Start/Stop</span>
                        </div>
                        <div class="engine-ambient-light"></div>
                      </div>
                    </div>
                  </div>
                </button>
              </div>
              <div class="engine-press-row">
                <div class="engine-sep-line"></div>
                <span class="engine-sep-text">Нажми Start</span>
                <div class="engine-sep-line engine-sep-line-right"></div>
              </div>
              <a href={`${appBaseUrl}/demo?lang=ru`} class="engine-demo-link">или войти напрямую →</a>
              <a href="https://t.me/skilyapp_bot" class="engine-demo-link" style="color:#475569">Открыть в Telegram</a>
            </div>
            
            <div class="mt-20 w-full" id="product-showcase-container">
               <div class="relative w-full max-w-5xl mx-auto parallax-element">
                  <div class="floating-animation">
                     <div class="absolute -inset-20 bg-blue-500/15 blur-[120px] rounded-full opacity-60"></div>
                     <div class="relative rounded-[2rem] md:rounded-[3rem] overflow-hidden shadow-[0_40px_80px_-20px_rgba(0,0,0,0.8),0_0_100px_0_rgba(59,130,246,0.3)] border border-white/10 group bg-slate-900">
                        <img 
                          src="/images/dashboard-preview.webp" 
                          alt="Skily Dashboard" 
                          width="1200"
                          height="645"
                          fetchpriority="high"
                          loading="eager"
                          class="w-full h-auto object-cover group-hover:scale-[1.03] transition-transform duration-1000" 
                        />
                     </div>
                  </div>
               </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════ FEATURES (Zig-Zag) ══════════════════════════════════════ -->
    <section id="features" class="relative z-10 py-24 md:py-40">
      <div class="max-w-[1400px] mx-auto px-6">
        <!-- Features Header -->
        <div class="text-center mb-24 md:mb-40 reveal-on-scroll">
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-300 text-[10px] font-bold tracking-[0.2em] uppercase mb-8">
            ✦ Полная платформа
          </div>
          <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black text-white mb-6 leading-tight max-w-5xl mx-auto">
            Всё, что нужно для успеха,<br/><span class="text-slate-300">в одном месте</span>
          </h2>
          <p class="text-slate-400 text-base md:text-lg max-w-2xl mx-auto">Тысячи студентов уже готовятся к экзаменам со Skily — персонализированный ИИ, реальные дуэли и геймификация.</p>
        </div>

        <div class="space-y-32 md:space-y-64">

        <!-- 1. IA TUTOR (Text Left, Demo Right) -->
        <div class="grid lg:grid-cols-[1fr,1.3fr] gap-12 lg:gap-20 items-center reveal-on-scroll">
          <div class="order-2 lg:order-1">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-300 text-[10px] font-bold tracking-[0.2em] uppercase mb-6">
              🤖 Персональный ИИ-Тьютор
            </div>
            <h3 class="text-3xl sm:text-4xl font-black text-white mb-6 leading-tight">Твой личный наставник <br/><span class="text-blue-400">в кармане 24/7</span></h3>
            <p class="text-slate-400 text-lg mb-8 leading-relaxed">
