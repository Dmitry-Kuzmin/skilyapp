const steps = [
  {
    n: '01',
    title: 'Зарегистрируйся за 10 секунд',
    desc: 'Через Telegram или email — без заполнения форм и ожидания. Сразу доступ к 3 000+ вопросам.',
  },
  {
    n: '02',
    title: 'Учи с ИИ, не угадывай',
    desc: 'Ошибся — ИИ объясняет правило на русском. Не просто «ответ Б», а логика и контекст.',
  },
  {
    n: '03',
    title: 'Тренируйся в дуэлях',
    desc: 'Соревнуйся с живыми игроками — давление реального соперника учит лучше любого учебника.',
  },
  {
    n: '04',
    title: 'Сдавай экзамен DGT',
    desc: 'Симулятор точно воспроизводит реальный тест. Когда набираешь 27+/30 — ты готов.',
  },
];

const plans = [
  {
    name: 'Старт',
    price: 'Бесплатно',
    priceNote: 'навсегда',
    features: [
      'Тесты по всем темам',
      '10 вопросов ИИ в день',
