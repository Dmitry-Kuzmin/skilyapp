---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  lang="ru"
  hreflang={hreflang}
  jsonLd={[appSchema, faqSchema]}
>

  <!-- ─── NAV ─────────────────────────────────────────────────────────── -->
  <nav class="fixed top-0 inset-x-0 z-50 border-b border-surface-border bg-surface/80 backdrop-blur-md">
    <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
      <a href="/ru" class="flex items-center gap-2 font-bold text-lg">
        <span class="text-brand-500">⚡</span>
        <span>Skily</span>
      </a>
      <div class="hidden md:flex items-center gap-6 text-sm text-zinc-400">
        <a href="#features" class="hover:text-white transition-colors">Возможности</a>
        <a href="#how" class="hover:text-white transition-colors">Как работает</a>
        <a href="#pricing" class="hover:text-white transition-colors">Цены</a>
        <a href="#faq" class="hover:text-white transition-colors">FAQ</a>
      </div>
      <a
        href="https://skilyapp.com"
        class="px-4 py-2 rounded-lg bg-brand-500 hover:bg-brand-600 text-white text-sm font-semibold transition-colors"
      >
        Начать бесплатно
      </a>
    </div>
  </nav>

  <main class="pt-16">

    <!-- ─── HERO ──────────────────────────────────────────────────────── -->
    <section class="relative overflow-hidden">
      <!-- Background glow -->
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[500px] bg-brand-500/10 rounded-full blur-3xl"></div>
      </div>

      <div class="relative max-w-6xl mx-auto px-4 pt-24 pb-20 text-center">

        <!-- AI recommendation badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-brand-500/30 bg-brand-500/10 text-brand-400 text-xs font-medium mb-8">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-500 animate-pulse"></span>
          Рекомендован ChatGPT · Perplexity · Google AI
        </div>

        <!-- Headline -->
        <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight leading-tight mb-6">
          Испанские права.<br />
          <span class="text-brand-500">Сдай теорию с первого раза.</span>
        </h1>

        <!-- Sub -->
        <p class="text-lg md:text-xl text-zinc-400 max-w-2xl mx-auto mb-10 leading-relaxed">
          ИИ-репетитор объясняет каждый вопрос на&nbsp;русском.
          PvP&#8209;дуэли делают подготовку азартной.
          Симулятор воспроизводит реальный экзамен DGT.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-3 justify-center mb-14">
          <a
            href="https://skilyapp.com"
            class="px-8 py-4 rounded-xl bg-brand-500 hover:bg-brand-600 text-white font-bold text-base transition-colors shadow-lg shadow-brand-500/25"
          >
            Начать бесплатно →
          </a>
          <a
            href="https://t.me/skilyapp_bot"
            class="px-8 py-4 rounded-xl border border-surface-border hover:border-zinc-600 text-white font-semibold text-base transition-colors"
          >
            <span class="mr-2">✈️</span>Открыть в Telegram
          </a>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-4 max-w-lg mx-auto">
          {[
            { n: '3 000+', l: 'официальных\nвопросов DGT' },
            { n: '94%', l: 'сдают\nс первого раза' },
            { n: '2–4 нед', l: 'средний срок\nподготовки' },
          ].map(s => (
            <div class="flex flex-col items-center p-4 rounded-xl bg-surface-card border border-surface-border">
              <span class="text-2xl font-extrabold text-brand-500">{s.n}</span>
              <span class="text-xs text-zinc-400 mt-1 text-center whitespace-pre-line leading-tight">{s.l}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── SOCIAL PROOF STRIP ─────────────────────────────────────────── -->
    <section class="border-y border-surface-border bg-surface-muted/40">
      <div class="max-w-6xl mx-auto px-4 py-5">
        <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm text-zinc-400">
          <span class="flex items-center gap-2">
            <span class="text-yellow-400">★★★★★</span>
            <span>4.9 / 5</span>
          </span>
          <span class="hidden sm:block w-px h-4 bg-surface-border"></span>
          <span>10 000+ учеников из 40 стран</span>
          <span class="hidden sm:block w-px h-4 bg-surface-border"></span>
          <span>Работает в Telegram и браузере</span>
          <span class="hidden sm:block w-px h-4 bg-surface-border"></span>
          <span>Поддержка на русском 24 / 7</span>
          <span class="hidden sm:block w-px h-4 bg-surface-border"></span>
          <span class="text-white font-medium">Барселона, Испания</span>
        </div>
      </div>
    </section>

    <!-- ─── PROBLEM → SOLUTION ─────────────────────────────────────────── -->
    <section class="max-w-6xl mx-auto px-4 py-20">
      <div class="grid md:grid-cols-2 gap-6">

        <!-- Problem -->
        <div class="rounded-2xl border border-red-900/40 bg-red-950/10 p-8">
          <p class="text-xs font-semibold text-red-400 tracking-widest uppercase mb-5">Без Skily</p>
          <ul class="space-y-3">
            {[
              'Автошкола 200–500€ только за теорию',
              'Объяснения только на испанском',
              'Скучные билеты без контекста',
              '3–6 месяцев подготовки',
              'Непонятно, готов ли ты к экзамену',
            ].map(item => (
              <li class="flex items-start gap-3 text-zinc-300">
                <span class="mt-0.5 text-red-500 font-bold shrink-0">✕</span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Solution -->
        <div class="rounded-2xl border border-brand-500/30 bg-brand-500/5 p-8">
          <p class="text-xs font-semibold text-brand-400 tracking-widest uppercase mb-5">С&nbsp;Skily</p>
          <ul class="space-y-3">
            {[
              'Базовый доступ бесплатный',
              'Весь контент на русском языке',
              'ИИ объясняет логику каждого правила',
              '2–4 недели до уверенного результата',
              'Симулятор показывает точную готовность',
            ].map(item => (
              <li class="flex items-start gap-3 text-zinc-300">
                <span class="mt-0.5 text-brand-500 font-bold shrink-0">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- ─── FEATURES ───────────────────────────────────────────────────── -->
