  applicationCategory: 'EducationApplication',
  operatingSystem: 'Web, iOS, Android, Telegram',
  url: 'https://skilyapp.com',
  downloadUrl: 'https://t.me/skilyapp_bot',
  inLanguage: ['ru', 'es', 'en'],
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'EUR',
    description: 'Бесплатный базовый доступ. Премиум от 4.99€/месяц.',
  },
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.9',
    reviewCount: '10000',
    bestRating: '5',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Skily',
    url: 'https://skilyapp.com',
    email: 'hello@skily.ai',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Barcelona',
      addressCountry: 'ES',
    },
  },
  featureList: [
    'ИИ-репетитор на русском языке',
    'PvP-дуэли с реальными игроками',
    'Симулятор экзамена DGT',
    'Тесты по 17 темам',
    'Сезонный пасс с наградами',
    'Аудиорежим',
    'Персональный банк ошибок',
    'Телеграм Mini App',
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Сколько вопросов на теоретическом экзамене DGT?',
