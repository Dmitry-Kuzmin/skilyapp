---
import { marked } from "marked";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { Dgt2026ArticleContent } from "../../../components/Dgt2026ArticleContent";
import { articles, getArticle } from "../../../data/articles";
import { articleContentRu } from "../../../data/articleContentRu";

export function getStaticPaths() {
  return articles.map((a) => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const article = getArticle(slug!);
if (!article) return Astro.redirect("/blog");

const lang = "ru";
const loc = article[lang];
const BASE = "https://skilyapp.com";
const canonical = `${BASE}/ru/article/${article.slug}`;

const isFullReact = article.slug === "ekzamen-dgt-2026";
const markdownRaw = articleContentRu[article.slug] ?? null;

// Extract headings for TOC
const headings: { level: number; text: string; id: string }[] = [];
function slugify(text: string): string {
  return text.toLowerCase().replace(/[^\w\s-]/g, "").trim().replace(/\s+/g, "-");
}
if (markdownRaw) {
  for (const line of markdownRaw.split("\n")) {
    const m = line.match(/^(#{2,3}) (.+)/);
    if (m) {
      const level = m[1].length;
      const text = m[2].trim();
      headings.push({ level, text, id: slugify(text) });
    }
  }
}

// Render markdown and inject heading IDs
let articleHtml: string | null = null;
if (markdownRaw) {
  let h2i = 0, h3i = 0;
  const h2Heads = headings.filter(h => h.level === 2);
  const h3Heads = headings.filter(h => h.level === 3);
  articleHtml = (await marked.parse(markdownRaw, { gfm: true, breaks: false }))
    .replace(/<h2>/g, () => `<h2 id="${h2Heads[h2i++]?.id ?? ""}">`)
    .replace(/<h3>/g, () => `<h3 id="${h3Heads[h3i++]?.id ?? ""}">`);
}

const twitterShareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(loc.title)}&url=${encodeURIComponent(canonical)}`;

const jsonLd: object[] = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Skilyapp", item: `${BASE}/` },
      { "@type": "ListItem", position: 2, name: "Блог", item: `${BASE}/blog` },
      { "@type": "ListItem", position: 3, name: loc.title, item: canonical },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "Article",
    headline: loc.title,
    description: loc.description,
    url: canonical,
    datePublished: article.publishedAt,
    dateModified: article.publishedAt,
    author: { "@type": "Person", name: loc.author },
    publisher: {
      "@type": "Organization",
      name: "Skilyapp",
      url: BASE,
      logo: { "@type": "ImageObject", url: `${BASE}/og-ru.jpg` },
    },
    inLanguage: "ru-RU",
    keywords: article.keywords?.join(", "),
    mainEntityOfPage: { "@type": "WebPage", "@id": canonical },
  },
];

if (article.faqItems?.length) {
  jsonLd.push({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: article.faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: { "@type": "Answer", text: item.answer },
    })),
  });
}

if (article.howTo) {
  jsonLd.push({
    "@context": "https://schema.org",
    "@type": "HowTo",
    name: article.howTo.name,
    description: article.howTo.description,
    totalTime: article.howTo.totalTime,
    step: article.howTo.steps.map((s) => ({
      "@type": "HowToStep",
      name: s.name,
      text: s.text,
    })),
  });
}

const hreflang = [
  { lang: "ru", href: canonical },
  { lang: "es", href: `${BASE}/article/${article.slug}` },
  { lang: "en", href: `${BASE}/en/article/${article.slug}` },
];

const publishedDate = new Date(article.publishedAt).toLocaleDateString("ru-RU", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout
  title={`${loc.title} | Skilyapp Блог`}
  description={loc.description}
  canonical={canonical}
  lang="ru"
  jsonLd={jsonLd}
  hreflang={hreflang}
>
  <!-- Reading progress bar -->
  <div id="progress-bar" class="fixed top-0 left-0 h-0.5 bg-white z-50" style="width:0%"></div>

  <!-- Sticky article nav -->
  <header class="sticky top-0 z-40 bg-zinc-950/95 backdrop-blur-sm border-b border-zinc-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-14">
        <a href="/blog" class="text-sm text-zinc-400 hover:text-zinc-200 transition-colors">← Назад к блогу</a>
        <a href="/" class="text-sm text-zinc-400 hover:text-zinc-200 hidden sm:block transition-colors">Skilyapp</a>
      </div>
    </div>
  </header>

  <main class="min-h-screen bg-zinc-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-16">

      <!-- Breadcrumb -->
      <nav class="mb-8 flex items-center gap-1.5 text-sm text-zinc-500">
        <a href="/" class="hover:text-zinc-300 transition-colors">Skilyapp</a>
        <span>/</span>
        <a href="/blog" class="hover:text-zinc-300 transition-colors">Блог</a>
        <span>/</span>
        <span class="text-zinc-400 line-clamp-1">{loc.title}</span>
      </nav>

      <!-- Two-column grid -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">

        <!-- Main Content -->
        <article id="article-body" class="lg:col-span-8">

          <!-- Article header -->
          <div class="mb-8">
            <div class="mb-4">
              <span class="inline-block rounded-full border border-zinc-700 bg-zinc-900 px-3 py-1 text-xs font-medium text-zinc-400">
                {loc.category}
              </span>
            </div>
            <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 leading-tight tracking-tight">
              {loc.title}
            </h1>
            <p class="text-xl text-zinc-400 leading-relaxed mb-6">
              {loc.description}
            </p>
            <div class="flex items-center gap-3 border-t border-zinc-800 pt-5">
              <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-zinc-800 text-sm font-semibold text-white">
                {loc.author.charAt(0).toUpperCase()}
              </div>
              <div>
                <p class="text-sm font-medium text-zinc-300">{loc.author}</p>
                <p class="text-xs text-zinc-500">{publishedDate}</p>
              </div>
            </div>
          </div>

          <!-- Mobile: read time + share (hidden on lg) -->
          <div class="lg:hidden mb-8">
            <div class="flex items-center justify-between p-4 bg-zinc-900/50 rounded-xl border border-zinc-800">
              <div class="flex items-center gap-2 text-sm text-zinc-400">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>{article.readTime} мин чтения</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="text-sm text-zinc-500">Поделиться</span>
                <a
                  href={twitterShareUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex h-9 w-9 items-center justify-center rounded-lg text-zinc-400 hover:text-white hover:bg-zinc-800 transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.258 5.622 5.906-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
                <button
                  id="copy-link-mobile"
                  class="flex h-9 w-9 items-center justify-center rounded-lg text-zinc-400 hover:text-white hover:bg-zinc-800 transition-colors"
                  title="Скопировать ссылку"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                </button>
              </div>
            </div>
          </div>

          <div class="mb-10 h-px bg-zinc-800"></div>

          <!-- Article content -->
          {isFullReact ? (
            <Dgt2026ArticleContent lang="ru" client:only="react" />
          ) : articleHtml ? (
            <div class="article-prose" set:html={articleHtml} />
          ) : (
            <p class="text-zinc-400">{loc.excerpt}</p>
          )}

          <!-- Share section -->
          <div class="mt-12 pt-8 border-t border-zinc-800">
            <p class="text-sm font-medium text-zinc-300 mb-4">Поделиться статьёй</p>
            <div class="flex items-center gap-3">
              <a
                href={twitterShareUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 rounded-lg border border-zinc-700 px-4 py-2 text-sm text-zinc-300 hover:border-zinc-500 hover:text-white transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.258 5.622 5.906-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                Twitter
              </a>
              <button
                id="copy-link-bottom"
                class="flex items-center gap-2 rounded-lg border border-zinc-700 px-4 py-2 text-sm text-zinc-300 hover:border-zinc-500 hover:text-white transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                Скопировать ссылку
              </button>
            </div>
          </div>

          <!-- FAQ -->
          {article.faqItems?.length && (
            <section class="mt-14">
              <div class="mb-6 flex items-center gap-3">
                <div class="h-px flex-1 bg-zinc-800"></div>
                <span class="text-xs font-semibold uppercase tracking-widest text-zinc-500">Частые вопросы</span>
                <div class="h-px flex-1 bg-zinc-800"></div>
              </div>
              <div class="space-y-3">
                {article.faqItems.map((item) => (
                  <details class="group rounded-2xl border border-zinc-800 bg-zinc-900 px-5 py-4 transition-colors hover:border-zinc-700">
                    <summary class="flex cursor-pointer list-none items-start justify-between gap-3 font-medium text-white">
                      <span>{item.question}</span>
                      <span class="mt-0.5 shrink-0 text-zinc-500 transition-transform duration-200 group-open:rotate-45">+</span>
                    </summary>
                    <p class="mt-3 text-sm leading-relaxed text-zinc-400">{item.answer}</p>
                  </details>
                ))}
              </div>
            </section>
          )}

          <!-- CTA -->
          <div class="mt-14 overflow-hidden rounded-2xl border border-zinc-700 bg-gradient-to-br from-zinc-900 to-zinc-950 p-7 text-center">
            <div class="mb-1 text-2xl">🚀</div>
            <p class="mb-1.5 text-lg font-bold text-white">Готов к экзамену DGT?</p>
            <p class="mb-5 text-sm text-zinc-400">
              Более 15&thinsp;000 кандидатов уже готовятся с Skilyapp — адаптивные тесты, PvP-дуэли и ИИ-тьютор.
            </p>
            <a
              href="https://t.me/skilyapp_bot"
              class="inline-block rounded-xl bg-white px-7 py-3 text-sm font-semibold text-black transition-colors hover:bg-zinc-100"
            >
              Начать бесплатно в Telegram →
            </a>
            <p class="mt-3 text-xs text-zinc-600">Без карты · Первая неделя бесплатно</p>
          </div>

        </article>

        <!-- Right Sidebar -->
        <aside class="hidden lg:block lg:col-span-4">
          <div class="sticky top-20 space-y-6">

            <!-- Meta card: read time + share -->
            <div class="p-6 bg-zinc-900/50 rounded-xl border border-zinc-800">
              <div class="space-y-4">
                <div class="flex items-center gap-2 text-sm text-zinc-400">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  <span>{article.readTime} мин чтения</span>
                </div>
                <div class="pt-4 border-t border-zinc-800">
                  <p class="text-sm font-medium text-zinc-300 mb-3">Поделиться</p>
                  <div class="flex items-center gap-2">
                    <a
                      href={twitterShareUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex h-9 w-9 items-center justify-center rounded-lg text-zinc-400 hover:text-white hover:bg-zinc-800 transition-colors"
                      title="Поделиться в Twitter"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.258 5.622 5.906-5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    </a>
                    <button
                      id="copy-link-sidebar"
                      class="flex h-9 w-9 items-center justify-center rounded-lg text-zinc-400 hover:text-white hover:bg-zinc-800 transition-colors"
                      title="Скопировать ссылку"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                    </button>
                  </div>
                </div>
              </div>
            </div>

            <!-- Table of Contents -->
            {headings.length > 0 && (
              <div class="p-6 bg-zinc-900/50 rounded-xl border border-zinc-800">
                <p class="text-sm font-semibold text-white mb-4">Содержание</p>
                <nav class="space-y-2">
                  {headings.map((h) => (
                    <a
                      href={`#${h.id}`}
                      class={h.level === 3
                        ? "block text-sm ml-4 text-zinc-500 hover:text-zinc-200 transition-colors"
                        : "block text-sm text-zinc-400 font-medium hover:text-zinc-200 transition-colors"}
                    >
                      {h.text}
                    </a>
                  ))}
                </nav>
              </div>
            )}

          </div>
        </aside>

      </div>
    </div>
  </main>

  <!-- Progress bar -->
  <script>
    const bar = document.getElementById('progress-bar');
    const body = document.getElementById('article-body');
    if (bar && body) {
      window.addEventListener('scroll', () => {
        const { top, height } = body.getBoundingClientRect();
        const pct = Math.min(100, Math.max(0, (-top / height) * 100));
        bar.style.width = pct + '%';
      }, { passive: true });
    }

    function copyLink(btnId: string) {
      const btn = document.getElementById(btnId);
      if (!btn) return;
      navigator.clipboard.writeText(window.location.href).then(() => {
        const prev = btn.innerHTML;
        btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
        setTimeout(() => { btn.innerHTML = prev; }, 1500);
      });
    }

    document.getElementById('copy-link-sidebar')?.addEventListener('click', () => copyLink('copy-link-sidebar'));
    document.getElementById('copy-link-mobile')?.addEventListener('click', () => copyLink('copy-link-mobile'));
    document.getElementById('copy-link-bottom')?.addEventListener('click', () => {
      const btn = document.getElementById('copy-link-bottom');
      if (!btn) return;
      navigator.clipboard.writeText(window.location.href).then(() => {
        const prev = btn.textContent ?? '';
        btn.textContent = '✓ Ссылка скопирована';
        setTimeout(() => { btn.textContent = prev; }, 1500);
      });
    });
  </script>

  <!-- Article prose styles -->
  <style is:global>
    .article-prose h1 { @apply text-3xl font-bold text-white mt-10 mb-4 scroll-mt-20; }
    .article-prose h2 { @apply text-2xl font-bold text-white mt-10 mb-3 pb-2 border-b border-zinc-800 scroll-mt-20; }
    .article-prose h3 { @apply text-xl font-semibold text-white mt-7 mb-2 scroll-mt-20; }
    .article-prose h4 { @apply text-base font-semibold text-zinc-200 mt-5 mb-1.5; }
    .article-prose p  { @apply text-zinc-300 leading-relaxed mb-4; }
    .article-prose strong { @apply font-semibold text-white; }
    .article-prose em { @apply text-zinc-200 italic; }
    .article-prose a  { @apply text-white underline underline-offset-2 decoration-zinc-600 hover:decoration-zinc-400 transition-colors; }

    .article-prose ul { @apply my-4 space-y-1.5 text-zinc-300 list-disc list-inside ml-4; }
    .article-prose ol { @apply my-4 space-y-1.5 text-zinc-300 list-decimal list-inside ml-4; }
    .article-prose li { @apply text-zinc-300; }

    .article-prose blockquote {
      @apply border-l-2 border-zinc-600 bg-zinc-900 px-4 py-3 rounded-r-xl my-5 text-zinc-300 text-sm;
    }
    .article-prose blockquote p { @apply mb-0; }

    .article-prose hr { @apply my-8 border-zinc-800; }

    .article-prose code {
      @apply bg-zinc-800 text-zinc-200 text-sm px-1.5 py-0.5 rounded font-mono;
    }
    .article-prose pre {
      @apply bg-zinc-900 border border-zinc-800 rounded-xl p-4 overflow-x-auto my-5;
    }
    .article-prose pre code { @apply bg-transparent p-0 text-zinc-200; }

    .article-prose table { @apply w-full my-6 text-sm border-collapse rounded-xl overflow-hidden shadow-sm; }
    .article-prose table thead { @apply bg-zinc-900 border-b border-zinc-700; }
    .article-prose table thead th {
      @apply text-left px-4 py-3 text-xs font-semibold uppercase tracking-wide text-zinc-400 border border-zinc-800;
    }
    .article-prose table tbody tr { @apply border-b border-zinc-800 even:bg-zinc-900/30; }
    .article-prose table tbody tr:hover { @apply bg-zinc-900/50; }
    .article-prose table tbody td { @apply px-4 py-3 text-zinc-300 border border-zinc-800; }

    .article-prose :is(h2, h3, h4) + p { @apply mt-0; }
  </style>
</BaseLayout>
