{
  "name": "sdadim-dgt-prep",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "./optimize-system.sh && concurrently \"npm run dev:frontend\" \"npm run validator\" \"./scripts/maintenance-service.sh\" --names \"APP,API,MAINT\" --prefix-colors \"cyan,magenta,yellow\"",
    "panic-clean": "./scripts/cleanup-and-optimize.sh",
    "dev:frontend": "NODE_OPTIONS='--max-old-space-size=1536' vite",
    "dev:tunnel": "./scripts/start-dev-with-tunnel.sh",
    "prebuild": "node scripts/update-version.js",
    "build": "tsc && vite build",
    "build:prerender": "npm run build && npm run prerender",
    "prerender": "node scripts/prerender.js",
    "deploy:prebuilt": "./scripts/deploy-prebuilt.sh",
    "build:analyze": "ANALYZE=true tsc && ANALYZE=true vite build",
    "deploy:prod": "npm run build && npm run prerender && vercel deploy dist --prod --yes",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "validator": "node --expose-gc --max-old-space-size=1536 validator-server.js",
    "supabase:setup": "node scripts/setup-supabase.js",
    "supabase:apply-migrations": "node scripts/apply-migrations.js",
    "supabase:apply": "node scripts/apply-migration-auto-v2.js",
    "supabase:deploy": "node scripts/deploy-function.js",
    "supabase:deploy:duel-manager": "node scripts/deploy-function.js duel-manager",
    "supabase:deploy:apply-sql": "node scripts/deploy-function.js apply-sql",
    "telegram:setup": "node scripts/setup-telegram-webhook.js",
    "telegram:info": "node scripts/setup-telegram-webhook.js '' --info",
    "telegram:delete": "node scripts/setup-telegram-webhook.js '' --delete",
    "dev:telegram": "./scripts/dev-telegram.sh",
    "tunnel:start": "./scripts/start-cloudflare-tunnel.sh",
    "tunnel:start:lt": "./scripts/start-localtunnel.sh",
    "tunnel:start:save": "./scripts/start-tunnel-with-persistent-url.sh",
    "tunnel:url": "./scripts/get-tunnel-url.sh",
    "tunnel:set-url": "node scripts/set-telegram-webapp-url.js",
    "materials:manifest": "node scripts/generate-materials-manifest.cjs",
    "import:pdd-russia": "node scripts/import-pdd-russia.js",
    "check:pdd-migrations": "node scripts/check-pdd-russia-migrations.js",
    "check:pdd-duplicates": "node scripts/check-pdd-duplicates.js check",
    "clean:pdd-duplicates": "node scripts/check-pdd-duplicates.js clean --confirm",
    "check:pdd-images": "node scripts/check-pdd-images.js",
    "reupload:pdd-images": "node scripts/reupload-pdd-images.js",
    "find:pdd-missing": "node scripts/find-missing-questions.js",
    "import:pdd-missing": "node scripts/find-and-import-missing-questions.js",
    "generate:images": "node --expose-gc --max-old-space-size=2048 scripts/generate-images-batch.js",
    "generate:images:test": "node scripts/generate-images-batch.js --dry-run",
    "sync:test": "node scripts/test-sync-one.js",
    "backup:db": "node scripts/backup-db.js",
    "sync:all": "node scripts/sync-all-to-db.js"
