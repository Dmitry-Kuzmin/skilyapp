---
/**
 * CostsCalculator.astro
 * Интерактивный калькулятор стоимости прав в Испании — чистый Vanilla JS, 0 КБ библиотек.
 */
---

<div class="bg-zinc-900/50 border border-zinc-800 rounded-2xl p-6 md:p-8 my-10 shadow-2xl relative overflow-hidden" id="calculator-root">
  <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-emerald-500 to-blue-500"></div>

  <div class="text-center mb-8">
    <h3 class="text-2xl font-black text-white flex items-center justify-center gap-2">
      <svg class="w-6 h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      Интерактивный Калькулятор 2026
    </h3>
    <p class="text-sm text-zinc-400 mt-2">Посчитайте свои реальные расходы с учетом пересдач и пошлин</p>
  </div>

  <div class="grid lg:grid-cols-2 gap-10">
    <div class="space-y-6">
      <div class="space-y-4 bg-black/20 p-5 rounded-xl border border-white/5">
        <div>
          <div class="flex justify-between mb-2">
            <label class="text-sm font-semibold text-zinc-300">Уроки практики (по 45 мин)</label>
            <span class="text-sm font-bold text-emerald-400" id="classes-val">20 уроков</span>
          </div>
          <input
            type="range" min="10" max="60" value="20"
            id="input-classes"
            class="w-full accent-emerald-500 h-2 bg-zinc-800 rounded-lg appearance-none cursor-pointer"
          />
          <p class="text-xs text-zinc-500 mt-2">Среднему водителю с нуля требуется 30–40 занятий.</p>
        </div>

        <div class="pt-4 border-t border-zinc-800">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-semibold text-zinc-300">Попытки Теории</p>
              <p class="text-xs text-zinc-500">Экзамен DGT</p>
            </div>
            <div class="flex gap-2" id="theory-buttons">
              {[1, 2, 3, 4].map(num => (
                <button type="button" data-val={num} class={`w-10 h-10 rounded-lg text-sm font-bold transition-all ${num === 1 ? 'bg-amber-500 text-black' : 'bg-zinc-800 text-white hover:bg-zinc-700'}`}>
                  {num}
                </button>
              ))}
            </div>
          </div>
        </div>

        <div class="pt-4 border-t border-zinc-800">
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-semibold text-zinc-300">Попытки Практики</p>
              <p class="text-xs text-zinc-500">Город / Автодром</p>
            </div>
            <div class="flex gap-2" id="practical-buttons">
              {[1, 2, 3, 4].map(num => (
                <button type="button" data-val={num} class={`w-10 h-10 rounded-lg text-sm font-bold transition-all ${num === 1 ? 'bg-amber-500 text-black' : 'bg-zinc-800 text-white hover:bg-zinc-700'}`}>
                  {num}
                </button>
              ))}
            </div>
          </div>
        </div>

        <div id="tasa-warning" class="text-xs text-red-400 bg-red-400/10 p-3 rounded-lg border border-red-400/20 hidden">
          ⚠️ Вы исчерпали лимит из 3 попыток на пошлину. Придется оплатить Tasa 2.1 заново (+94.05€).
        </div>
      </div>
    </div>

    <div class="space-y-4">
      <div class="bg-emerald-500/10 border border-emerald-500/30 rounded-xl p-5 relative">
        <div class="absolute top-3 right-3 text-[10px] font-bold tracking-widest uppercase bg-emerald-500 text-black px-2 py-0.5 rounded-full">Выбор Sdadim</div>
        <p class="text-sm text-zinc-400 mb-1">Обучение с нами</p>
        <p class="text-4xl font-black text-white"><span id="sdadim-total">839.00</span> €</p>
        <div class="mt-4 space-y-2 text-xs text-zinc-400">
          <div class="flex justify-between"><span>Курс (Sdadim)</span> <span>199.00 €</span></div>
          <div class="flex justify-between text-emerald-400"><span>Матрикула</span> <span>0.00 € (Нет)</span></div>
          <div class="flex justify-between text-emerald-400"><span>Практика (<span id="sdadim-classes-count">17</span> уроков)</span> <span><span id="sdadim-classes-cost">561</span> € (-3 беспл.)</span></div>
          <div class="flex justify-between"><span>Услуги автошколы (Записи)</span> <span><span id="total-tramitacion">70</span> €</span></div>
          <div class="flex justify-between"><span>Аренда авто (Экзамены)</span> <span><span id="total-car-rent">45</span> €</span></div>
          <div class="flex justify-between text-yellow-400 font-bold border-t border-zinc-800 pt-2"><span>Tasa DGT 2.1</span> <span><span id="total-tasa">94.05</span> €</span></div>
        </div>
      </div>

      <div class="bg-zinc-900 border border-zinc-800 rounded-xl p-5">
        <p class="text-sm text-zinc-500 mb-1">Обычная автошкола (В среднем)</p>
        <p class="text-3xl font-black text-zinc-300"><span id="classic-total">1209.00</span> €</p>
        <div class="mt-4 space-y-2 text-xs text-zinc-500">
          <div class="flex justify-between"><span>Теоретический блок</span> <span>250.00 €</span></div>
          <div class="flex justify-between text-red-400"><span>Матрикула (Зачисление)</span> <span>150.00 €</span></div>
          <div class="flex justify-between"><span>Практика (<span id="classic-classes-count">20</span> уроков)</span> <span><span id="classic-classes-cost">660</span> €</span></div>
          <div class="flex justify-between"><span>Остальные сборы и DGT</span> <span><span id="classic-others">209.05</span> €</span></div>
        </div>
      </div>

      <div class="text-sm font-bold text-center text-emerald-400 pt-2">
        Ваша экономия: <span id="saving-total">370.00</span> €
      </div>
    </div>
  </div>
</div>

<script is:inline>
  function initCalculator() {
    const root = document.getElementById('calculator-root');
    if (!root) return;

    const state = { practicalClasses: 20, theoryAttempts: 1, practicalAttempts: 1 };

    const C = {
      TASA_DGT: 94.05,
      CLASSIC_MATRICULA: 150,
      SDADIM_COURSE: 199,
      CLASSIC_THEORY: 250,
      COST_PER_CLASS: 33,
      EXAM_CAR_RENT: 45,
      TRAMITACION: 35,
    };

    function updateUI() {
      const { practicalClasses, theoryAttempts, practicalAttempts } = state;
      const totalAttempts = theoryAttempts + practicalAttempts;
      const extraTasas = Math.floor((totalAttempts - 1) / 3);
      const totalTasa = (1 + extraTasas) * C.TASA_DGT;
      const totalTramitacion = (theoryAttempts + practicalAttempts) * C.TRAMITACION;
      const totalCarRent = practicalAttempts * C.EXAM_CAR_RENT;
      const sdadimClassesPay = Math.max(0, practicalClasses - 3);

      const sdadimTotal = C.SDADIM_COURSE + totalTasa + totalCarRent + totalTramitacion + sdadimClassesPay * C.COST_PER_CLASS;
      const classicTotal = C.CLASSIC_MATRICULA + C.CLASSIC_THEORY + totalTasa + totalCarRent + totalTramitacion + practicalClasses * C.COST_PER_CLASS;

      document.getElementById('classes-val').textContent = `${practicalClasses} уроков`;
      document.getElementById('sdadim-total').textContent = sdadimTotal.toFixed(2);
      document.getElementById('classic-total').textContent = classicTotal.toFixed(2);
      document.getElementById('saving-total').textContent = (classicTotal - sdadimTotal).toFixed(2);
      document.getElementById('sdadim-classes-count').textContent = sdadimClassesPay;
      document.getElementById('sdadim-classes-cost').textContent = (sdadimClassesPay * C.COST_PER_CLASS).toFixed(0);
      document.getElementById('total-tramitacion').textContent = totalTramitacion.toFixed(0);
      document.getElementById('total-car-rent').textContent = totalCarRent.toFixed(0);
      document.getElementById('total-tasa').textContent = totalTasa.toFixed(2);
      document.getElementById('classic-classes-count').textContent = practicalClasses;
      document.getElementById('classic-classes-cost').textContent = (practicalClasses * C.COST_PER_CLASS).toFixed(0);
      document.getElementById('classic-others').textContent = (totalTramitacion + totalCarRent + totalTasa).toFixed(2);

      const warning = document.getElementById('tasa-warning');
      extraTasas > 0 ? warning.classList.remove('hidden') : warning.classList.add('hidden');
    }

    root.querySelector('#input-classes').addEventListener('input', (e) => {
      state.practicalClasses = parseInt(e.target.value);
      updateUI();
    });

    function setupButtons(containerId, stateKey) {
      const container = document.getElementById(containerId);
      const buttons = container.querySelectorAll('button');
      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          state[stateKey] = parseInt(btn.dataset.val);
          buttons.forEach(b => {
            b.classList.remove('bg-amber-500', 'text-black');
            b.classList.add('bg-zinc-800', 'text-white');
          });
          btn.classList.add('bg-amber-500', 'text-black');
          btn.classList.remove('bg-zinc-800', 'text-white');
          updateUI();
        });
      });
    }

    setupButtons('theory-buttons', 'theoryAttempts');
    setupButtons('practical-buttons', 'practicalAttempts');
    updateUI();
  }

  initCalculator();
  document.addEventListener('astro:after-swap', initCalculator);
</script>
