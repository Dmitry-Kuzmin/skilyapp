---
const currentPath = Astro.url.pathname;

const NAV_LINKS = [
  { href: '/', label: 'Курс' },
  { href: '/blog', label: 'Блог' },
  { href: '/legal/terms', label: 'Документы' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 bg-[#050B14]/80 backdrop-blur-xl">
  <div class="max-w-7xl mx-auto px-4 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 hover:opacity-90 transition-opacity">
      <img src="/favicon-s.svg" alt="Sdadim" class="w-8 h-8 rounded-[22%] shadow-lg shadow-blue-500/20" />
      <div class="flex flex-col">
        <span class="text-xl font-bold tracking-tight text-white/90 leading-none">Sdadim</span>
        <span class="text-[9px] text-zinc-400 font-bold tracking-[0.1em] leading-tight uppercase mt-0.5">by Skilyapp</span>
      </div>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-6">
      {NAV_LINKS.map(({ href, label }) => (
        <a
          href={href}
          class={`text-sm font-medium transition-colors ${currentPath === href ? 'text-white' : 'text-zinc-400 hover:text-white'}`}
        >
          {label}
        </a>
      ))}
      <a
        href="https://t.me/skilyapp_bot?start=course"
        target="_blank"
        rel="noopener noreferrer"
        class="px-4 py-2 rounded-xl bg-blue-600 hover:bg-blue-500 text-white text-sm font-semibold transition-colors"
      >
        Занять место →
      </a>
    </nav>

    <!-- Mobile burger -->
    <button
      id="mobile-menu-toggle"
      class="md:hidden p-2 text-zinc-400 hover:text-white transition-colors"
      aria-label="Меню"
    >
      <svg id="icon-menu" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-white/5 bg-[#050B14] px-4 py-4 flex flex-col gap-4">
    {NAV_LINKS.map(({ href, label }) => (
      <a href={href} class="text-sm font-medium text-zinc-300 hover:text-white transition-colors">
        {label}
      </a>
    ))}
    <a
      href="https://t.me/skilyapp_bot?start=course"
      target="_blank"
      rel="noopener noreferrer"
      class="px-4 py-3 rounded-xl bg-blue-600 text-white text-sm font-semibold text-center"
    >
      Занять место →
    </a>
  </div>
</header>

<script is:inline>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    iconMenu.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
  });
</script>
