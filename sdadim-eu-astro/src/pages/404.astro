---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Страница не найдена | Sdadim"
  description="Эта страница не существует. Вернитесь на главную или в блог."
  canonical="https://sdadim.eu/404"
>
  <Header />

  <div class="min-h-screen bg-[#050B14] flex items-center justify-center px-4">
    <div class="text-center max-w-md">
      <p class="text-8xl font-black text-white/5 mb-4 leading-none select-none">404</p>
      <h1 class="text-3xl font-black text-white mb-3">Страница не найдена</h1>
      <p class="text-zinc-500 mb-8 leading-relaxed">
        Возможно, адрес изменился или страница была удалена.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="px-6 py-3 rounded-xl bg-blue-600 hover:bg-blue-500 text-white font-semibold text-sm transition-colors">
          На главную
        </a>
        <a href="/blog" class="px-6 py-3 rounded-xl bg-white/5 hover:bg-white/10 border border-white/10 text-white font-semibold text-sm transition-colors">
          В блог
        </a>
      </div>
    </div>
  </div>

  <Footer />
</BaseLayout>
