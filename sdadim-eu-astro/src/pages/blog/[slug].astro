---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CostsCalculator from '../../components/CostsCalculator.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const isCostsPage = post.slug === 'tseny-na-prava';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: post.data.author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Sdadim',
    url: 'https://sdadim.eu',
    logo: 'https://sdadim.eu/favicon-s.svg',
  },
  image: post.data.ogImage ?? 'https://sdadim.eu/og-image.jpg',
  url: post.data.canonical,
  inLanguage: 'ru',
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': post.data.canonical,
  },
};
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonical={post.data.canonical}
  ogImage={post.data.ogImage}
  jsonLd={jsonLd}
>
  <Header />

  <div class="min-h-screen bg-[#050B14]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-20">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-14">

        <main class="lg:col-span-8">
          <a href="/blog" class="inline-flex items-center gap-1.5 text-sm text-zinc-500 hover:text-white transition-colors mb-8">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Все статьи
          </a>

          <div class="mb-8">
            {post.data.tags?.[0] && (
              <span class="inline-block text-[10px] uppercase tracking-widest font-bold text-blue-400 bg-blue-500/10 px-2.5 py-1 rounded-full mb-4">
                {post.data.tags[0]}
              </span>
            )}
            <h1 class="text-3xl md:text-4xl lg:text-5xl font-black text-white leading-tight tracking-tight mb-5">
              {post.data.title}
            </h1>
            <p class="text-lg text-zinc-400 leading-relaxed mb-5">
              {post.data.description}
            </p>
            <div class="flex flex-wrap items-center gap-4 text-sm text-zinc-600">
              <span class="flex items-center gap-1.5">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                {post.data.pubDate.toLocaleDateString('ru-RU', { year: 'numeric', month: 'long', day: 'numeric' })}
              </span>
              {post.data.readingTime && (
                <span class="flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                  {post.data.readingTime} мин чтения
                </span>
              )}
            </div>
          </div>

          <div class="prose prose-invert prose-zinc max-w-none
            prose-headings:font-black prose-headings:tracking-tight
            prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4 prose-h2:pb-3 prose-h2:border-b prose-h2:border-white/5
            prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
            prose-p:text-zinc-300 prose-p:leading-[1.85] prose-p:text-[15px]
            prose-strong:text-white
          ">
            <Content />
            
            {isCostsPage && <CostsCalculator />}
          </div>
        </main>

        <aside class="hidden lg:block lg:col-span-4">
          <div class="sticky top-24 space-y-5">
            <div class="rounded-xl border border-white/5 bg-white/[0.03] p-5">
              <p class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-3">Готовьтесь к DGT</p>
              <p class="text-sm text-zinc-300 mb-4">Тренируйте официальные вопросы DGT с персональным ИИ-тьютором.</p>
              <a
                href="https://t.me/skilyapp_bot?start=course"
                target="_blank"
                rel="noopener noreferrer"
                class="block w-full py-2.5 rounded-xl bg-blue-600 hover:bg-blue-500 text-white text-sm font-semibold text-center transition-colors"
              >
                Начать бесплатно →
              </a>
            </div>
          </div>
        </aside>

      </div>
    </div>
  </div>

  <Footer />
</BaseLayout>
