---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const CATEGORIES = [
  'Практика DGT',
  'Истории сдачи',
  'Подготовка к DGT',
  'Финансы',
  'Закон и Штрафы',
  'Полезно',
];
---

<BaseLayout
  title="Блог о правах в Испании | Сдадим"
  description="Полезные статьи о получении прав в Испании для русскоязычных: гайды, советы, разбор экзамена DGT."
  canonical="https://sdadim.eu/blog"
>
  <Header />

  <div class="min-h-screen bg-[#050B14]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-20">
      <div class="grid grid-cols-1 lg:grid-cols-4 xl:grid-cols-5 gap-6 lg:gap-10">

        <!-- Sidebar -->
        <aside class="lg:col-span-1">
          <div class="sticky top-24 space-y-8">
            <div>
              <h1 class="text-2xl font-black text-white mb-1.5">Блог</h1>
              <p class="text-sm text-zinc-500 leading-relaxed">Инструкции и советы о правах в Испании</p>
            </div>

            <nav class="space-y-0.5">
              <a href="/blog" class="w-full text-left px-3 py-2 rounded-lg text-sm font-medium flex items-center justify-between gap-3 bg-blue-500/10 text-blue-300 border-l-2 border-blue-500">
                <span>Все статьи</span>
                <span class="text-xs px-2 py-0.5 rounded-full tabular-nums bg-blue-500/15 text-blue-400">{posts.length}</span>
              </a>
              {CATEGORIES.map((cat) => {
                const count = posts.filter(p => p.data.tags?.includes(cat) || p.slug.includes(cat.toLowerCase())).length;
                return (
                  <a href={`/blog?cat=${encodeURIComponent(cat)}`} class="w-full text-left px-3 py-2 rounded-lg text-sm font-medium flex items-center justify-between gap-3 text-zinc-400 hover:bg-white/5 hover:text-white border-l-2 border-transparent transition-all">
                    <span>{cat}</span>
                  </a>
                );
              })}
            </nav>

            <div class="rounded-xl border border-blue-500/20 bg-blue-500/5 p-4">
              <p class="text-white font-semibold text-sm mb-1">Готовиться к DGT?</p>
              <p class="text-zinc-400 text-xs leading-relaxed mb-3">Тренируйте тесты с полной базой вопросов DGT в SkilyApp.</p>
              <a href="https://t.me/skilyapp_bot" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-xs font-semibold text-blue-400 hover:text-blue-300 transition-colors">
                Попробовать бесплатно →
              </a>
            </div>
          </div>
        </aside>

        <!-- Main -->
        <main class="lg:col-span-3 xl:col-span-4">
          <!-- Search (client-side, progressive enhancement) -->
          <div class="relative mb-8">
            <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-zinc-500 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
            </svg>
            <input
              id="blog-search"
              type="search"
              placeholder="Поиск статей..."
              class="w-full pl-10 pr-4 py-2.5 rounded-xl bg-white/[0.04] border border-white/[0.08] text-white placeholder-zinc-500 text-sm focus:outline-none focus:border-blue-500/50 transition-all"
            />
          </div>

          <!-- Articles grid -->
          <div id="articles-grid" class="grid grid-cols-1 md:grid-cols-2 gap-5">
            {sortedPosts.map((post) => (
              <article
                class="group flex flex-col rounded-2xl bg-[#0c1523] hover:bg-[#0f1a2b] transition-all duration-300 overflow-hidden"
                data-title={post.data.title.toLowerCase()}
                data-excerpt={post.data.description.toLowerCase()}
              >
                <a href={`/blog/${post.slug}`} class="flex flex-col flex-1">
                  {post.data.ogImage ? (
                    <div class="h-44 overflow-hidden">
                      <img src={post.data.ogImage} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                    </div>
                  ) : (
                    <div class="h-44 bg-gradient-to-br from-blue-600/8 to-cyan-600/4 flex items-center justify-center">
                      <svg class="w-10 h-10 text-blue-500/20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                  )}

                  <div class="flex flex-col flex-1 p-6">
                    <div class="flex items-center gap-2.5 mb-3">
                      <span class="text-[10px] uppercase tracking-widest font-bold text-blue-400 bg-blue-500/10 px-2 py-0.5 rounded-full">
                        {post.data.tags?.[0] ?? 'Статья'}
                      </span>
                      {post.data.readingTime && (
                        <span class="flex items-center gap-1 text-[11px] text-zinc-600">
                          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                          {post.data.readingTime} мин
                        </span>
                      )}
                    </div>

                    <h2 class="font-bold text-white text-[17px] leading-snug mb-3 group-hover:text-blue-300 transition-colors line-clamp-2">
                      {post.data.title}
                    </h2>

                    <p class="text-zinc-500 text-[13px] leading-relaxed flex-1 line-clamp-3">
                      {post.data.description}
                    </p>

                    <div class="flex items-center justify-between mt-5 pt-4 border-t border-white/5">
                      <div class="flex items-center gap-1.5 text-[11px] text-zinc-600">
                        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        {post.data.pubDate.toLocaleDateString('ru-RU', { year: 'numeric', month: 'long', day: 'numeric' })}
                      </div>
                      <span class="text-[12px] text-zinc-500 group-hover:text-blue-400 transition-colors font-medium">
                        Читать →
                      </span>
                    </div>
                  </div>
                </a>
              </article>
            ))}
          </div>

          <div class="mt-12 rounded-2xl border border-blue-500/20 bg-gradient-to-br from-blue-600/10 to-cyan-600/5 p-8 text-center">
            <p class="text-white font-black text-xl mb-2">Готовы сдать теорию DGT?</p>
            <p class="text-zinc-400 text-sm mb-6 max-w-md mx-auto">Присоединяйтесь к курсу с живыми уроками или тренируйтесь самостоятельно в SkilyApp.</p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <a href="https://t.me/skilyapp_bot?start=course" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl bg-blue-600 hover:bg-blue-500 text-white font-semibold text-sm transition-colors">
                Записаться на курс →
              </a>
              <a href="https://t.me/skilyapp_bot" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-xl bg-white/5 hover:bg-white/10 border border-white/10 text-white font-semibold text-sm transition-colors">
                Тренировать тесты бесплатно
              </a>
            </div>
          </div>
        </main>
      </div>
    </div>
  </div>

  <Footer />
</BaseLayout>

<script is:inline>
  const search = document.getElementById('blog-search');
  const articles = document.querySelectorAll('#articles-grid article');

  search?.addEventListener('input', (e) => {
    const q = e.target.value.toLowerCase().trim();
    articles.forEach((art) => {
      const title = art.dataset.title || '';
      const excerpt = art.dataset.excerpt || '';
      art.style.display = (!q || title.includes(q) || excerpt.includes(q)) ? '' : 'none';
    });
  });
</script>
