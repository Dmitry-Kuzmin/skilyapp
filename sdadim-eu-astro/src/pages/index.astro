---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CinematicHero } from '../components/ui/CinematicHero';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const latestPosts = posts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const year = new Date().getFullYear();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: 'Онлайн-курс подготовки к теоретическому экзамену DGT в Испании',
  description: 'Живой онлайн-курс на русском языке: 16 000+ вопросов DGT, куратор, помощь с документами. 9 из 10 студентов сдают с первой попытки.',
  url: 'https://sdadim.eu/',
  provider: { '@type': 'Organization', name: 'Сдадим', url: 'https://sdadim.eu' },
  inLanguage: 'ru',
  courseMode: 'online',
  offers: {
    '@type': 'Offer',
    priceCurrency: 'EUR',
    price: '199',
    availability: 'https://schema.org/InStock',
  },
};
---

<BaseLayout
  title={`Sdadim — права в Испании с первого раза | Теория DGT на русском ${year}`}
  description="Онлайн-курс подготовки к теоретическому экзамену DGT на русском языке. Объясняем логику ПДД, помогаем с Cita и Tasa. 9 из 10 сдают с первой попытки."
  canonical="https://sdadim.eu/"
  jsonLd={jsonLd}
>
  {/* Hero — React остров с Framer Motion PulseBeams анимацией */}
  <CinematicHero
    ctaHeading="Права в Испании — с первого раза"
    ctaDescription="Объясняем логику ПДД, а не заставляем зубрить. 16 000 вопросов, живые уроки, поддержка с Cita и Tasa — всё в одном курсе."
    client:load
  />

  {/* ─── Доверие: 3 цифры ──────────────────────────────── */}
  <section class="py-16 px-4 bg-[#060a14]">
    <div class="max-w-4xl mx-auto grid grid-cols-3 gap-6 text-center">
      {[
        { val: '9/10', label: 'сдают с первой попытки' },
        { val: '16 000+', label: 'вопросов в базе DGT' },
        { val: '100%', label: 'онлайн-формат' },
      ].map(({ val, label }) => (
        <div class="p-5 rounded-2xl bg-white/[0.03] border border-white/[0.06]">
          <div class="text-3xl md:text-4xl font-black text-white mb-1">{val}</div>
          <div class="text-xs text-zinc-500 font-medium uppercase tracking-wider">{label}</div>
        </div>
      ))}
    </div>
  </section>

  {/* ─── Боли ──────────────────────────────────────────── */}
  <section class="py-24 px-4 bg-[#060a14]">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <span class="inline-block text-[10px] uppercase tracking-widest font-bold text-red-400 bg-red-500/10 px-3 py-1.5 rounded-full mb-4">С чем вы столкнётесь</span>
        <h2 class="text-3xl md:text-5xl font-black text-white tracking-tight">Почему это так сложно?</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          { icon: '🌐', title: 'Экзамен — на испанском', desc: 'Вопросы DGT переполнены юридической лексикой. Гугл-переводчик не поможет — нужно понимать логику, а не слова.' },
          { icon: '📚', title: '16 000 вопросов с ловушками', desc: 'Официальная база DGT — 30 вопросов на экзамене, максимум 3 ошибки. Без системы подготовки шансы 50/50.' },
          { icon: '📋', title: 'Бюрократия с нуля', desc: 'Cita Previa, Tasa DGT, психотехнический тест, TIE — каждый шаг может застопорить, если не знать порядок.' },
        ].map(({ icon, title, desc }) => (
          <div class="p-7 rounded-2xl bg-white/[0.02] border border-white/[0.06] hover:border-red-500/20 transition-colors">
            <div class="text-3xl mb-4">{icon}</div>
            <h3 class="text-lg font-black text-white mb-2">{title}</h3>
            <p class="text-zinc-500 text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ─── Наши преимущества ─────────────────────────────── */}
  <section class="py-24 px-4 bg-[#060a14]">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <span class="inline-block text-[10px] uppercase tracking-widest font-bold text-emerald-400 bg-emerald-500/10 px-3 py-1.5 rounded-full mb-4">Как мы решаем</span>
        <h2 class="text-3xl md:text-5xl font-black text-white tracking-tight">Почему Sdadim?</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {[
          { icon: '🧠', title: 'Объясняем логику', desc: 'Преподаватели разбирают каждую тему на русском — вы понимаете правила, а не запоминаете ответы.' },
          { icon: '⏰', title: 'Готовьтесь в своём ритме', desc: 'Живые уроки 2 раза в неделю + записи навсегда. Работаете посменно — не проблема.' },
          { icon: '📑', title: 'Документы — под ключ', desc: 'Cita Previa, оплата Tasa DGT, запись на психотехнику — куратор ведёт через каждый шаг.' },
        ].map(({ icon, title, desc }) => (
          <div class="p-7 rounded-2xl bg-white/[0.02] border border-white/[0.06] hover:border-emerald-500/20 transition-colors">
            <div class="text-3xl mb-4">{icon}</div>
            <h3 class="text-lg font-black text-white mb-2">{title}</h3>
            <p class="text-zinc-500 text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ─── Цены ──────────────────────────────────────────── */}
  <section id="pricing" class="py-24 px-4 bg-[#060a14] relative">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[600px] bg-blue-500/[0.04] rounded-full blur-[150px]"></div>
    </div>
    <div class="relative max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <span class="inline-block text-[10px] uppercase tracking-widest font-bold text-amber-400 bg-amber-500/10 px-3 py-1.5 rounded-full mb-4">Специальное предложение потока</span>
        <h2 class="text-3xl md:text-5xl font-black text-white tracking-tight mb-3">Выберите свой формат</h2>
        <p class="text-zinc-400 max-w-xl mx-auto">Все тарифы включают 2 месяца живых занятий и доступ к тренажёру SkilyApp</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 max-w-4xl mx-auto">
        {[
          {
            name: 'Теория',
            badge: '',
            price: '€199',
            sub: 'Платформа 3 мес · Полная оплата при бронировании',
            features: ['16 живых эфиров (2 мес × 2/нед × 2ч)', 'Платформа Skilyapp на 3 мес в подарок', 'Записи занятий (доступ 30 дней)', 'Общий Telegram-чат учеников'],
            disabled: ['Пошаговые инструкции по сбору документов', 'Полное ведение и запись на экзамен'],
            cta: 'Занять место',
            ctaStyle: 'border border-white/10 bg-white/5 hover:bg-white/10 text-white',
            highlight: false,
          },
          {
            name: 'С сопровождением',
            badge: 'ХИТ ПОТОКА',
            price: '€259',
            sub: 'Платформа 6 мес · Полная оплата при бронировании',
            features: ['16 живых эфиров (2 мес × 2/нед × 2ч)', 'Платформа Skilyapp на 6 мес', 'Записи занятий (сохраняются на 6 месяцев)', 'Закрытый чат с кураторами и преподавателем', 'Испанский для водителей (мини-курс)', 'Пошаговые инструкции по сбору документов'],
            disabled: ['Полное ведение и запись на экзамен (помощь)'],
            cta: 'Занять место →',
            ctaStyle: 'bg-gradient-to-r from-cyan-500 to-blue-600 hover:brightness-110 text-white shadow-xl shadow-blue-500/20',
            highlight: true,
          },
          {
            name: 'VIP',
            badge: 'ПОД КЛЮЧ',
            price: '€349',
            sub: 'Платформа 12 мес · Полная оплата при бронировании',
            features: ['16 живых эфиров (2 мес × 2/нед × 2ч)', 'Платформа Skilyapp на 12 мес (Unlimited)', 'Записи занятий (сохраняются на 12 месяцев)', 'VIP-чат: личная поддержка 24/7', 'Испанский для водителей (мини-курс)', 'Индивидуальный разбор твоих документов', 'Полное ведение и запись на экзамен (помощь)'],
            disabled: [],
            cta: 'Занять место VIP →',
            ctaStyle: 'bg-gradient-to-r from-violet-500 to-purple-600 hover:brightness-110 text-white shadow-xl shadow-violet-500/20',
            highlight: false,
          },
        ].map(({ name, badge, price, sub, features, disabled, cta, ctaStyle, highlight }) => (
          <div class={`relative flex flex-col rounded-[2rem] p-7 ${highlight ? 'bg-gradient-to-b from-[#0d1f3a] to-[#071322] border border-blue-500/30 shadow-2xl shadow-blue-900/30' : 'bg-white/[0.02] border border-white/[0.08]'}`}>
            {badge && (
              <div class={`absolute -top-3 left-6 text-[10px] font-black uppercase tracking-widest px-3 py-1 rounded-full ${highlight ? 'bg-cyan-500 text-white' : 'bg-violet-500 text-white'}`}>
                {badge}
              </div>
            )}
            <h3 class="text-white font-bold text-lg mb-1">{name}</h3>
            <div class="text-4xl font-black text-white mb-1">{price}</div>
            <p class="text-zinc-600 text-[11px] mb-6 leading-snug">{sub}</p>

            <ul class="space-y-2.5 mb-6 flex-1">
              {features.map((f) => (
                <li class="flex items-start gap-2 text-sm text-zinc-300">
                  <span class="text-emerald-400 mt-0.5">✓</span>
                  {f}
                </li>
              ))}
              {disabled.map((f) => (
                <li class="flex items-start gap-2 text-sm text-zinc-600 line-through">
                  <span class="mt-0.5">✕</span>
                  {f}
                </li>
              ))}
            </ul>

            <a
              href="https://t.me/skilyapp_bot?start=course"
              target="_blank"
              rel="noopener noreferrer"
              class={`w-full py-3.5 rounded-2xl font-bold text-sm text-center transition-all ${ctaStyle}`}
            >
              {cta}
            </a>
            <a
              href="https://t.me/skilyapp_bot"
              target="_blank"
              rel="noopener noreferrer"
              class="block text-center text-xs text-zinc-600 hover:text-zinc-400 transition-colors mt-3"
            >
              Задать вопрос в Telegram
            </a>
          </div>
        ))}
      </div>

      <div class="flex flex-wrap items-center justify-center gap-6 mt-12 text-xs text-zinc-500">
        <span class="flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-white/[0.03] border border-white/[0.05]">🔒 Цена фиксируется при бронировании</span>
        <span class="flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-white/[0.03] border border-white/[0.05]">💳 Предоплата 50% · остаток перед стартом</span>
        <span class="flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-white/[0.03] border border-white/[0.05]">✅ Без скрытых платежей</span>
      </div>
    </div>
  </section>

  {/* ─── Последние статьи блога ────────────────────────── */}
  <section class="py-24 px-4 bg-[#060a14]">
    <div class="max-w-5xl mx-auto">
      <div class="flex items-end justify-between mb-10">
        <div>
          <span class="inline-block text-[10px] uppercase tracking-widest font-bold text-blue-400 bg-blue-500/10 px-3 py-1.5 rounded-full mb-3">Блог</span>
          <h2 class="text-3xl md:text-4xl font-black text-white tracking-tight">Полезные материалы</h2>
        </div>
        <a href="/blog" class="text-sm text-zinc-500 hover:text-white transition-colors hidden sm:block">Все статьи →</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        {latestPosts.map((post) => (
          <a href={`/blog/${post.slug}`} class="group flex flex-col rounded-2xl bg-[#0c1523] hover:bg-[#0f1a2b] transition-all border border-white/[0.05] hover:border-blue-500/20 overflow-hidden">
            <div class="p-6 flex flex-col flex-1">
              {post.data.tags?.[0] && (
                <span class="inline-block text-[10px] uppercase tracking-widest font-bold text-blue-400 bg-blue-500/10 px-2 py-0.5 rounded-full mb-3 self-start">
                  {post.data.tags[0]}
                </span>
              )}
              <h3 class="font-bold text-white text-base leading-snug mb-2 group-hover:text-blue-300 transition-colors line-clamp-2">
                {post.data.title}
              </h3>
              <p class="text-zinc-500 text-xs leading-relaxed flex-1 line-clamp-3">{post.data.description}</p>
              <div class="flex items-center justify-between mt-4 pt-4 border-t border-white/5">
                <span class="text-[10px] text-zinc-600">
                  {post.data.pubDate.toLocaleDateString('ru-RU', { month: 'short', year: 'numeric' })}
                </span>
                <span class="text-xs text-zinc-500 group-hover:text-blue-400 transition-colors font-medium">Читать →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/blog" class="inline-block text-sm text-zinc-500 hover:text-white border border-white/10 hover:border-white/20 px-6 py-2.5 rounded-xl transition-all">
          Все статьи блога →
        </a>
      </div>
    </div>
  </section>

  {/* ─── CTA финальный ─────────────────────────────────── */}
  <section class="py-24 px-4 bg-[#060a14]">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-3xl md:text-5xl font-black text-white mb-4 tracking-tight">Готов сдать с первого раза?</h2>
      <p class="text-zinc-500 mb-10 leading-relaxed">Более 1000 русскоязычных уже получили права в Испании с нашим курсом.</p>
      <a
        href="https://t.me/skilyapp_bot?start=course"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block px-12 py-5 rounded-2xl bg-gradient-to-r from-blue-600 to-cyan-500 text-white font-black text-xl shadow-2xl shadow-blue-500/20 hover:scale-105 active:scale-95 transition-all"
      >
        Занять место в потоке →
      </a>
    </div>
  </section>
</BaseLayout>
