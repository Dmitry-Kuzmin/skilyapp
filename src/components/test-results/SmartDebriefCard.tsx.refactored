/**
 * SmartDebriefCard V2 - Refactored with Zustand
 * 
 * Clean architecture:
 * - Business logic → useAIAnalysis hook
 * - AI prompts → aiPrompts.ts
 * - State → Zustand store
 * - UI → Separate components
 * 
 * Result: ~250 lines instead of 1500+
 */

import { useState, memo, useEffect } from 'react';
import { createPortal } from 'react-dom';
import { motion, AnimatePresence } from 'framer-motion';
import {
  X, RefreshCw, Brain, Copy, Target, Lightbulb,
  AlertCircle, CheckCircle2, Image as ImageIcon
} from 'lucide-react';
import { Button } from '@/components/ui/button';
import { cn } from '@/lib/utils';
import { AILimitReachedModal } from '@/components/ai/AILimitReachedModal';
import { getImageUrl } from '@/utils/imageUtils';
import { useIsMobile } from '@/hooks/use-mobile';
import { Drawer, DrawerContent, DrawerHeader, DrawerTitle, DrawerDescription } from '@/components/ui/drawer';
import { useProfileData } from '@/hooks/useProfileData';
import { useAIAnalysis } from '@/hooks/useAIAnalysis';
import { TriggerCardInitial, TriggerCardDone } from './TriggerCards';
import type { FailedQuestion, StudentStats } from '@/utils/aiPrompts';
import ReactMarkdown from 'react-markdown';

interface SmartDebriefCardProps {
  failedQuestions: FailedQuestion[];
  weakTopic?: string;
  country?: 'russia' | 'spain' | string;
  studentStats?: StudentStats;
}

const SmartDebriefCard = memo(function SmartDebriefCard({
  failedQuestions,
  country = 'russia',
  studentStats,
}: SmartDebriefCardProps) {
  const platform = useIsMobile() ? 'mobile' : 'web';
  const isMobile = platform === 'mobile';

  const [resultModalOpen, setResultModalOpen] = useState(false);
  const { profileData } = useProfileData();

  // 🔥 ВСЯ ЛОГИКА В ХУКЕ
  const {
    data: analysisData,
    isLoading,
    error,
    limitModalOpen,
    analyze,
    setLimitModalOpen,
    isServerPremium,
  } = useAIAnalysis(
    failedQuestions,
    country,
    studentStats || (profileData ? {
      name: profileData.first_name || 'Студент',
      xp: 0,
      streak: 0,
    } : undefined)
  );

  // Guards
  if (!failedQuestions || failedQuestions.length === 0) return null;

  const handleAnalyze = async () => {
    await analyze();
    // Модал откроется автоматически через useEffect когда данные загрузятся
  };

  const handleRetry = () => {
    analyze();
  };

  // Auto-open modal when analysis completes
  useEffect(() => {
    if (analysisData && !error && !isLoading) {
      setResultModalOpen(true);
    }
  }, [analysisData, error, isLoading]);

  // Severity styling
  const getSeverityStyles = (severity: string) => {
    switch (severity) {
      case 'critical':
        return 'from-red-500/20 via-orange-500/10 to-red-500/20 border-red-500/40';
      case 'high':
        return 'from-orange-500/20 via-yellow-500/10 to-orange-500/20 border-orange-500/40';
      case 'medium':
        return 'from-yellow-500/20 via-amber-500/10 to-yellow-500/20 border-amber-500/40';
      default:
        return 'from-blue-500/20 via-indigo-500/10 to-blue-500/20 border-blue-500/40';
    }
  };

  const getSeverityIcon = (severity: string) => {
    if (severity === 'critical' || severity === 'high') return AlertCircle;
    return CheckCircle2;
  };

  // Render Analysis Content
  const renderAnalysisContent = () => {
    if (!analysisData) return null;

    const SeverityIcon = getSeverityIcon(analysisData.severity);

    return (
      <div className="space-y-6">
        {/* Summary */}
        <div className="bg-gradient-to-br from-purple-500/10 to-indigo-500/10 border border-purple-500/20 rounded-lg p-6">
          <div className="flex items-start gap-4">
            <div className="p-3 bg-purple-500/20 rounded-lg">
              <Brain className="w-6 h-6 text-purple-400" />
            </div>
            <div className="flex-1">
              <h4 className="text-lg font-semibold text-white mb-2">
                {analysisData.summary || analysisData.greeting || 'Анализ завершён'}
              </h4>
            </div>
          </div>
        </div>

        {/* Diagnosis */}
        <div className={cn(
          "bg-gradient-to-br border rounded-lg p-6",
          getSeverityStyles(analysisData.severity)
        )}>
          <div className="flex items-start gap-4">
            <div className="p-3 bg-white/10 rounded-lg">
              <SeverityIcon className="w-6 h-6 text-white" />
            </div>
            <div className="flex-1">
              <h4 className="text-lg font-semibold text-white mb-2">
                {analysisData.diagnosisTitle || 'Диагностика'}
              </h4>
              <p className="text-gray-200 leading-relaxed">
                {analysisData.diagnosisBody || analysisData.diagnosis || 'Анализ выполнен'}
              </p>
            </div>
          </div>

          {/* Tags */}
          {analysisData.tags && analysisData.tags.length > 0 && (
            <div className="flex flex-wrap gap-2 mt-4">
              {analysisData.tags.map((tag, idx) => (
                <span
                  key={idx}
                  className="px-3 py-1 bg-white/10 border border-white/20 rounded-full text-sm text-white"
                >
                  {tag}
                </span>
              ))}
            </div>
          )}
        </div>

        {/* Logic Steps */}
        {analysisData.logicSteps && analysisData.logicSteps.length > 0 && (
          <div className="space-y-4">
            <h4 className="text-lg font-semibold text-white flex items-center gap-2">
              <Target className="w-5 h-5 text-indigo-400" />
              Логика решений
            </h4>
            {analysisData.logicSteps.map((step, idx) => {
              const questionData = step.questionId
                ? failedQuestions.find((q) => q.questionId === step.questionId)
                : null;

              return (
                <div
                  key={idx}
                  className="bg-gray-800/50 border border-gray-700 rounded-lg p-6 space-y-4"
                >
                  {questionData?.imageUrl && (
                    <div className="relative rounded-lg overflow-hidden bg-gray-900">
                      <img
                        src={getImageUrl(questionData.imageUrl)}
                        alt="Вопрос"
                        className="w-full h-auto"
                      />
                      <div className="absolute top-3 left-3 bg-black/70 px-2 py-1 rounded flex items-center gap-1">
                        <ImageIcon className="w-4 h-4 text-blue-400" />
                        <span className="text-xs text-white">Вопрос #{idx + 1}</span>
                      </div>
                    </div>
                  )}

                  <div className="prose prose-invert max-w-none">
                    <ReactMarkdown>{step.step}</ReactMarkdown>
                  </div>

                  {step.source && (
                    <div className="text-xs text-gray-500 border-t border-gray-700 pt-3">
                      📖 Источник: {step.source}
                    </div>
                  )}
                </div>
              );
            })}
          </div>
        )}

        {/* Mnemonic */}
        {analysisData.mnemonic && (
          <div className="bg-gradient-to-br from-amber-500/10 to-yellow-500/10 border border-amber-500/30 rounded-lg p-6">
            <div className="flex items-start gap-4">
              <Lightbulb className="w-6 h-6 text-amber-400 flex-shrink-0" />
              <div>
                <h4 className="text-lg font-semibold text-white mb-2">Лайфхак запоминания</h4>
                <p className="text-gray-200 leading-relaxed italic">"{analysisData.mnemonic}"</p>
              </div>
            </div>
          </div>
        )}
      </div>
    );
  };

  // Modal/Drawer Content
  const modalContent = (
    <div className="space-y-6">
      <div className="flex items-center justify-between">
        <div className="flex items-center gap-3">
          <div className="p-2 bg-purple-500/20 rounded-lg">
            <Brain className="w-6 h-6 text-purple-400" />
          </div>
          <div>
            <h3 className="text-xl font-bold text-white">AI Дебрифинг</h3>
            <p className="text-sm text-gray-400">Персональный анализ ошибок</p>
          </div>
        </div>
        {!isMobile && (
          <Button
            variant="ghost"
            size="icon"
            onClick={() => setResultModalOpen(false)}
            className="text-gray-400 hover:text-white"
          >
            <X className="w-5 h-5" />
          </Button>
        )}
      </div>

      {isLoading ? (
        <div className="flex flex-col items-center justify-center py-12">
          <motion.div
            animate={{ rotate: 360 }}
            transition={{ duration: 2, repeat: Infinity, ease: 'linear' }}
          >
            <Brain className="w-16 h-16 text-purple-400" />
          </motion.div>
          <p className="text-white mt-4">Анализирую твои ошибки...</p>
        </div>
      ) : error ? (
        <div className="text-center py-12">
          <AlertCircle className="w-16 h-16 text-red-400 mx-auto mb-4" />
          <p className="text-white mb-4">{error}</p>
          <Button onClick={handleRetry} variant="outline">
            <RefreshCw className="w-4 h-4 mr-2" />
            Попробовать снова
          </Button>
        </div>
      ) : (
        <div className="max-h-[70vh] overflow-y-auto pr-2">
          {renderAnalysisContent()}
        </div>
      )}
    </div>
  );

  return (
    <>
      {/* Trigger Card */}
      {analysisData ? (
        <TriggerCardDone onClick={() => setResultModalOpen(true)} />
      ) : (
        <TriggerCardInitial onClick={handleAnalyze} disabled={isLoading} />
      )}

      {/* Result Modal/Drawer */}
      {isMobile ? (
        <Drawer open={resultModalOpen} onOpenChange={setResultModalOpen}>
          <DrawerContent>
            <DrawerHeader>
              <DrawerTitle>AI Дебрифинг</DrawerTitle>
              <DrawerDescription>Персональный анализ ошибок</DrawerDescription>
            </DrawerHeader>
            <div className="p-4">{modalContent}</div>
          </DrawerContent>
        </Drawer>
      ) : (
        <AnimatePresence>
          {resultModalOpen &&
            createPortal(
              <motion.div
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                exit={{ opacity: 0 }}
                className="fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm p-4"
                onClick={() => setResultModalOpen(false)}
              >
                <motion.div
                  initial={{ scale: 0.9, opacity: 0 }}
                  animate={{ scale: 1, opacity: 1 }}
                  exit={{ scale: 0.9, opacity: 0 }}
                  onClick={(e) => e.stopPropagation()}
                  className="bg-gray-900 border border-gray-700 rounded-2xl shadow-2xl max-w-4xl w-full max-h-[90vh] overflow-hidden"
                >
                  <div className="p-6">{modalContent}</div>
                </motion.div>
              </motion.div>,
              document.body
            )}
        </AnimatePresence>
      )}

      {/* Limit Modal */}
      <AILimitReachedModal
        isOpen={limitModalOpen}
        onClose={() => setLimitModalOpen(false)}
        isPremium={isServerPremium}
      />
    </>
  );
});

export default SmartDebriefCard;
