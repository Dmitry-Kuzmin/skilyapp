{
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    },
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Vary",
          "value": "Accept-Encoding"
        }
      ]
    },
    {
      "source": "/noise.svg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://web.telegram.org https://telegram.org https://*.telegram.org;"
        },
        {
          "key": "Accept-CH",
          "value": "DPR, Viewport-Width, Width"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/curso",
      "destination": "/curso.html"
    },
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/pricing",
      "destination": "/pricing.html"
    },
    {
      "source": "/help",
      "destination": "/help.html"
    },
    {
      "source": "/features",
      "destination": "/features.html"
    },
    {
      "source": "/partners",
      "destination": "/partners.html"
    },
    {
      "source": "/blog",
      "destination": "/blog.html"
    },
    {
      "source": "/tests",
      "destination": "/tests.html"
    },
    {
      "source": "/games",
      "destination": "/games.html"
    },
    {
      "source": "/road-signs",
      "destination": "/road-signs.html"
    },
    {
      "source": "/dictionary",
      "destination": "/dictionary.html"
    },
    {
      "source": "/learning-map",
      "destination": "/learning-map.html"
    },
    {
      "source": "/achievements",
      "destination": "/achievements.html"
    },
    {
      "source": "/referrals",
      "destination": "/referrals.html"
    },
    {
      "source": "/dgt-tests",
      "destination": "/dgt-tests.html"
    },
    {
      "source": "/guides",
      "destination": "/guides.html"
    },
    {
      "source": "/guides/:slug",
      "destination": "/guides/:slug.html"
    },
    {
      "source": "/article/:slug",
      "destination": "/article/:slug.html"
    },
    {
      "source": "/legal/:tab",
      "destination": "/legal/:tab.html"
    },
    {
      "source": "/((?!assets|favicon|manifest|robot\\.txt|sitemap\\.xml|sw\\.js|workbox-.*\\.js|.*\\.js|.*\\.map|.*\\.css|.*\\.png|.*\\.jpg|.*\\.jpeg|.*\\.gif|.*\\.ico|.*\\.svg|.*\\.webp|.*\\.mp3|.*\\.wav|.*\\.json).*)",
      "destination": "/index.html"
    }
  ]
}
